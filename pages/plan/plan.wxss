п»ҝ/* ===== з’ҒвҖіеһқжӨӨ?===== */
.container {
  background: var(--bg);
  min-height: 100vh;
  padding-bottom: 160rpx;
}

/* жӨӨе •е„ҙйҸҚеҝҘзҙ°йҸҚеӣ©о„· + йҸӮжқҝо–ғйҺёеӨҗжҢі */
.top-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 24rpx 16rpx;
}
.tabs {
  display: flex;
  background: #f0f0f0;
  border-radius: 50rpx;
  padding: 6rpx;
  /* gap: 4rpx; */
}
.tab {
  padding: 12rpx 32rpx;
  border-radius: 40rpx;
  font-size: 26rpx;
  color: #666;
  transition: all 0.2s;
}
.tab.active {
  background: var(--green);
  color: #fff;
  font-weight: 700;
}

.btn-add {
  background: var(--green);
  color: #fff;
  border-radius: 40rpx;
  padding: 14rpx 28rpx;
  font-size: 26rpx;
  font-weight: 600;
  line-height: 1.4;
  box-shadow: 0 4rpx 12rpx rgba(7,193,96,0.3);
  white-space: nowrap;
}

/* з’ҒвҖіеһқйҚ’жҘ„гҖғ */
.plan-list {
  padding: 0 24rpx;
  display: flex;
  flex-direction: column;
  /* gap: 16rpx; */
}

/* з’ҒвҖіеһқйҚ—пј„еў– */
.plan-card {
  background: #fff;
  border-radius: 20rpx;
  display: flex;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}

/* е®ёпёҝжҷ¶з»”ж ЁжҪҜй”ӣе Ҙо–Ғй‘№еҸүеҜңжөјжЁәеҺӣз»ҫСҚзҙҡ*/
.plan-left-bar {
  width: 8rpx;
  background: var(--green);
  flex-shrink: 0;
}
.plan-card.urgent .plan-left-bar { background: var(--red); }
.plan-card.low    .plan-left-bar { background: var(--text-3); }
.plan-card.done   .plan-left-bar { background: var(--green); }

.plan-body { flex: 1; padding: 24rpx 20rpx 20rpx 20rpx; }

/* жӨӨжғ°о”‘ */
.plan-top {
  display: flex;
  align-items: center;
  /* gap: 16rpx; */
  margin-bottom: 16rpx;
}
.check-circle {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  border: 3rpx solid #ddd;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  font-size: 22rpx;
  color: #fff;
  transition: all 0.2s;
}
.check-circle.checked {
  background: var(--green);
  border-color: var(--green);
}
.plan-title {
  flex: 1;
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a1a;
}
.plan-title.strike {
  text-decoration: line-through;
  color: #aaa;
}
.delete-btn { flex-shrink: 0; }
.delete-icon { font-size: 34rpx; }

/* йҸҚеӣ©о„·зҗӣ?*/
.plan-tags {
  display: flex;
  align-items: center;
  /* gap: 10rpx; */
  flex-wrap: wrap;
  margin-bottom: 16rpx;
}
.tag {
  display: inline-block;
  padding: 4rpx 14rpx;
  border-radius: 8rpx;
  font-size: 20rpx;
  font-weight: 600;
}
.tag-green  { background: var(--green-light); color: var(--green); }
.tag-orange { background: var(--orange-light); color: var(--orange); }
.tag-red    { background: var(--red-light); color: var(--red); }
.tag-blue   { background: var(--blue-light); color: var(--blue); }
.tag-date { font-size: 22rpx; color: #aaa; }

/* жқ©ж¶ҳе®ійҸү?*/
.plan-progress-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10rpx;
}
.progress-label { font-size: 22rpx; color: #aaa; }
.progress-pct { font-size: 24rpx; font-weight: 700; color: #aaa; }
.progress-pct.green { color: var(--green); }
.progress-bar {
  height: 8rpx;
  background: #f0f0f0;
  border-radius: 8rpx;
  overflow: hidden;
}
.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--green), var(--green));
  border-radius: 8rpx;
  transition: width 0.4s;
}
.plan-card.urgent .progress-fill { background: linear-gradient(90deg, var(--red), var(--red)); }

/* жөјжЁәеҺӣз»ҫСҮвӮ¬еӨӢе«Ё */
.modal-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}
.modal-label { font-size: 28rpx; color: #555; }
.priority-row { display: flex; /* gap: 12rpx; */ }
.pri-btn {
  padding: 10rpx 24rpx;
  border-radius: 40rpx;
  font-size: 24rpx;
  background: #f0f0f0;
  color: #666;
  border: 2rpx solid transparent;
}
.pri-btn.active-green  { background: var(--green-light); color: var(--green); border-color: var(--green); }
.pri-btn.active-orange { background: var(--orange-light); color: var(--orange); border-color: var(--orange); }
.pri-btn.active-red    { background: var(--red-light); color: var(--red); border-color: var(--red); }

.date-picker {
  padding: 12rpx 20rpx;
  background: var(--bg);
  border-radius: 12rpx;
  font-size: 26rpx;
  color: #333;
  min-width: 180rpx;
  text-align: center;
}

/* еҜ®еңӯзҚҘйҚҗе‘Ҝж®‘жқҲж’іеҸҶеҰ—?йҲҘ?е®ёиҢ¬ж•ұйҚҸг„Ҙзң¬ app.wxss зјҒзҶ¶з«ҙз’Ғеү§з–Ҷ */

/* еҜ®еңӯзҚҘйҚҗе‘Ҝж®‘йҸӮеӣЁж№°йҚ©?*/
.modal-textarea-wrap {
  margin-bottom: 20rpx;
}
.modal-textarea {
  width: 100%;
  min-height: 120rpx;
  background: #f4f6f8;
  border-radius: 16rpx;
  padding: 20rpx;
  font-size: 26rpx;
  box-sizing: border-box;
}

/* ===== е®ёпёҪзІҰйҚ’зҠ»ж«Һй”ӣе Јо…ёйҚ’жҺ—гҖүй”ӣ?===== */
.swipe-area {
  position: relative;
  overflow: hidden;
  border-radius: 20rpx;
  margin-bottom: 16rpx;
}
.swipe-card {
  width: 100%;
  height: auto;
  min-height: 80rpx;
}
.swipe-card .plan-card {
  transition: box-shadow 0.2s, opacity 0.2s;
}
.swipe-card .plan-card.swiped {
  box-shadow: -4rpx 4rpx 16rpx rgba(0,0,0,0.1);
  opacity: 0.85;
}
.swipe-delete-btn {
  position: absolute;
  right: 0;
  top: 0;
  bottom: 0;
  width: 160rpx;
  background: linear-gradient(135deg, #FF4D4F, #CF1322);
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 0 20rpx 20rpx 0;
  z-index: 1;
}
.swipe-delete-text {
  color: #fff;
  font-size: 28rpx;
  font-weight: 700;
}
.swipe-hint {
  font-size: 20rpx;
  color: #ccc;
  flex-shrink: 0;
  white-space: nowrap;
  animation: hintPulse 2s ease-in-out infinite;
}
@keyframes hintPulse {
  0%, 100% { opacity: 0.5; }
  50% { opacity: 1; }
}

/* з»Ңиҷ№е§ёйҺ¬?*/
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
  /* gap: 16rpx; */
}
.empty-emoji { font-size: 80rpx; }
.empty-text { font-size: 28rpx; color: #aaa; }


