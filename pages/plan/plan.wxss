/* ===== 计划页 ===== */
.container {
  background: #f4f6f8;
  min-height: 100vh;
  padding-bottom: 160rpx;
}

/* 顶部栏：标签 + 新增按钮 */
.top-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 24rpx 16rpx;
}
.tabs {
  display: flex;
  background: #f0f0f0;
  border-radius: 50rpx;
  padding: 6rpx;
  gap: 4rpx;
}
.tab {
  padding: 12rpx 32rpx;
  border-radius: 40rpx;
  font-size: 26rpx;
  color: #666;
  transition: all 0.2s;
}
.tab.active {
  background: #07C160;
  color: #fff;
  font-weight: 700;
}

.btn-add {
  background: #07C160;
  color: #fff;
  border-radius: 40rpx;
  padding: 14rpx 28rpx;
  font-size: 26rpx;
  font-weight: 600;
  line-height: 1.4;
  box-shadow: 0 4rpx 12rpx rgba(7,193,96,0.3);
  white-space: nowrap;
}

/* 计划列表 */
.plan-list {
  padding: 0 24rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

/* 计划卡片 */
.plan-card {
  background: #fff;
  border-radius: 20rpx;
  display: flex;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}

/* 左侧竖条（颜色按优先级）*/
.plan-left-bar {
  width: 8rpx;
  background: #07C160;
  flex-shrink: 0;
}
.plan-card.urgent .plan-left-bar { background: #F56C6C; }
.plan-card.low    .plan-left-bar { background: #B8C0CC; }
.plan-card.done   .plan-left-bar { background: #07C160; }

.plan-body { flex: 1; padding: 24rpx 20rpx 20rpx 20rpx; }

/* 顶行 */
.plan-top {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 16rpx;
}
.check-circle {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  border: 3rpx solid #ddd;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  font-size: 22rpx;
  color: #fff;
  transition: all 0.2s;
}
.check-circle.checked {
  background: #07C160;
  border-color: #07C160;
}
.plan-title {
  flex: 1;
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a1a;
}
.plan-title.strike {
  text-decoration: line-through;
  color: #aaa;
}
.delete-btn { flex-shrink: 0; }
.delete-icon { font-size: 34rpx; }

/* 标签行 */
.plan-tags {
  display: flex;
  align-items: center;
  gap: 10rpx;
  flex-wrap: wrap;
  margin-bottom: 16rpx;
}
.tag {
  display: inline-block;
  padding: 4rpx 14rpx;
  border-radius: 8rpx;
  font-size: 20rpx;
  font-weight: 600;
}
.tag-green  { background: #E8F8EF; color: #07C160; }
.tag-orange { background: #FFF3E0; color: #E6A23C; }
.tag-red    { background: #FEF0F0; color: #F56C6C; }
.tag-blue   { background: #E3F2FD; color: #1976D2; }
.tag-date { font-size: 22rpx; color: #aaa; }

/* 进度条 */
.plan-progress-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10rpx;
}
.progress-label { font-size: 22rpx; color: #aaa; }
.progress-pct { font-size: 24rpx; font-weight: 700; color: #aaa; }
.progress-pct.green { color: #07C160; }
.progress-bar {
  height: 8rpx;
  background: #f0f0f0;
  border-radius: 8rpx;
  overflow: hidden;
}
.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #2ECC71, #07C160);
  border-radius: 8rpx;
  transition: width 0.4s;
}
.plan-card.urgent .progress-fill { background: linear-gradient(90deg, #FF6B6B, #F56C6C); }

/* 优先级选择 */
.modal-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}
.modal-label { font-size: 28rpx; color: #555; }
.priority-row { display: flex; gap: 12rpx; }
.pri-btn {
  padding: 10rpx 24rpx;
  border-radius: 40rpx;
  font-size: 24rpx;
  background: #f0f0f0;
  color: #666;
  border: 2rpx solid transparent;
}
.pri-btn.active-green  { background: #E8F8EF; color: #07C160; border-color: #07C160; }
.pri-btn.active-orange { background: #FFF3E0; color: #E6A23C; border-color: #E6A23C; }
.pri-btn.active-red    { background: #FEF0F0; color: #F56C6C; border-color: #F56C6C; }

.date-picker {
  padding: 12rpx 20rpx;
  background: #f7f8fa;
  border-radius: 12rpx;
  font-size: 26rpx;
  color: #333;
  min-width: 180rpx;
  text-align: center;
}
.modal-textarea-wrap { margin-bottom: 20rpx; }

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
  gap: 16rpx;
}
.empty-emoji { font-size: 80rpx; }
.empty-text { font-size: 28rpx; color: #aaa; }
