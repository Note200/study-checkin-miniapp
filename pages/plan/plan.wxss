/* ===== 计划页 ===== */
.container {
  background: var(--bg);
  min-height: 100vh;
  padding-bottom: 160rpx;
}

/* 顶部栏：标签 + 新增按钮 */
.top-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 24rpx 16rpx;
}
.tabs {
  display: flex;
  background: #f0f0f0;
  border-radius: 50rpx;
  padding: 6rpx;
  gap: 4rpx;
}
.tab {
  padding: 12rpx 32rpx;
  border-radius: 40rpx;
  font-size: 26rpx;
  color: #666;
  transition: all 0.2s;
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 56rpx;
}
.tab.active {
  background: var(--green);
  color: #fff;
  font-weight: 700;
}

.btn-add {
  background: var(--green);
  color: #fff;
  border-radius: 40rpx;
  padding: 14rpx 28rpx;
  font-size: 26rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 56rpx;
  box-shadow: 0 4rpx 12rpx rgba(7,193,96,0.3);
  white-space: nowrap;
}

/* 计划列表 */
.plan-list {
  padding: 0 24rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

/* 计划卡片 */
.plan-card {
  background: #fff;
  border-radius: 20rpx;
  display: flex;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}

/* 左侧竖条（颜色按优先级）*/
.plan-left-bar {
  width: 8rpx;
  background: var(--green);
  flex-shrink: 0;
}
.plan-card.urgent .plan-left-bar { background: var(--red); }
.plan-card.low    .plan-left-bar { background: var(--text-3); }
.plan-card.done   .plan-left-bar { background: var(--green); }

.plan-body { flex: 1; padding: 24rpx 20rpx 20rpx 20rpx; }

/* 顶行 */
.plan-top {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 16rpx;
}
.check-circle {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  border: 3rpx solid #ddd;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  font-size: 22rpx;
  color: #fff;
  transition: all 0.2s;
}
.check-circle.checked {
  background: var(--green);
  border-color: var(--green);
}
.plan-title {
  flex: 1;
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a1a;
}
.plan-title.strike {
  text-decoration: line-through;
  color: #aaa;
}
.delete-btn { flex-shrink: 0; }
.delete-icon { font-size: 34rpx; }

/* 标签行 */
.plan-tags {
  display: flex;
  align-items: center;
  gap: 10rpx;
  flex-wrap: wrap;
  margin-bottom: 16rpx;
}
.tag {
  display: inline-block;
  padding: 4rpx 14rpx;
  border-radius: 8rpx;
  font-size: 20rpx;
  font-weight: 600;
}
.tag-green  { background: var(--green-light); color: var(--green); }
.tag-orange { background: var(--orange-light); color: var(--orange); }
.tag-red    { background: var(--red-light); color: var(--red); }
.tag-blue   { background: var(--blue-light); color: var(--blue); }
.tag-date { font-size: 22rpx; color: #aaa; }

/* 进度条 */
.plan-progress-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10rpx;
}
.progress-label { font-size: 22rpx; color: #aaa; }
.progress-pct { font-size: 24rpx; font-weight: 700; color: #aaa; }
.progress-pct.green { color: var(--green); }
.progress-bar {
  height: 8rpx;
  background: #f0f0f0;
  border-radius: 8rpx;
  overflow: hidden;
}
.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--green), var(--green));
  border-radius: 8rpx;
  transition: width 0.4s;
}
.plan-card.urgent .progress-fill { background: linear-gradient(90deg, var(--red), var(--red)); }

/* 优先级选择 */
.modal-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}
.modal-label { font-size: 28rpx; color: #555; }
.priority-row { display: flex; gap: 12rpx; }
.pri-btn {
  padding: 10rpx 24rpx;
  border-radius: 40rpx;
  font-size: 24rpx;
  background: #f0f0f0;
  color: #666;
  border: 2rpx solid transparent;
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 48rpx;
}
.pri-btn.active-green  { background: var(--green-light); color: var(--green); border-color: var(--green); }
.pri-btn.active-orange { background: var(--orange-light); color: var(--orange); border-color: var(--orange); }
.pri-btn.active-red    { background: var(--red-light); color: var(--red); border-color: var(--red); }

.date-picker {
  padding: 12rpx 20rpx;
  background: var(--bg);
  border-radius: 12rpx;
  font-size: 26rpx;
  color: #333;
  min-width: 180rpx;
  text-align: center;
}

/* 弹窗内的输入框 — 已由全局 app.wxss 统一设置 */

/* 弹窗内的文本域 */
.modal-textarea-wrap {
  margin-bottom: 20rpx;
}
.modal-textarea {
  width: 100%;
  min-height: 120rpx;
  background: #f4f6f8;
  border-radius: 16rpx;
  padding: 20rpx;
  font-size: 26rpx;
  box-sizing: border-box;
}

/* ===== 左滑删除（计划页） ===== */
.swipe-wrapper {
  position: relative;
  overflow: hidden;
  border-radius: 20rpx;
  margin-bottom: 16rpx;
}
.swipe-inner {
  display: flex;
  transition: transform 0.2s ease;
}
.swipe-inner .plan-card {
  flex: 1;
  min-width: 100%;
}
.swipe-delete-btn {
  position: absolute;
  right: 0;
  top: 0;
  bottom: 0;
  width: 160rpx;
  background: linear-gradient(135deg, #FF4D4F, #CF1322);
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 0 20rpx 20rpx 0;
  z-index: 1;
}
.swipe-delete-text {
  color: #fff;
  font-size: 28rpx;
  font-weight: 700;
}
.swipe-hint {
  font-size: 20rpx;
  color: #ccc;
  flex-shrink: 0;
  white-space: nowrap;
  animation: hintPulse 2s ease-in-out infinite;
}
@keyframes hintPulse {
  0%, 100% { opacity: 0.5; }
  50% { opacity: 1; }
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
  gap: 16rpx;
}
.empty-emoji { font-size: 80rpx; }
.empty-text { font-size: 28rpx; color: #aaa; }

/* 内容预览 */
.content-preview {
  margin-bottom: 12rpx;
  padding: 12rpx 16rpx;
  background: #f8f9fa;
  border-radius: 12rpx;
  font-size: 24rpx;
  color: #888;
  line-height: 1.5;
  max-height: 72rpx;
  overflow: hidden;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

/* 长按反馈 */
.plan-card:active {
  opacity: 0.85;
  transform: scale(0.98);
}
