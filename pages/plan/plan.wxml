<view class="container">

  <!-- 鏍囩鏍?+ 鏂板鎸夐挳 -->
  <view class="top-bar">
    <view class="tabs">
      <view class="tab {{activeTab === 0 ? 'active' : ''}}" data-index="0" bindtap="switchTab">鍏ㄩ儴</view>
      <view class="tab {{activeTab === 1 ? 'active' : ''}}" data-index="1" bindtap="switchTab">杩涜涓?/view>
      <view class="tab {{activeTab === 2 ? 'active' : ''}}" data-index="2" bindtap="switchTab">宸插畬鎴?/view>
    </view>
    <view class="btn-add" bindtap="showAdd">+ 鏂板</view>
  </view>

  <!-- 璁″垝鍒楄〃 -->
  <view class="plan-list" wx:if="{{plans.length > 0}}">
    <movable-area class="swipe-area" wx:for="{{plans}}" wx:key="id" style="height:auto;">
      <movable-view
        class="swipe-card"
        direction="horizontal"
        x="{{item._x || 0}}"
        damping="30"
        friction="5"
        out-of-bounds
        bindchange="onSwipeChange"
        data-index="{{index}}"
        id="swipe-{{index}}">
        <!-- 鍓嶆櫙鍗＄墖 -->
        <view
          class="plan-card card-animate {{item.status === 1 ? 'done' : ''}} {{item.priority === 2 ? 'urgent' : item.priority === 0 ? 'low' : ''}} {{item._x < -60 ? 'swiped' : ''}}"
          bindlongpress="onLongPress"
          data-id="{{item.id}}"
          data-title="{{item.title}}"
          data-content="{{item.content}}"
          data-plan-date="{{item.planDate}}"
          data-priority="{{item.priority}}"
          data-status="{{item.status}}">
          <!-- 宸︿晶褰╄壊绔栨潯 -->
          <view class="plan-left-bar"></view>

          <view class="plan-body">
            <!-- 椤堕儴锛氬嬀閫?+ 鏍囬 -->
            <view class="plan-top">
              <view
                class="check-circle {{item.status === 1 ? 'checked' : ''}}"
                data-id="{{item.id}}"
                data-status="{{item.status}}"
                bindtap="togglePlan">
                <view wx:if="{{item.status === 1}}">鉁?/view>
              </view>
              <view class="plan-title {{item.status === 1 ? 'strike' : ''}}">{{item.title}}</view>
              <view class="swipe-hint"><view>鈫?婊戝姩</view></view>
            </view>

            <!-- 鏍囩琛岋細浼樺厛绾?+ 鏃ユ湡 -->
            <view class="plan-tags">
              <view class="tag {{item.priority === 2 ? 'tag-red' : item.priority === 1 ? 'tag-orange' : 'tag-green'}}">
                {{item.priority === 2 ? '绱ф€? : item.priority === 1 ? '鏅€? : '瀹芥澗'}}
              </view>
              <view class="tag-date">鈴?{{item.planDate}}</view>
            </view>

            <!-- 鍐呭棰勮 -->
            <view class="content-preview" wx:if="{{item.content}}">
              <view>{{item.content}}</view>
            </view>

            <!-- 杩涘害鏉?-->
            <view class="plan-progress-row">
              <view class="progress-label">瀹屾垚杩涘害</view>
              <view class="progress-pct {{item.status === 1 ? 'green' : ''}}">{{item.status === 1 ? '100%' : (item.progress || 0) + '%'}}</view>
            </view>
            <view class="progress-bar">
              <view class="progress-fill" style="width: {{item.status === 1 ? 100 : (item.progress || 0)}}%"></view>
            </view>
          </view>
        </view>
        <!-- 婊戝嚭鍚庣殑鍒犻櫎鎸夐挳 -->
        <view class="swipe-delete-btn" catchtap="deletePlan" data-id="{{item.id}}">
          <view class="swipe-delete-text">鍒犻櫎</view>
        </view>
      </movable-view>
    </movable-area>
  </view>

  <!-- 绌虹姸鎬?-->
  <view class="empty-state" wx:if="{{plans.length === 0}}">
    <view class="empty-emoji">馃搵</view>
    <view class="empty-text">杩樻病鏈夎鍒掞紝娣诲姞涓€涓惂</view>
  </view>

  <!-- FAB -->
  <view class="fab" bindtap="showAdd">+</view>

  <!-- 娣诲姞寮圭獥 -->
  <view class="modal-mask" wx:if="{{showAddModal}}" bindtap="closeModal">
    <view class="modal-content" catchtap="preventClose">
      <view class="modal-title">娣诲姞瀛︿範璁″垝</view>
      <view class="form-input-group">
        <input class="input" placeholder="璁″垝鏍囬" data-field="title" bindinput="onInput" value="{{newPlan.title}}"/>
      </view>
      <view class="modal-textarea-wrap">
        <viewarea class="modal-textarea" placeholder="璁″垝璇︽儏锛堝彲閫夛級" data-field="content" bindinput="onInput" value="{{newPlan.content}}"/>
      </view>
      <view class="modal-row">
        <view class="modal-label">浼樺厛绾?/text>
        <view class="priority-row">
          <view class="pri-btn {{newPlan.priority === 0 ? 'active-green' : ''}}" data-val="0" bindtap="setPriority">瀹芥澗</view>
          <view class="pri-btn {{newPlan.priority === 1 ? 'active-orange' : ''}}" data-val="1" bindtap="setPriority">鏅€?/view>
          <view class="pri-btn {{newPlan.priority === 2 ? 'active-red' : ''}}" data-val="2" bindtap="setPriority">绱ф€?/view>
        </view>
      </view>
      <view class="modal-row">
        <view class="modal-label">璁″垝鏃ユ湡</view>
        <picker mode="date" value="{{newPlan.planDate}}" bindchange="onDateChange">
          <view class="date-picker">{{newPlan.planDate || '閫夋嫨鏃ユ湡'}}</view>
        </picker>
      </view>
      <view class="modal-actions">
        <button class="modal-btn cancel" bindtap="closeModal">鍙栨秷</button>
        <button class="modal-btn confirm" bindtap="submitPlan">纭娣诲姞</button>
      </view>
    </view>
  </view>

  <!-- 缂栬緫寮圭獥 -->
  <view class="modal-mask" wx:if="{{showEditModal}}" bindtap="closeEditModal">
    <view class="modal-content" catchtap="preventClose">
      <view class="modal-title">缂栬緫璁″垝</view>
      <view class="form-input-group">
        <input class="input" placeholder="璁″垝鏍囬" data-field="title" bindinput="onEditInput" value="{{editPlan.title}}"/>
      </view>
      <view class="modal-textarea-wrap">
        <viewarea class="modal-textarea" placeholder="璁″垝璇︽儏锛堝彲閫夛級" data-field="content" bindinput="onEditInput" value="{{editPlan.content}}"/>
      </view>
      <view class="modal-row">
        <view class="modal-label">浼樺厛绾?/text>
        <view class="priority-row">
          <view class="pri-btn {{editPlan.priority === 0 ? 'active-green' : ''}}" data-val="0" bindtap="setEditPriority">瀹芥澗</view>
          <view class="pri-btn {{editPlan.priority === 1 ? 'active-orange' : ''}}" data-val="1" bindtap="setEditPriority">鏅€?/view>
          <view class="pri-btn {{editPlan.priority === 2 ? 'active-red' : ''}}" data-val="2" bindtap="setEditPriority">绱ф€?/view>
        </view>
      </view>
      <view class="modal-row">
        <view class="modal-label">璁″垝鏃ユ湡</view>
        <picker mode="date" value="{{editPlan.planDate}}" bindchange="onEditDateChange">
          <view class="date-picker">{{editPlan.planDate || '閫夋嫨鏃ユ湡'}}</view>
        </picker>
      </view>
      <view class="modal-actions">
        <button class="modal-btn cancel" bindtap="closeEditModal">鍙栨秷</button>
        <button class="modal-btn confirm" bindtap="submitEditPlan">淇濆瓨淇敼</button>
      </view>
    </view>
  </view>

</view>
