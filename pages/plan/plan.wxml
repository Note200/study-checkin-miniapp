<view class="container">

  <!-- 标签栏 + 新增按钮 -->
  <view class="top-bar">
    <view class="tabs">
      <view class="tab {{activeTab === 0 ? 'active' : ''}}" data-index="0" bindtap="switchTab">全部</view>
      <view class="tab {{activeTab === 1 ? 'active' : ''}}" data-index="1" bindtap="switchTab">进行中</view>
      <view class="tab {{activeTab === 2 ? 'active' : ''}}" data-index="2" bindtap="switchTab">已完成</view>
    </view>
    <view class="btn-add" bindtap="showAdd">+ 新增</view>
  </view>

  <!-- 计划列表 -->
  <view class="plan-list" wx:if="{{plans.length > 0}}">
    <movable-area class="swipe-area" wx:for="{{plans}}" wx:key="id" style="height:auto;">
      <movable-view
        class="swipe-card"
        direction="horizontal"
        x="{{item._x || 0}}"
        damping="30"
        friction="5"
        out-of-bounds
        bindchange="onSwipeChange"
        data-index="{{index}}"
        id="swipe-{{index}}">
        <!-- 前景卡片 -->
        <view
          class="plan-card card-animate {{item.status === 1 ? 'done' : ''}} {{item.priority === 2 ? 'urgent' : item.priority === 0 ? 'low' : ''}} {{item._x < -60 ? 'swiped' : ''}}"
          bindlongpress="onLongPress"
          data-id="{{item.id}}"
          data-title="{{item.title}}"
          data-content="{{item.content}}"
          data-plan-date="{{item.planDate}}"
          data-priority="{{item.priority}}"
          data-status="{{item.status}}">
          <!-- 左侧彩色竖条 -->
          <view class="plan-left-bar"></view>

          <view class="plan-body">
            <!-- 顶部：勾选 + 标题 -->
            <view class="plan-top">
              <view
                class="check-circle {{item.status === 1 ? 'checked' : ''}}"
                data-id="{{item.id}}"
                data-status="{{item.status}}"
                bindtap="togglePlan">
                <view wx:if="{{item.status === 1}}">✓</view>
              </view>
              <text class="plan-title {{item.status === 1 ? 'strike' : ''}}">{{item.title}}</text>
              <view class="swipe-hint"><view>← 滑动</view></view>
            </view>

            <!-- 标签行：优先级 + 日期 -->
            <view class="plan-tags">
              <text class="tag {{item.priority === 2 ? 'tag-red' : item.priority === 1 ? 'tag-orange' : 'tag-green'}}">
                {{item.priority === 2 ? '紧急' : item.priority === 1 ? '普通' : '宽松'}}
              </text>
              <text class="tag-date">⏰ {{item.planDate}}</text>
            </view>

            <!-- 内容预览 -->
            <view class="content-preview" wx:if="{{item.content}}">
              <text>{{item.content}}</text>
            </view>

            <!-- 进度条 -->
            <view class="plan-progress-row">
              <text class="progress-label">完成进度</text>
              <text class="progress-pct {{item.status === 1 ? 'green' : ''}}">{{item.status === 1 ? '100%' : (item.progress || 0) + '%'}}</text>
            </view>
            <view class="progress-bar">
              <view class="progress-fill" style="width: {{item.status === 1 ? 100 : (item.progress || 0)}}%"></view>
            </view>
          </view>
        </view>
        <!-- 滑出后的删除按钮 -->
        <view class="swipe-delete-btn" catchtap="deletePlan" data-id="{{item.id}}">
          <view class="swipe-delete-text">删除</view>
        </view>
      </movable-view>
    </movable-area>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{plans.length === 0}}">
    <view class="empty-emoji">📋</view>
    <view class="empty-text">还没有计划，添加一个吧</view>
  </view>

  <!-- FAB -->
  <view class="fab" bindtap="showAdd">+</view>

  <!-- 添加弹窗 -->
  <view class="modal-mask" wx:if="{{showAddModal}}" bindtap="closeModal">
    <view class="modal-content" catchtap="preventClose">
      <view class="modal-title">添加学习计划</view>
      <view class="form-input-group">
        <input class="input" placeholder="计划标题" data-field="title" bindinput="onInput" value="{{newPlan.title}}"/>
      </view>
      <view class="modal-textarea-wrap">
        <textarea class="modal-textarea" placeholder="计划详情（可选）" data-field="content" bindinput="onInput" value="{{newPlan.content}}"/>
      </view>
      <view class="modal-row">
        <text class="modal-label">优先级</text>
        <view class="priority-row">
          <view class="pri-btn {{newPlan.priority === 0 ? 'active-green' : ''}}" data-val="0" bindtap="setPriority">宽松</view>
          <view class="pri-btn {{newPlan.priority === 1 ? 'active-orange' : ''}}" data-val="1" bindtap="setPriority">普通</view>
          <view class="pri-btn {{newPlan.priority === 2 ? 'active-red' : ''}}" data-val="2" bindtap="setPriority">紧急</view>
        </view>
      </view>
      <view class="modal-row">
        <text class="modal-label">计划日期</text>
        <picker mode="date" value="{{newPlan.planDate}}" bindchange="onDateChange">
          <view class="date-picker">{{newPlan.planDate || '选择日期'}}</view>
        </picker>
      </view>
      <view class="modal-actions">
        <button class="modal-btn cancel" bindtap="closeModal">取消</button>
        <button class="modal-btn confirm" bindtap="submitPlan">确认添加</button>
      </view>
    </view>
  </view>

  <!-- 编辑弹窗 -->
  <view class="modal-mask" wx:if="{{showEditModal}}" bindtap="closeEditModal">
    <view class="modal-content" catchtap="preventClose">
      <view class="modal-title">编辑计划</view>
      <view class="form-input-group">
        <input class="input" placeholder="计划标题" data-field="title" bindinput="onEditInput" value="{{editPlan.title}}"/>
      </view>
      <view class="modal-textarea-wrap">
        <textarea class="modal-textarea" placeholder="计划详情（可选）" data-field="content" bindinput="onEditInput" value="{{editPlan.content}}"/>
      </view>
      <view class="modal-row">
        <text class="modal-label">优先级</text>
        <view class="priority-row">
          <view class="pri-btn {{editPlan.priority === 0 ? 'active-green' : ''}}" data-val="0" bindtap="setEditPriority">宽松</view>
          <view class="pri-btn {{editPlan.priority === 1 ? 'active-orange' : ''}}" data-val="1" bindtap="setEditPriority">普通</view>
          <view class="pri-btn {{editPlan.priority === 2 ? 'active-red' : ''}}" data-val="2" bindtap="setEditPriority">紧急</view>
        </view>
      </view>
      <view class="modal-row">
        <text class="modal-label">计划日期</text>
        <picker mode="date" value="{{editPlan.planDate}}" bindchange="onEditDateChange">
          <view class="date-picker">{{editPlan.planDate || '选择日期'}}</view>
        </picker>
      </view>
      <view class="modal-actions">
        <button class="modal-btn cancel" bindtap="closeEditModal">取消</button>
        <button class="modal-btn confirm" bindtap="submitEditPlan">保存修改</button>
      </view>
    </view>
  </view>

</view>
