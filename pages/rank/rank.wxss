/* ===== 排行榜页面 ===== */
.container {
  background: var(--bg);
  min-height: 100vh;
}

/* 标题栏 */
.page-header {
  background: linear-gradient(135deg, var(--gold) 0%, #FF9600 100%);
  padding: 40rpx 32rpx 48rpx;
  text-align: center;
}
.page-title {
  font-size: 40rpx;
  font-weight: 800;
  color: #fff;
  display: block;
}
.page-sub {
  font-size: 24rpx;
  color: rgba(255,255,255,0.9);
  margin-top: 8rpx;
  display: block;
  font-weight: 600;
}

/* 前三名奖台 */
.podium {
  display: flex;
  align-items: flex-end;
  justify-content: center;
  padding: 32rpx 24rpx;
  gap: 16rpx;
  margin: -20rpx 24rpx 0;
  position: relative;
  z-index: 2;
}
.podium-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
  gap: 8rpx;
}
.podium-avatar-wrap {
  position: relative;
}
.podium-avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  border: 4rpx solid #fff;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.1);
}
.first .podium-avatar {
  width: 112rpx;
  height: 112rpx;
}
.podium-crown {
  position: absolute;
  top: -20rpx;
  left: 50%;
  transform: translateX(-50%);
  font-size: 32rpx;
}
.podium-name {
  font-size: 24rpx;
  font-weight: 700;
  color: var(--text-1);
  text-align: center;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 160rpx;
  display: block;
}
.podium-bar {
  border-radius: 16rpx 16rpx 0 0;
  padding: 16rpx 0;
  width: 100%;
  text-align: center;
}
.first-bar { background: var(--gold); height: 120rpx; }
.second-bar { background: #C0C0C0; height: 90rpx; }
.third-bar { background: #CD7F32; height: 70rpx; display: flex; align-items: center; justify-content: center; }
.podium-count {
  font-size: 24rpx;
  font-weight: 800;
  color: #fff;
  display: block;
}

/* 排名列表 */
.rank-list {
  padding: 16rpx 24rpx;
}
.rank-list .rank-item:nth-child(1) { animation-delay: 0s; }
.rank-list .rank-item:nth-child(2) { animation-delay: 0.06s; }
.rank-list .rank-item:nth-child(3) { animation-delay: 0.12s; }
.rank-list .rank-item:nth-child(4) { animation-delay: 0.18s; }
.rank-list .rank-item:nth-child(5) { animation-delay: 0.24s; }
.rank-list .rank-item:nth-child(n+6) { animation-delay: 0.3s; }
.rank-item {
  display: flex;
  align-items: center;
  padding: 24rpx 20rpx;
  background: var(--card-bg);
  border-radius: 16rpx;
  margin-bottom: 12rpx;
  gap: 20rpx;
  border: 2rpx solid var(--border);
  box-shadow: var(--shadow-sm);
}
.rank-item.me {
  background: var(--green-light);
  border-color: var(--green);
  box-shadow: 0 4rpx 16rpx rgba(88,204,2,0.15);
}
.rank-num {
  width: 56rpx;
  height: 56rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 800;
  color: var(--text-3);
  background: var(--bg);
  flex-shrink: 0;
}
.rank-1 { background: var(--gold); color: #fff; }
.rank-2 { background: #C0C0C0; color: #fff; }
.rank-3 { background: #CD7F32; color: #fff; }
.rank-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  flex-shrink: 0;
}
.rank-info { flex: 1; }
.rank-name {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text-1);
  display: block;
}
.rank-label {
  font-size: 22rpx;
  color: var(--green);
  font-weight: 600;
  display: block;
  margin-top: 4rpx;
}
.rank-score {
  display: flex;
  align-items: baseline;
  gap: 4rpx;
}
.rank-count {
  font-size: 36rpx;
  font-weight: 800;
  color: var(--green);
}
.rank-unit {
  font-size: 22rpx;
  color: var(--text-3);
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
  gap: 16rpx;
}
.empty-emoji { font-size: 80rpx; }
.empty-text { font-size: 28rpx; color: var(--text-3); }
