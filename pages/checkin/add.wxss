/* ===== 添加打卡任务页 ===== */
page { background: #f4f6f8; }
.container { padding: 32rpx 24rpx; }
.page-title { margin-bottom: 36rpx; }
.page-title text:first-child { font-size: 40rpx; font-weight: 700; color: #1a1a1a; display: block; }
.page-subtitle { font-size: 26rpx; color: #aaa; }

.form-section { background: #fff; border-radius: 20rpx; padding: 28rpx 24rpx; margin-bottom: 24rpx; box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.05); }
.form-label { font-size: 26rpx; color: #555; margin-bottom: 12rpx; display: block; }
.form-input {
  width: 100%; background: #f7f8fa; border-radius: 14rpx;
  padding: 24rpx; font-size: 28rpx; box-sizing: border-box;
  border: 2rpx solid transparent;
}
.form-input:focus { border-color: #07C160; background: #fff; }

.type-wrap { display: flex; gap: 16rpx; }
.type-btn {
  flex: 1; padding: 20rpx 0; border-radius: 16rpx; text-align: center;
  font-size: 28rpx; background: #f7f8fa; color: #666; border: 2rpx solid transparent;
}
.type-btn.active { background: #E8F8EF; color: #07C160; border-color: #07C160; font-weight: 700; }

.btn-submit {
  width: 100%; background: #07C160; color: #fff;
  border-radius: 50rpx; font-size: 32rpx; font-weight: 700;
  padding: 28rpx 0; border: none; margin-top: 8rpx;
  box-shadow: 0 6rpx 20rpx rgba(7,193,96,0.3);
}
.btn-submit:active { transform: scale(0.97); }
