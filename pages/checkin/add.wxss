/* ===== 娣诲姞鎵撳崱浠诲姟椤?===== */
page { background: #f4f6f8; }
.container { padding: 32rpx 24rpx; }
.page-title { margin-bottom: 36rpx; }
.page-title text:first-child { font-size: 40rpx; font-weight: 700; color: #1a1a1a; display: block; }
.page-subtitle { font-size: 26rpx; color: #aaa; }

/* 琛ㄥ崟 */
.form { display: flex; flex-direction: column; /* gap: 0; */ }
.form-item {
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx 28rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.05);
}
.label {
  font-size: 26rpx;
  color: #555;
  margin-bottom: 16rpx;
  display: block;
  font-weight: 600;
}

/* 杈撳叆妗?*/
.input-wrap {
  background: #f7f8fa;
  border-radius: 14rpx;
  padding: 0 24rpx;
  border: 2rpx solid transparent;
  transition: border 0.2s;
}
.input-wrap:focus-within {
  border-color: #07C160;
  background: #fff;
}
.input {
  height: 88rpx;
  font-size: 28rpx;
  color: #1a1a1a;
  width: 100%;
}

/* 浠诲姟绫诲瀷閫夋嫨 */
.type-list {
  display: flex;
  /* gap: 16rpx; */
}
.type-item {
  flex: 1;
  background: #f7f8fa;
  border-radius: 16rpx;
  padding: 24rpx 16rpx;
  text-align: center;
  border: 2rpx solid transparent;
  transition: all 0.2s;
  display: flex;
  flex-direction: column;
  align-items: center;
  /* gap: 8rpx; */
}
.type-item.active {
  background: #E8F8EF;
  border-color: #07C160;
}
.type-icon { font-size: 40rpx; }
.type-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}
.type-item.active .type-name { color: #07C160; }
.type-desc {
  font-size: 22rpx;
  color: #aaa;
}
.type-item.active .type-desc { color: #07C160; }

/* 閫夋嫨鍣?*/
.picker-wrap { margin-top: 4rpx; }
.picker {
  background: #f7f8fa;
  border-radius: 14rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  color: #1a1a1a;
  border: 2rpx solid transparent;
  transition: border 0.2s;
}

/* 澶嶉€夋 */
.checkbox-wrap { margin-top: 4rpx; }
.checkbox-item {
  display: flex;
  align-items: center;
  /* gap: 12rpx; */
  font-size: 28rpx;
  color: #555;
}

/* 鎻愪氦鎸夐挳 */
.btn-submit {
  width: 100%;
  background: #07C160;
  color: #fff;
  border-radius: 50rpx;
  font-size: 32rpx;
  font-weight: 700;
  padding: 28rpx 0;
  border: none;
  margin-top: 16rpx;
  box-shadow: 0 6rpx 20rpx rgba(7,193,96,0.3);
}
.btn-submit:active { transform: scale(0.97); }


