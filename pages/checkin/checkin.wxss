/* pages/checkin/checkin.wxss - Modern Design */
.container {
  min-height: 100vh;
  background: #f0f2f8;
  padding: 20rpx;
  padding-bottom: 140rpx;
}

.task-list {
  display: flex;
  flex-direction: column;
}

.task-card {
  background: #fff;
  border-radius: 28rpx;
  padding: 36rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 24rpx rgba(108, 92, 231, 0.06), 0 1rpx 4rpx rgba(0,0,0,0.02);
  position: relative;
  overflow: hidden;
}

.task-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  width: 6rpx;
  height: 100%;
  background: linear-gradient(180deg, #6C5CE7 0%, #a855f7 100%);
  border-radius: 3rpx;
}

.task-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 28rpx;
  padding-left: 16rpx;
}

.task-name {
  font-size: 34rpx;
  font-weight: 700;
  color: #1a1a2e;
  display: block;
  margin-bottom: 10rpx;
}

.task-type {
  font-size: 22rpx;
  color: #6C5CE7;
  background: #f5f3ff;
  padding: 6rpx 18rpx;
  border-radius: 12rpx;
  display: inline-block;
  font-weight: 600;
}

.task-stats {
  text-align: right;
}

.stats-num {
  font-size: 48rpx;
  font-weight: 800;
  background: linear-gradient(135deg, #6C5CE7 0%, #a855f7 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  display: block;
}

.stats-label {
  font-size: 22rpx;
  color: #9ca3af;
}

.task-progress {
  margin-bottom: 28rpx;
  padding-left: 16rpx;
}

.progress-bar {
  height: 10rpx;
  background: #f0f2f8;
  border-radius: 5rpx;
  overflow: hidden;
  margin-bottom: 12rpx;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #6C5CE7 0%, #a855f7 100%);
  border-radius: 5rpx;
}

.progress-text {
  font-size: 24rpx;
  color: #9ca3af;
  font-weight: 500;
}

.task-actions {
  display: flex;
  gap: 16rpx;
  padding-left: 16rpx;
}

.btn-checkin {
  flex: 1;
  background: linear-gradient(135deg, #6C5CE7 0%, #a855f7 100%);
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 40rpx;
  box-shadow: 0 6rpx 20rpx rgba(108, 92, 231, 0.3);
}

.btn-checkin:active {
  transform: scale(0.97);
}

.btn-checkin.checked {
  background: #f0f2f8;
  color: #9ca3af;
  box-shadow: none;
  font-weight: 500;
}

.btn-history {
  flex: 1;
  background: #f5f6fa;
  color: #6b7280;
  font-size: 28rpx;
  font-weight: 500;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 40rpx;
}

.btn-history:active {
  background: #ebebf0;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 160rpx 0;
}

.empty-text {
  font-size: 28rpx;
  color: #9ca3af;
  margin-bottom: 32rpx;
}

.btn-add {
  background: linear-gradient(135deg, #6C5CE7 0%, #a855f7 100%);
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
  padding: 24rpx 64rpx;
  border-radius: 52rpx;
  box-shadow: 0 6rpx 20rpx rgba(108, 92, 231, 0.3);
}

.fab {
  position: fixed;
  right: 36rpx;
  bottom: 100rpx;
  width: 108rpx;
  height: 108rpx;
  background: linear-gradient(135deg, #6C5CE7 0%, #a855f7 100%);
  border-radius: 54rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 12rpx 36rpx rgba(108, 92, 231, 0.4);
  z-index: 100;
}

.fab:active {
  transform: scale(0.9);
}

.fab-icon {
  font-size: 52rpx;
  color: #fff;
  font-weight: 300;
  line-height: 1;
}

/* 打卡弹窗 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(10, 10, 30, 0.45);
  backdrop-filter: blur(6px);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  background: #fff;
  border-radius: 32rpx;
  padding: 48rpx 40rpx;
  width: 600rpx;
  box-sizing: border-box;
  box-shadow: 0 24rpx 60rpx rgba(0,0,0,0.12);
}

.modal-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1a1a2e;
  margin-bottom: 24rpx;
  text-align: center;
}

.modal-task-name {
  font-size: 28rpx;
  color: #6C5CE7;
  text-align: center;
  margin-bottom: 32rpx;
  background: #f5f3ff;
  padding: 14rpx 28rpx;
  border-radius: 16rpx;
  display: inline-block;
  font-weight: 600;
}

.modal-textarea {
  width: 100%;
  height: 160rpx;
  padding: 24rpx;
  border: none;
  background: #f5f6fa;
  border-radius: 20rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  display: block;
  color: #1a1a2e;
  margin-bottom: 32rpx;
}

.modal-actions {
  display: flex;
  gap: 20rpx;
}

.modal-btn {
  flex: 1;
  height: 92rpx;
  line-height: 92rpx;
  border-radius: 46rpx;
  font-size: 28rpx;
  font-weight: 600;
  padding: 0;
  margin: 0;
}

.modal-btn.cancel {
  background: #f0f2f8;
  color: #6b7280;
}

.modal-btn.confirm {
  background: linear-gradient(135deg, #6C5CE7 0%, #a855f7 100%);
  color: #fff;
  box-shadow: 0 6rpx 18rpx rgba(108, 92, 231, 0.3);
}

.history-modal {
  height: 700rpx;
  display: flex;
  flex-direction: column;
}

.history-list {
  flex: 1;
  max-height: 480rpx;
}

.history-item {
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f5f6fa;
}

.history-date {
  font-size: 26rpx;
  color: #6C5CE7;
  margin-bottom: 8rpx;
  font-weight: 600;
}

.history-remark {
  font-size: 28rpx;
  color: #4b5563;
}
