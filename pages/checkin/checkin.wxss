/* ===== 打卡页 ===== */
.container {
  background: #f4f6f8;
  min-height: 100vh;
  padding-bottom: 160rpx;
}

.section-hd {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 28rpx 12rpx;
}
.section-title { font-size: 32rpx; font-weight: 700; color: #1a1a1a; }
.section-month { font-size: 26rpx; color: #999; }

/* 任务列表 */
.task-list { padding: 0 24rpx; display: flex; flex-direction: column; gap: 16rpx; }

.task-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}

/* 课程图标 */
.task-icon-wrap {
  width: 88rpx;
  height: 88rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.task-icon { font-size: 40rpx; }

.task-info { flex: 1; }
.task-name { font-size: 30rpx; font-weight: 600; color: #1a1a1a; display: block; }
.task-sub-row { display: flex; align-items: center; gap: 6rpx; margin-top: 6rpx; }
.task-clock { font-size: 20rpx; }
.task-sub { font-size: 22rpx; color: #aaa; }

/* 打卡按钮 */
.btn-checkin {
  background: #07C160;
  color: #fff;
  border-radius: 40rpx;
  font-size: 26rpx;
  font-weight: 600;
  padding: 14rpx 28rpx;
  border: none;
  box-shadow: 0 4rpx 12rpx rgba(7,193,96,0.3);
  line-height: 1.2;
  flex-shrink: 0;
}
.btn-checkin:active { transform: scale(0.95); }
.btn-checkin.checked {
  background: #f2f3f5;
  color: #07C160;
  box-shadow: none;
  border: 2rpx solid #07C160;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
  gap: 20rpx;
}
.empty-emoji { font-size: 80rpx; }
.empty-text { font-size: 28rpx; color: #999; }
.btn-create {
  background: #07C160;
  color: #fff;
  border-radius: 40rpx;
  font-size: 28rpx;
  padding: 18rpx 48rpx;
  border: none;
  margin-top: 10rpx;
}

/* 日历卡片 */
.calendar-card {
  margin: 0 24rpx;
  margin-top: 0;
}
.week-row {
  display: flex;
  justify-content: space-around;
  margin-bottom: 16rpx;
}
.week-label {
  font-size: 24rpx;
  color: #aaa;
  width: calc(100% / 7);
  text-align: center;
}
.date-grid {
  display: flex;
  flex-wrap: wrap;
}
.date-cell {
  width: calc(100% / 7);
  aspect-ratio: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  color: #555;
  margin-bottom: 8rpx;
}
.date-cell.empty { visibility: hidden; }
.date-cell.checked {
  background: #07C160;
  color: #fff;
  border-radius: 50%;
  font-weight: 700;
}
.date-cell.today {
  background: #E8F8EF;
  color: #07C160;
  border-radius: 50%;
  font-weight: 700;
  border: 2rpx solid #07C160;
}
.date-cell.checked.today {
  background: #07C160;
  color: #fff;
}

/* 历史弹窗 */
.modal-task-name {
  text-align: center;
  font-size: 30rpx;
  font-weight: 600;
  color: #07C160;
  margin-bottom: 24rpx;
}
.modal-textarea-wrap { margin-bottom: 16rpx; }
.history-modal { max-height: 80vh; }
.history-list { max-height: 400rpx; }
.history-item {
  display: flex;
  justify-content: space-between;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f2f3f5;
  font-size: 26rpx;
}
.history-date { color: #07C160; font-weight: 600; }
.history-remark { color: #999; flex: 1; text-align: right; padding-left: 20rpx; }
