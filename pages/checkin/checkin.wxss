/* ===== 打卡页 ===== */
.container {
  background: #f4f6f8;
  min-height: 100vh;
  padding-bottom: 160rpx;
}

.section-hd {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 28rpx 12rpx;
}
.section-title { font-size: 32rpx; font-weight: 700; color: #1a1a1a; }
.section-month { font-size: 26rpx; color: #999; }

/* 任务列表 */
.task-list { padding: 0 24rpx; display: flex; flex-direction: column; gap: 16rpx; }

.task-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}

/* 课程图标 */
.task-icon-wrap {
  width: 88rpx;
  height: 88rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.task-icon { font-size: 40rpx; }

.task-info { flex: 1; min-width: 0; overflow: hidden; }
.task-name { font-size: 30rpx; font-weight: 600; color: #1a1a1a; display: block; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.task-sub-row { display: flex; align-items: center; gap: 6rpx; margin-top: 6rpx; }
.task-clock { font-size: 20rpx; }
.task-sub { font-size: 22rpx; color: #aaa; }

/* 打卡按钮 */
.btn-checkin {
  background: #07C160;
  color: #fff;
  border-radius: 40rpx;
  font-size: 26rpx;
  font-weight: 600;
  padding: 14rpx 28rpx;
  border: none;
  box-shadow: 0 4rpx 12rpx rgba(7,193,96,0.3);
  line-height: 1.2;
  flex-shrink: 0;
}
.btn-checkin:active { transform: scale(0.95); }
.btn-checkin.checked {
  background: #f2f3f5;
  color: #07C160;
  box-shadow: none;
  border: 2rpx solid #07C160;
}

/* ===== 左滑删除（打卡页） ===== */
.swipe-area {
  position: relative;
  overflow: hidden;
  border-radius: 20rpx;
}
.swipe-card {
  width: 100%;
  height: auto;
  min-height: 80rpx;
}
.swipe-card .task-card {
  transition: box-shadow 0.2s, opacity 0.2s;
}
.swipe-card .task-card.swiped {
  box-shadow: -4rpx 4rpx 16rpx rgba(0,0,0,0.1);
  opacity: 0.85;
}
.task-del-btn {
  position: absolute;
  right: 0;
  top: 0;
  bottom: 0;
  width: 160rpx;
  background: linear-gradient(135deg, #FF4D4F, #CF1322);
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 0 20rpx 20rpx 0;
  z-index: 1;
}
.swipe-hint-small {
  font-size: 18rpx;
  color: #ccc;
  flex-shrink: 0;
  white-space: nowrap;
  animation: hintPulse 2s ease-in-out infinite;
}

/* 删除按钮（保留原样式作为备用） */
.btn-delete {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: #f2f3f5;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.btn-delete:active { background: #e8e8e8; }
.delete-icon { font-size: 28rpx; }

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
  gap: 20rpx;
}
.empty-emoji { font-size: 80rpx; }
.empty-text { font-size: 28rpx; color: #999; }
.btn-create {
  background: #07C160;
  color: #fff;
  border-radius: 40rpx;
  font-size: 28rpx;
  padding: 18rpx 48rpx;
  border: none;
  margin-top: 10rpx;
}

/* 日历卡片 */
.calendar-card {
  margin: 0 24rpx;
  margin-top: 0;
}
.week-row {
  display: flex;
  justify-content: space-around;
  margin-bottom: 16rpx;
}
.week-label {
  font-size: 24rpx;
  color: #aaa;
  width: calc(100% / 7);
  text-align: center;
}
.date-grid {
  display: flex;
  flex-wrap: wrap;
}
.date-cell {
  width: calc(100% / 7);
  aspect-ratio: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  color: #555;
  margin-bottom: 4rpx;
  border-radius: 12rpx;
  transition: all 0.2s;
}
.date-cell.empty { visibility: hidden; }
.date-cell.today {
  color: #07C160;
  font-weight: 800;
  box-shadow: inset 0 0 0 3rpx #07C160;
}
.date-cell.selected {
  background: var(--blue) !important;
  color: #fff !important;
  font-weight: 700;
  box-shadow: 0 4rpx 12rpx rgba(28,176,246,0.35);
}
.date-cell.selected.heat-0 { color: #fff !important; }
/* 热力图等级颜色 */
.date-cell.heat-0 { background: #f8f9fa; }
.date-cell.heat-1 { background: #c6f6d5; color: #276749; }
.date-cell.heat-2 { background: #68d391; color: #fff; font-weight: 600; }
.date-cell.heat-3 { background: #38a169; color: #fff; font-weight: 700; }
.date-cell.heat-4 { background: #07C160; color: #fff; font-weight: 800; }

/* 热力图图例 */
.heat-legend {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 6rpx;
  margin-top: 16rpx;
  padding-top: 12rpx;
  border-top: 1rpx solid #f2f3f5;
}
.legend-label { font-size: 20rpx; color: #aaa; }
.legend-dot {
  width: 24rpx;
  height: 24rpx;
  border-radius: 6rpx;
}
.legend-dot.heat-0 { background: #f8f9fa; border: 1rpx solid #e0e0e0; }
.legend-dot.heat-1 { background: #c6f6d5; }
.legend-dot.heat-2 { background: #68d391; }
.legend-dot.heat-3 { background: #38a169; }
.legend-dot.heat-4 { background: #07C160; }

/* 历史弹窗 */
.modal-task-name {
  text-align: center;
  font-size: 30rpx;
  font-weight: 600;
  color: #07C160;
  margin-bottom: 24rpx;
}
.modal-textarea-wrap { margin-bottom: 16rpx; }
.history-modal { max-height: 80vh; }
.history-list { max-height: 400rpx; }
.history-item {
  display: flex;
  justify-content: space-between;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f2f3f5;
  font-size: 26rpx;
}
.history-date { color: #07C160; font-weight: 600; }
.history-remark { color: #999; flex: 1; text-align: right; padding-left: 20rpx; }

/* 打卡成功动画 */
.success-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
  animation: fadeIn 0.3s ease;
}
@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}
.success-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
  animation: popIn 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
}
@keyframes popIn {
  0% { transform: scale(0.5); opacity: 0; }
  100% { transform: scale(1); opacity: 1; }
}
.success-circle {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: #07C160;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 32rpx rgba(7,193,96,0.4);
}
.success-check.animate {
  animation: checkBounce 0.6s ease 0.2s both;
}
@keyframes checkBounce {
  0% { transform: scale(0); }
  50% { transform: scale(1.3); }
  100% { transform: scale(1); }
}
.check-mark {
  font-size: 80rpx;
  color: #fff;
  font-weight: 700;
}
.success-text {
  font-size: 40rpx;
  font-weight: 700;
  color: #fff;
}
.success-sub {
  font-size: 28rpx;
  color: rgba(255,255,255,0.8);
}

/* 撒花粒子 */
.confetti-container {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  overflow: hidden;
  pointer-events: none;
  z-index: 999;
}
.confetti {
  position: absolute;
  top: -20rpx;
  width: 16rpx;
  height: 16rpx;
  animation: confettiFall linear forwards;
}
.confetti-circle { border-radius: 50%; }
.confetti-square { border-radius: 2rpx; }
.confetti-star {
  clip-path: polygon(50% 0%, 61% 35%, 98% 35%, 68% 57%, 79% 91%, 50% 70%, 21% 91%, 32% 57%, 2% 35%, 39% 35%);
}
@keyframes confettiFall {
  0% { transform: translateY(0) rotate(0deg); opacity: 1; }
  100% { transform: translateY(100vh) rotate(720deg); opacity: 0; }
}
