<view class="container">

  <!-- 今日打卡任务（支持左滑删除） -->
  <view class="section-hd">
    <text class="section-title">今日打卡任务</text>
  </view>

  <view class="task-list" wx:if="{{tasks.length > 0}}">
    <movable-area class="swipe-area" wx:for="{{tasks}}" wx:key="id" style="height:auto;">
      <movable-view
        class="swipe-card"
        direction="horizontal"
        x="{{item._x || 0}}"
        damping="30"
        friction="5"
        out-of-bounds
        bindchange="onSwipeChange"
        data-index="{{index}}">
        <!-- 前景卡片 -->
        <view class="task-card card-animate {{item._x < -60 ? 'swiped' : ''}}" data-id="{{item.id}}" bindlongtap="longPressTask">
          <view class="task-icon-wrap" style="background: {{item.iconBg || '#E8F8EF'}}">
            <text class="task-icon">{{item.icon || '📖'}}</text>
          </view>
          <view class="task-info">
            <text class="task-name">{{item.title}}</text>
            <view class="task-sub-row">
              <text class="task-clock">⏱</text>
              <text class="task-sub">目标 {{item.targetMinutes || 30}} 分钟</text>
            </view>
          </view>
          <view
            class="btn-checkin {{item.todayChecked ? 'checked' : ''}}"
            data-id="{{item.id}}"
            bindtap="{{item.todayChecked ? 'undoCheckin' : 'openCheckin'}}">
            {{item.todayChecked ? '已完成' : '打卡'}}
          </view>
          <text class="swipe-hint-small">← 滑动</text>
        </view>
        <!-- 底层删除按钮 -->
        <view class="swipe-delete-btn task-del-btn" catchtap="deleteTask" data-id="{{item.id}}">
          <text class="swipe-delete-text">删除</text>
        </view>
      </movable-view>
    </movable-area>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{tasks.length === 0}}">
    <text class="empty-emoji">✏️</text>
    <text class="empty-text">还没有打卡任务，去创建一个吧</text>
    <button class="btn-create" bindtap="addTask">+ 创建任务</button>
  </view>

  <!-- 本月打卡日历 -->
  <view class="section-hd" style="margin-top: 16rpx;">
    <text class="section-title">本月打卡日历</text>
    <text class="section-month">{{calendarYear}}年{{calendarMonth}}月</text>
  </view>
  <view class="card calendar-card">
    <!-- 星期标题 -->
    <view class="week-row">
      <text wx:for="{{['日','一','二','三','四','五','六']}}" wx:key="*this" class="week-label">{{item}}</text>
    </view>
    <!-- 日期格（热力图） -->
    <view class="date-grid">
      <view
        wx:for="{{calendarDays}}"
        wx:key="*this"
        data-index="{{index}}"
        bindtap="onDateTap"
        class="date-cell {{item.isToday ? 'today' : ''}} {{item.empty ? 'empty' : ''}} {{item.selected ? 'selected' : ''}} {{item.checked ? 'heat-' + item.level : ''}}">
        <text wx:if="{{!item.empty}}">{{item.day}}</text>
      </view>
    </view>
    <!-- 热力图图例 -->
    <view class="heat-legend">
      <text class="legend-label">少</text>
      <view class="legend-dot heat-0"></view>
      <view class="legend-dot heat-1"></view>
      <view class="legend-dot heat-2"></view>
      <view class="legend-dot heat-3"></view>
      <view class="legend-dot heat-4"></view>
      <text class="legend-label">多</text>
    </view>
  </view>

  <!-- FAB -->
  <view class="fab" bindtap="addTask">+</view>

  <!-- 打卡成功动画 + 撒花 -->
  <view class="success-overlay" wx:if="{{showSuccessAnim}}">
    <!-- 撒花粒子 -->
    <view class="confetti-container">
      <view wx:for="{{confettiList}}" wx:key="id"
        class="confetti confetti-{{item.shape}}"
        style="left: {{item.x}}%; background: {{item.color}}; animation-delay: {{item.delay}}s; animation-duration: {{item.duration}}s;"></view>
    </view>
    <view class="success-content">
      <view class="success-circle">
        <view class="success-check {{showSuccessAnim ? 'animate' : ''}}">
          <text class="check-mark">✓</text>
        </view>
      </view>
      <text class="success-text">打卡成功</text>
      <text class="success-sub">继续加油！💪</text>
    </view>
  </view>

  <!-- 打卡弹窗 -->
  <view class="modal-mask" wx:if="{{showCheckinModal}}" bindtap="closeModal">
    <view class="modal-content" catchtap="preventClose">
      <view class="modal-title">今日打卡</view>
      <view class="modal-task-name">{{currentTask.title}}</view>
      <view class="modal-textarea-wrap">
        <textarea class="modal-textarea" placeholder="说点什么吧（可选）" bindinput="onRemarkInput" value="{{checkinRemark}}" style="width:100%;box-sizing:border-box;" />
      </view>
      <view class="modal-actions">
        <button class="modal-btn cancel" bindtap="closeModal">取消</button>
        <button class="modal-btn confirm" bindtap="doCheckin">确认打卡</button>
      </view>
    </view>
  </view>

  <!-- 历史弹窗 -->
  <view class="modal-mask" wx:if="{{showHistory}}" bindtap="closeHistory">
    <view class="modal-content history-modal" catchtap="preventClose">
      <view class="modal-title">打卡历史</view>
      <scroll-view scroll-y class="history-list">
        <view class="history-item" wx:for="{{historyList}}" wx:key="id">
          <view class="history-date">{{item.checkinDate}}</view>
          <view class="history-remark">{{item.remark || '无备注'}}</view>
        </view>
      </scroll-view>
      <button class="modal-btn confirm" bindtap="closeHistory">关闭</button>
    </view>
  </view>

</view>
