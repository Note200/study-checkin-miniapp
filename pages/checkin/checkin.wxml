<view class="container">
  <!-- 打卡任务列表 -->
  <view class="task-list">
    <view class="task-card" wx:for="{{tasks}}" wx:key="id">
      <view class="task-header">
        <view class="task-info">
          <text class="task-name">{{item.title}}</text>
          <text class="task-type">{{item.type === 0 ? '习惯打卡' : '目标打卡'}}</text>
        </view>
        <view class="task-stats">
          <text class="stats-num">{{item.totalDays}}</text>
          <text class="stats-label">累计天数</text>
        </view>
      </view>
      <view class="task-progress">
        <view class="progress-bar">
          <view class="progress-fill" style="width: {{item.progress}}%"></view>
        </view>
        <text class="progress-text">连续 {{item.continueDays}} 天</text>
      </view>
      <view class="task-actions">
        <button class="btn-checkin" data-id="{{item.id}}" bindtap="openCheckin">
          {{item.todayChecked ? '已打卡' : '打卡'}}
        </button>
        <button class="btn-history" data-id="{{item.id}}" bindtap="viewHistory">
          历史
        </button>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{tasks.length === 0}}">
    <text class="empty-text">还没有打卡任务</text>
    <button class="btn-add" bindtap="addTask">创建打卡任务</button>
  </view>

  <!-- 打卡按钮 -->
  <view class="fab" bindtap="addTask">
    <text class="fab-icon">+</text>
  </view>

  <!-- 打卡弹窗 -->
  <view class="modal-mask" wx:if="{{showCheckinModal}}" bindtap="closeModal">
    <view class="modal-content" catchtap="">
      <view class="modal-title">今日打卡</view>
      <view class="modal-task-name">{{currentTask.title}}</view>
      <textarea class="modal-textarea" placeholder="说点什么吧（可选）" bindinput="onRemarkInput" value="{{checkinRemark}}" style="width:100%;box-sizing:border-box;" />
      <view class="modal-actions">
        <button class="modal-btn cancel" bindtap="closeModal">取消</button>
        <button class="modal-btn confirm" bindtap="doCheckin">确认打卡</button>
      </view>
    </view>
  </view>

  <!-- 历史记录弹窗 -->
  <view class="modal-mask" wx:if="{{showHistory}}" bindtap="closeHistory">
    <view class="modal-content history-modal" catchtap="">
      <view class="modal-title">打卡历史</view>
      <scroll-view scroll-y class="history-list">
        <view class="history-item" wx:for="{{historyList}}" wx:key="id">
          <view class="history-date">{{item.checkinDate}}</view>
          <view class="history-remark">{{item.remark || '无备注'}}</view>
        </view>
      </scroll-view>
      <button class="modal-btn" bindtap="closeHistory">关闭</button>
    </view>
  </view>
</view>
