<view class="container">
  <view class="page-title">
    <view>鍒涘缓鎵撳崱</view>
    <view class="page-subtitle">璁惧畾浣犵殑瀛︿範鐩爣</view>
  </view>

  <view class="form">
    <view class="form-item">
      <view class="label">鎵撳崱浠诲姟鍚嶇О</view>
      <view class="input-wrap">
        <input class="input" placeholder="濡傦細姣忔棩鑳屽崟璇? bindinput="onTitleInput" value="{{title}}" />
      </view>
    </view>

    <view class="form-item">
      <view class="label">浠诲姟绫诲瀷</view>
      <view class="type-list">
        <view
          class="type-item {{type === 0 ? 'active' : ''}}"
          data-type="0"
          bindtap="onTypeChange">
          <view class="type-icon">馃攧</view>
          <view class="type-name">涔犳儻鎵撳崱</view>
          <view class="type-desc">姣忓ぉ閮借鎵撳崱</view>
        </view>
        <view
          class="type-item {{type === 1 ? 'active' : ''}}"
          data-type="1"
          bindtap="onTypeChange">
          <view class="type-icon">馃幆</view>
          <view class="type-name">鐩爣鎵撳崱</view>
          <view class="type-desc">鍧氭寔瀹屾垚N澶?/text>
        </view>
      </view>
    </view>

    <view class="form-item">
      <view class="label">鐩爣澶╂暟</view>
      <view class="picker-wrap">
        <picker mode="selector" range="{{days}}" bindchange="onDaysChange">
          <view class="picker">{{targetDays}} 澶?/view>
        </picker>
      </view>
    </view>

    <view class="form-item">
      <view class="label">姣忔鐩爣鏃堕暱</view>
      <view class="picker-wrap">
        <picker mode="selector" range="{{minutes}}" bindchange="onMinutesChange">
          <view class="picker">{{targetMinutes}} 鍒嗛挓</view>
        </picker>
      </view>
    </view>

    <view class="form-item">
      <view class="label">鍏紑鑼冨洿</view>
      <view class="checkbox-wrap">
        <checkbox-group bindchange="onPublicChange">
          <label class="checkbox-item">
            <checkbox value="1" checked="{{isPublic === 1}}" color="#07C160"/>
            <view>鍏紑缁欑彮绾ф垚鍛?/text>
          </label>
        </checkbox-group>
      </view>
    </view>

    <button class="btn-submit" bindtap="submit">鍒涘缓鎵撳崱浠诲姟</button>
  </view>
</view>
