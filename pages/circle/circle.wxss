/* ===== 班级圈页面 ===== */
.container {
  background: var(--bg);
  min-height: 100vh;
  padding-bottom: 40rpx;
}

/* 发布区 */
.publish-card {
  background: #fff;
  margin: 24rpx;
  border-radius: var(--radius-lg);
  padding: 24rpx;
  box-shadow: var(--shadow);
  border: 2rpx solid var(--border);
}
.publish-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}
.publish-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  flex-shrink: 0;
}
.publish-input {
  flex: 1;
  background: var(--bg);
  border-radius: 40rpx;
  padding: 18rpx 28rpx;
  border: 2rpx solid var(--border);
}
.publish-placeholder {
  font-size: 26rpx;
  color: var(--text-3);
}

/* 类型标签 */
.type-tags {
  display: flex;
  gap: 12rpx;
  margin-top: 20rpx;
}
.modal-types {
  justify-content: center;
  margin-top: 24rpx;
  margin-bottom: 12rpx;
}
.type-tag {
  font-size: 22rpx;
  padding: 8rpx 20rpx;
  border-radius: 40rpx;
  background: var(--bg);
  color: var(--text-3);
  font-weight: 600;
  border: 2rpx solid transparent;
}
.type-tag.active-green { background: var(--green-light); color: var(--green-dark); border-color: var(--green); }
.type-tag.active-blue { background: var(--blue-light); color: var(--blue-dark); border-color: var(--blue); }
.type-tag.active-orange { background: var(--orange-light); color: var(--orange-dark); border-color: var(--orange); }

/* 动态列表 */
.post-list {
  padding: 0 24rpx;
}
.post-card {
  background: #fff;
  border-radius: var(--radius-lg);
  padding: 28rpx;
  margin-bottom: 16rpx;
  box-shadow: var(--shadow-sm);
  border: 2rpx solid var(--border);
}
.post-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 16rpx;
}
.post-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  flex-shrink: 0;
}
.post-user-info { flex: 1; }
.post-username {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text-1);
  display: block;
}
.post-meta-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-top: 4rpx;
}
.post-time {
  font-size: 22rpx;
  color: var(--text-3);
}
.post-class-tag {
  font-size: 20rpx;
  background: var(--blue-light);
  color: var(--blue-dark);
  padding: 2rpx 10rpx;
  border-radius: 10rpx;
  font-weight: 700;
}
.post-delete {
  font-size: 24rpx;
  color: var(--red);
  font-weight: 600;
  padding: 8rpx 16rpx;
  flex-shrink: 0;
}
.post-content {
  font-size: 28rpx;
  color: var(--text-1);
  line-height: 1.6;
  padding: 8rpx 0;
}

/* 互动栏 */
.post-actions {
  display: flex;
  gap: 32rpx;
  padding-top: 16rpx;
  border-top: 2rpx solid var(--border);
  margin-top: 12rpx;
}
.action-btn {
  display: flex;
  align-items: center;
  gap: 6rpx;
  font-size: 26rpx;
  color: var(--text-3);
  padding: 6rpx 0;
}
.action-icon { font-size: 30rpx; }
.action-count { font-size: 24rpx; }
.action-btn.liked { color: var(--red); }

/* 评论列表 */
.comments-section {
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 2rpx solid var(--border);
}
.comment-item {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  padding: 10rpx 0;
}
.comment-avatar {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  flex-shrink: 0;
}
.comment-bubble { flex: 1; }
.comment-user { font-size: 24rpx; font-weight: 700; color: var(--text-2); }
.comment-text { font-size: 26rpx; color: var(--text-1); margin-top: 4rpx; line-height: 1.5; }
.comment-time { font-size: 20rpx; color: var(--text-3); margin-top: 4rpx; }
.comment-empty {
  font-size: 26rpx;
  color: var(--text-3);
  text-align: center;
  padding: 20rpx 0;
}
.comment-input-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 16rpx;
}
.comment-input {
  flex: 1;
  height: 64rpx;
  line-height: 64rpx;
  background: var(--bg);
  border-radius: 32rpx;
  padding: 0 24rpx;
  font-size: 26rpx;
  border: 2rpx solid var(--border);
}
.comment-send-btn {
  font-size: 26rpx;
  color: var(--green);
  font-weight: 700;
  padding: 12rpx 20rpx;
}

/* 评论弹窗 */
.comment-modal .circle-textarea {
  min-height: 120rpx;
}

/* 弹窗 */
.circle-textarea {
  width: 100%;
  min-height: 200rpx;
  background: var(--bg);
  border-radius: 16rpx;
  padding: 20rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  line-height: 1.6;
}
.char-count {
  text-align: right;
  font-size: 22rpx;
  color: var(--text-3);
  margin-top: 4rpx;
  display: block;
}

/* ===== modal 弹窗基础样式 ===== */
.modal-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.5);
  z-index: 999;
  display: flex;
  align-items: flex-end;
  justify-content: center;
}
.modal-content {
  background: #fff;
  width: 100%;
  max-height: 80vh;
  border-radius: 24rpx 24rpx 0 0;
  padding: 32rpx 32rpx calc(32rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}
.modal-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-1);
  text-align: center;
  margin-bottom: 24rpx;
}
.modal-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 20rpx;
}
.modal-btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 700;
  border: none;
  margin: 0;
}
.modal-btn.cancel {
  background: var(--bg);
  color: var(--text-2);
}
.modal-btn.confirm {
  background: var(--green);
  color: #fff;
}
.cancel { background: var(--bg) !important; color: var(--text-2) !important; }
.confirm { background: var(--green) !important; color: #fff !important; }

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
  gap: 16rpx;
}
.empty-emoji { font-size: 80rpx; }
.empty-text { font-size: 28rpx; color: var(--text-3); }
