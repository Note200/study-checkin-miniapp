/* ===== 课程表页 ===== */
.container {
  background: var(--bg);
  height: 100vh;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
}

/* 顶部栏 */
.top-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 24rpx;
  background: linear-gradient(135deg, #58CC02 0%, #46a302 100%);
  color: #fff;
}
.week-selector {
  display: flex;
  align-items: center;
  gap: 12rpx;
}
.week-selector-label { font-size: 28rpx; color: rgba(255,255,255,0.85); }
.week-selector-value {
  font-size: 32rpx;
  font-weight: 700;
  color: #fff;
  min-width: 36rpx;
  text-align: center;
}
.view-toggle {
  background: rgba(255,255,255,0.2);
  border-radius: 20rpx;
  padding: 10rpx 24rpx;
  font-size: 24rpx;
  color: #fff;
  font-weight: 600;
}

/* FAB 悬浮按钮 */
.fab {
  position: fixed;
  right: 40rpx;
  bottom: 160rpx;
  width: 96rpx;
  height: 96rpx;
  background: var(--green);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(7,193,96,0.4);
  z-index: 100;
  color: #fff;
  font-size: 48rpx;
}

/* ===== 格子视图 ===== */
.grid-header {
  display: flex;
  background: #fff;
  border-bottom: 2rpx solid #e8e8e8;
}
.grid-corner {
  width: 70rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-right: 1rpx solid #e8e8e8;
  flex-shrink: 0;
}
.grid-corner-text { font-size: 20rpx; color: #999; }
.grid-day-header {
  flex: 1;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-right: 1rpx solid #f0f0f0;
  background: #fff;
}
.grid-day-header:last-child { border-right: none; }
.grid-day-header.today { background: #E8F5E9; }
.grid-day-name { font-size: 24rpx; color: #666; font-weight: 600; }
.grid-day-header.today .grid-day-name { color: #58CC02; }

/* 格子主体 - 用table布局保证等高 */
.grid-body {
  flex: 1;
  overflow-y: auto;
  position: relative;
}
.grid-table {
  width: 100%;
  border-collapse: collapse;
}
.grid-table-row {
  display: flex;
  height: 160rpx;
  border-bottom: 1rpx solid #f0f0f0;
}
.grid-table-row:last-child { border-bottom: none; }
.grid-section-cell {
  width: 70rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-right: 1rpx solid #e8e8e8;
  flex-shrink: 0;
  background: #fafafa;
}
.grid-section-num { font-size: 22rpx; color: #999; font-weight: 600; }
.grid-day-cell {
  flex: 1;
  border-right: 1rpx solid #f0f0f0;
  position: relative;
  box-sizing: border-box;
  min-height: 160rpx;
}
.grid-day-cell:last-child { border-right: none; }
.grid-day-cell.isHidden {
  border-right: 1rpx solid #f0f0f0;
}

.course-cell-card {
  position: relative;
  border-radius: 12rpx;
  padding: 10rpx 12rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  overflow: hidden;
  box-sizing: border-box;
  z-index: 2;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.12);
  min-height: 160rpx;
  margin: 4rpx;
}
.cell-name {
  font-size: 22rpx;
  font-weight: 700;
  color: #fff;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  line-height: 1.3;
  text-shadow: 0 1rpx 2rpx rgba(0,0,0,0.15);
}
.cell-info {
  font-size: 18rpx;
  color: rgba(255,255,255,0.9);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  text-shadow: 0 1rpx 2rpx rgba(0,0,0,0.15);
  margin-top: 4rpx;
}
.cell-classroom {
  font-size: 16rpx;
  color: rgba(255,255,255,0.8);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-top: 2rpx;
}

/* ===== 列表视图 ===== */

/* 星期选择器 */
.week-tabs {
  background: #fff;
  padding: 24rpx 16rpx;
  display: flex;
  justify-content: space-around;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05);
}
.week-tab {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 16rpx;
  border-radius: 16rpx;
  transition: all 0.2s;
}
.week-tab.active { background: var(--green); }
.week-name { font-size: 22rpx; color: #aaa; }
.week-tab.active .week-name { color: #fff; }

/* 课程列表 */
.course-list { padding: 16rpx 24rpx; display: flex; flex-direction: column; gap: 16rpx; }
.course-card {
  background: #fff;
  border-radius: 20rpx;
  display: flex;
  overflow: hidden;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.05);
}
.course-left-bar { width: 8rpx; flex-shrink: 0; }
.course-body {
  flex: 1;
  padding: 24rpx 20rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}
.course-name { font-size: 30rpx; font-weight: 700; color: #1a1a1a; }
.course-detail { font-size: 24rpx; color: #aaa; }
.course-actions { display: flex; align-items: center; gap: 12rpx; padding-right: 16rpx; }
.btn-del { background: var(--red-light); color: var(--red); border: none; border-radius: 12rpx; font-size: 22rpx; padding: 10rpx 20rpx; }

/* 空状态 */
.empty-state {
  display: flex; flex-direction: column; align-items: center; padding: 80rpx 0; gap: 20rpx;
}
.empty-emoji { font-size: 80rpx; }
.empty-text { font-size: 28rpx; color: #aaa; }
.btn-create {
  background: var(--green); color: #fff; border-radius: 40rpx;
  font-size: 28rpx; padding: 18rpx 48rpx; border: none;
}
