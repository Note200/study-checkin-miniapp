/* ===== 课程表页 ===== */
.container {
  background: #f0f2f5;
  height: 100vh;
  display: flex;
  flex-direction: column;
}

/* 顶部栏 */
.top-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 24rpx;
  background: linear-gradient(135deg, #58CC02 0%, #46a302 100%);
  color: #fff;
  flex-shrink: 0;
}
.week-selector {
  display: flex;
  align-items: center;
}
.week-label { font-size: 28rpx; color: rgba(255,255,255,0.85); margin: 0 8rpx; }
.week-value {
  font-size: 32rpx;
  font-weight: 700;
  color: #fff;
  min-width: 36rpx;
  text-align: center;
}
.view-toggle {
  background: rgba(255,255,255,0.2);
  border-radius: 20rpx;
  padding: 10rpx 24rpx;
  font-size: 24rpx;
  color: #fff;
  font-weight: 600;
}

/* FAB */
.fab {
  position: fixed;
  right: 40rpx;
  bottom: 160rpx;
  width: 96rpx;
  height: 96rpx;
  background: #58CC02;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 6rpx 20rpx rgba(7,193,96,0.4);
  z-index: 100;
  color: #fff;
  font-size: 48rpx;
  font-weight: 700;
}

/* ===== 格子视图 ===== */
.grid-wrapper {
  flex: 1;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

/* 星期标题行 */
.day-row {
  display: flex;
  height: 80rpx;
  background: #fff;
  border-bottom: 1rpx solid #e8e8e8;
  flex-shrink: 0;
}
.day-label-box {
  width: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  color: #aaa;
  flex-shrink: 0;
}
.day-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}
.day-name {
  font-size: 24rpx;
  color: #666;
  font-weight: 600;
}
.day-date {
  font-size: 18rpx;
  color: #ccc;
  margin-top: 2rpx;
}
.day-item.today .day-name { color: #58CC02; font-weight: 700; }
.day-item.today .day-date { color: #58CC02; }
.day-item.today {
  background: #E8F5E9;
  border-radius: 12rpx;
}

/* 课程表主体 */
.grid-scroll {
  flex: 1;
  background: #fff;
}
.grid-inner {
  position: relative;
  width: 100%;
}

/* 水平分隔线 */
.h-line {
  position: absolute;
  left: 0;
  right: 0;
  height: 1rpx;
  background: #e8e8e8;
  z-index: 1;
}

/* 节次标签 */
.section-label {
  position: absolute;
  left: 0;
  width: 64rpx;
  height: 120rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 2;
}
.section-num {
  font-size: 22rpx;
  color: #aaa;
  font-weight: 600;
}

/* 课程卡片 */
.course-card {
  position: absolute;
  border-radius: 10rpx;
  padding: 6rpx 8rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  overflow: hidden;
  z-index: 10;
  box-sizing: border-box;
}
.course-card.dragging-card {
  opacity: 0.3;
  transform: scale(0.95);
}
.card-name {
  font-size: 22rpx;
  font-weight: 600;
  color: #fff;
  text-align: center;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  line-height: 1.2;
  text-shadow: 0 1rpx 3rpx rgba(0,0,0,0.2);
}
.card-room {
  font-size: 18rpx;
  color: rgba(255,255,255,0.9);
  margin-top: 2rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 100%;
}

/* ===== 列表视图 ===== */
.list-wrapper {
  flex: 1;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}
.week-tabs {
  display: flex;
  background: #fff;
  padding: 16rpx 8rpx;
  border-bottom: 1rpx solid #e8e8e8;
  flex-shrink: 0;
}
.week-tab {
  flex: 1;
  text-align: center;
  padding: 12rpx 0;
  border-radius: 12rpx;
  transition: all 0.2s;
}
.week-tab.active {
  background: #58CC02;
  color: #fff;
}
.week-tab.today-tab:not(.active) { background: #E8F5E9; }
.tab-name { font-size: 24rpx; font-weight: 600; }
.tab-date { font-size: 18rpx; color: #bbb; margin-top: 2rpx; }
.week-tab.active .tab-date { color: rgba(255,255,255,0.8); }
.course-list {
  flex: 1;
  overflow-y: auto;
  padding: 16rpx 24rpx;
}
.course-item {
  display: flex;
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
}
.item-bar { width: 8rpx; flex-shrink: 0; }
.item-body { flex: 1; padding: 20rpx 24rpx; }
.item-name { font-size: 30rpx; font-weight: 600; color: #333; }
.item-detail { font-size: 24rpx; color: #999; margin-top: 8rpx; }

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}
.empty-icon { font-size: 80rpx; margin-bottom: 20rpx; }
.empty-text { font-size: 28rpx; color: #999; }

/* 动画 */
.view-hidden { display: none; }
.view-fade-in { animation: fadeIn 0.3s ease; }
@keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
