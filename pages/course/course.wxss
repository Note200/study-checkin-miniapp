page {
  background: var(--bg, #f5f5f5);
}

.container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

/* ===== 顶栏 ===== */
.top-bar {
  background: var(--card-bg, #fff);
  padding: 16rpx 24rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  flex-shrink: 0;
  border-bottom: 2rpx solid var(--border, #e9ecef);
}
.week-selector {
  display: flex;
  align-items: center;
}
.week-picker-wrap {
  display: flex;
  align-items: center;
  background: var(--green-light, #e8f5e9);
  padding: 12rpx 32rpx;
  border-radius: 32rpx;
  box-shadow: 0 2rpx 8rpx rgba(88,204,2,0.15);
}
.week-text {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--green, #58CC02);
}
.week-arrow {
  font-size: 20rpx;
  color: var(--green, #58CC02);
  margin-left: 10rpx;
}

/* ===== 课表滚动区（微信文档：scroll-view 需固定高度） ===== */
.timetable-scroll {
  flex: 1;
  height: 0;
}

.timetable-body {
  display: flex;
  flex-wrap: wrap;
  position: relative;
  width: 750rpx;
}

/* 左上角月份 */
.corner-cell {
  width: 70rpx;
  height: 70rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  flex-shrink: 0;
}
.corner-month {
  font-size: 24rpx;
  font-weight: 600;
  color: #58CC02;
}

/* 星期标题行 */
.day-header {
  display: flex;
  width: calc(750rpx - 70rpx);
  height: 70rpx;
  flex-shrink: 0;
  background: var(--card-bg, #fff);
  border-bottom: 2rpx solid var(--border, #e9ecef);
}
.day-item {
  width: calc(100% / 7);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 4rpx 0;
  border-radius: 12rpx;
  margin: 6rpx 2rpx;
  transition: background 0.2s;
}
.day-item.today {
  background: var(--green, #58CC02);
  border-radius: 12rpx;
}
.day-name {
  font-size: 24rpx;
  font-weight: 700;
  color: var(--text-1, #333);
}
.day-item.today .day-name {
  color: #fff;
  font-weight: 800;
}
.day-date {
  font-size: 20rpx;
  color: var(--text-3, #999);
  margin-top: 2rpx;
}
.day-item.today .day-date {
  color: rgba(255,255,255,0.85);
}

/* 节次标签列 */
.section-col {
  width: 70rpx;
  flex-shrink: 0;
  background: var(--card-bg, #fff);
  border-right: 2rpx solid var(--border, #e9ecef);
}
.section-cell {
  height: 120rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  border-bottom: 1rpx solid rgba(0,0,0,0.04);
}
.section-num {
  font-size: 24rpx;
  font-weight: 700;
  color: var(--green, #58CC02);
}
.section-times {
  display: flex;
  flex-direction: column;
  align-items: center;
}
.section-time {
  font-size: 14rpx;
  color: var(--text-3, #bbb);
  line-height: 1.2;
}

/* 课程网格区域 */
.grid-area {
  position: relative;
  width: calc(750rpx - 70rpx);
  min-height: calc(12 * 120rpx + 5rpx);
  background: var(--card-bg, #fff);
}

/* 水平分隔线 */
.h-line {
  position: absolute;
  left: 0;
  right: 0;
  height: 1rpx;
  background: rgba(0,0,0,0.05);
}

/* 竖直分隔线 */
.v-line {
  position: absolute;
  top: 0;
  width: 1rpx;
  height: 100%;
  background: rgba(0,0,0,0.05);
}

/* 课程卡片（rpx 固定定位） */
.course-card {
  position: absolute;
  width: calc(100% / 7 - 10rpx);
  box-sizing: border-box;
  border-radius: 12rpx;
  padding: 8rpx 10rpx;
  overflow: hidden;
  z-index: 2;
  /* 微妙内阴影让卡片从网格中浮起来 */
  box-shadow:
    inset 0 1rpx 0 rgba(255,255,255,0.25),
    0 4rpx 12rpx rgba(0,0,0,0.12);
  /* 底部稍暗的渐变 + 左侧亮色装饰条 */
  background-image: linear-gradient(
    180deg,
    rgba(255,255,255,0.12) 0%,
    rgba(0,0,0,0.06) 100%
  ) !important;
  /* 用 border-left 模拟左侧装饰条（比 ::before 安全） */
  border-left: 6rpx solid rgba(255,255,255,0.45);
  transition: transform 0.15s ease, box-shadow 0.15s ease;
}
.course-card:active {
  transform: scale(0.94);
  box-shadow:
    inset 0 1rpx 0 rgba(255,255,255,0.25),
    0 2rpx 6rpx rgba(0,0,0,0.15);
}
.card-name {
  font-size: 22rpx;
  font-weight: 700;
  color: #fff;
  line-height: 1.25;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
  padding-left: 10rpx;
  text-shadow: 0 1rpx 3rpx rgba(0,0,0,0.18);
}
.card-room {
  font-size: 17rpx;
  color: rgba(255,255,255,0.9);
  margin-top: 4rpx;
  padding-left: 10rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  text-shadow: 0 1rpx 2rpx rgba(0,0,0,0.12);
}

