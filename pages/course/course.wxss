/* ===== 课程表页 ===== */
.container {
  background: #f4f6f8;
  min-height: 100vh;
  padding-bottom: 160rpx;
}

/* 周次选择 */
.week-selector {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 16rpx 24rpx;
  background: #fff;
  border-bottom: 1rpx solid #f0f0f0;
}
.week-selector-label { font-size: 28rpx; color: #555; }
.week-selector-value {
  font-size: 30rpx;
  font-weight: 700;
  color: #07C160;
  min-width: 36rpx;
  text-align: center;
}

/* FAB 悬浮按钮 */
.fab {
  position: fixed;
  right: 40rpx;
  bottom: 160rpx;
  width: 96rpx;
  height: 96rpx;
  background: #07C160;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(7,193,96,0.4);
  z-index: 100;
}


/* 星期选择器 */
.week-tabs {
  background: #fff;
  padding: 24rpx 16rpx;
  display: flex;
  justify-content: space-around;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05);
}
.week-tab {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 16rpx;
  border-radius: 16rpx;
  transition: all 0.2s;
}
.week-tab.active { background: #07C160; }
.week-name { font-size: 22rpx; color: #aaa; }
.week-date { font-size: 28rpx; font-weight: 700; color: #333; }
.week-tab.active .week-name,
.week-tab.active .week-date { color: #fff; }
.week-dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: #07C160;
}
.week-tab.active .week-dot { background: rgba(255,255,255,0.7); }

/* 课程列表 */
.course-list { padding: 16rpx 24rpx; display: flex; flex-direction: column; gap: 16rpx; }
.course-card {
  background: #fff;
  border-radius: 20rpx;
  display: flex;
  overflow: hidden;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.05);
}
.course-left-bar { width: 8rpx; flex-shrink: 0; }
.course-body {
  flex: 1;
  padding: 24rpx 20rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}
.course-name { font-size: 30rpx; font-weight: 700; color: #1a1a1a; }
.course-detail { font-size: 24rpx; color: #aaa; }
.course-actions { display: flex; align-items: center; gap: 12rpx; padding-right: 16rpx; }
.btn-edit { background: #E8F8EF; color: #07C160; border: none; border-radius: 12rpx; font-size: 22rpx; padding: 10rpx 20rpx; }
.btn-del { background: #FEF0F0; color: #F56C6C; border: none; border-radius: 12rpx; font-size: 22rpx; padding: 10rpx 20rpx; }

/* 空状态 */
.empty-state {
  display: flex; flex-direction: column; align-items: center; padding: 80rpx 0; gap: 20rpx;
}
.empty-emoji { font-size: 80rpx; }
.empty-text { font-size: 28rpx; color: #aaa; }
.btn-create {
  background: #07C160; color: #fff; border-radius: 40rpx;
  font-size: 28rpx; padding: 18rpx 48rpx; border: none;
}
