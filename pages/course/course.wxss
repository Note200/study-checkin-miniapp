page {
  background: #f5f5f5;
}

.container {
  min-height: 100vh;
  background: #f5f5f5;
}

/* ===== 顶栏 ===== */
.top-bar {
  background: #fff;
  padding: 16rpx 24rpx;
  display: flex;
  justify-content: center;
  align-items: center;
}
.week-selector {
  display: flex;
  align-items: center;
  background: #e8f5e9;
  padding: 10rpx 30rpx;
  border-radius: 30rpx;
}
.week-text {
  font-size: 28rpx;
  font-weight: 600;
  color: #58CC02;
}
.week-arrow {
  font-size: 20rpx;
  color: #58CC02;
  margin-left: 10rpx;
}
.week-picker-trigger {
  position: absolute;
  width: 100%;
  height: 100%;
  opacity: 0;
}

/* ===== 星期行 ===== */
.day-row {
  display: flex;
  background: #fff;
  border-bottom: 1rpx solid #eee;
  padding: 10rpx 0;
}
.day-left {
  width: 90rpx;
  display: flex;
  justify-content: center;
  align-items: center;
}
.month-text {
  font-size: 24rpx;
  font-weight: 600;
  color: #58CC02;
}
.day-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 6rpx 0;
}
.day-item.today {
  background: #e8f5e9;
  border-radius: 12rpx;
}
.day-name {
  font-size: 24rpx;
  font-weight: 600;
  color: #333;
}
.day-item.today .day-name {
  color: #58CC02;
}
.day-date {
  font-size: 20rpx;
  color: #999;
  margin-top: 2rpx;
}
.day-item.today .day-date {
  color: #7ecb8a;
}

/* ===== 课表主体 ===== */
.timetable {
  display: flex;
  background: #fff;
  min-height: calc(100vh - 180rpx);
}

/* 节次标签列 */
.section-col {
  width: 90rpx;
  flex-shrink: 0;
}
.section-cell {
  height: 120rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  border-right: 1rpx solid #eee;
}
.section-num {
  font-size: 24rpx;
  font-weight: 600;
  color: #58CC02;
}
.section-time {
  font-size: 16rpx;
  color: #bbb;
  line-height: 1.2;
}

/* 课程网格区域 */
.grid-area {
  flex: 1;
  position: relative;
}

/* 分隔线 */
.h-line {
  position: absolute;
  left: 0;
  right: 0;
  height: 1rpx;
  background: #eee;
}
.v-line {
  position: absolute;
  top: 0;
  bottom: 0;
  width: 1rpx;
  background: #eee;
}

/* 课程卡片 */
.course-card {
  position: absolute;
  border-radius: 10rpx;
  padding: 6rpx 8rpx;
  box-sizing: border-box;
  overflow: hidden;
  z-index: 2;
  margin: 2rpx;
}
.card-name {
  font-size: 20rpx;
  font-weight: 600;
  color: #fff;
  line-height: 1.2;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
.card-room {
  font-size: 16rpx;
  color: rgba(255,255,255,0.85);
  margin-top: 2rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

/* FAB */
.fab {
  position: fixed;
  right: 40rpx;
  bottom: 140rpx;
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: #58CC02;
  color: #fff;
  font-size: 52rpx;
  text-align: center;
  line-height: 100rpx;
  box-shadow: 0 8rpx 24rpx rgba(88,204,2,0.4);
  z-index: 100;
}
