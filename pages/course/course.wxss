.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 120rpx;
}

/* ===== 顶栏 ===== */
.top-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 24rpx;
  background: #fff;
}
.week-selector {
  display: flex;
  align-items: center;
  background: #f0f7ff;
  border-radius: 24rpx;
  padding: 10rpx 24rpx;
}
.week-label { font-size: 26rpx; color: #666; }
.week-value { font-size: 30rpx; font-weight: 700; color: #5B8FF9; margin: 0 8rpx; min-width: 40rpx; text-align: center; }
.view-toggle { font-size: 24rpx; color: #666; background: #f0f0f0; padding: 10rpx 20rpx; border-radius: 20rpx; }

/* ===== 星期标题行 ===== */
.day-row {
  display: flex;
  background: #fff;
  border-bottom: 1rpx solid #e8e8e8;
}
.day-label-box { width: 70rpx; flex-shrink: 0; }
.day-item {
  flex: 1;
  text-align: center;
  padding: 14rpx 0;
  border-left: 1rpx solid #e8e8e8;
}
.day-item.today { background: #e8f5e9; }
.day-name { font-size: 24rpx; color: #999; }
.day-date { font-size: 22rpx; color: #bbb; margin-top: 2rpx; }
.day-item.today .day-name { color: #58CC02; font-weight: 600; }
.day-item.today .day-date { color: #7ecb8a; }

/* ===== 格子视图 ===== */
.grid-wrapper { background: #fff; }
.grid-wrapper.view-hidden { display: none; }
.grid-scroll { width: 100%; }
.grid-inner {
  position: relative;
  min-height: 400rpx;
  background-color: #fff;
  border-left: 2rpx solid #aaa;
}

/* 分隔线 */
.h-line {
  position: absolute;
  left: 70rpx;
  right: 0;
  height: 1rpx;
  background: #e8e8e8;
}
.v-line {
  position: absolute;
  top: 0;
  width: 4rpx;
  background: #999;
  z-index: 10;
}

/* 节次标签 */
.section-label {
  position: absolute;
  left: 0;
  width: 70rpx;
  display: flex;
  justify-content: center;
  align-items: center;
}
.section-num {
  font-size: 28rpx;
  font-weight: 600;
  color: #999;
}

/* 课程卡片 */
.course-card {
  position: absolute;
  border-radius: 12rpx;
  padding: 8rpx 10rpx;
  box-sizing: border-box;
  overflow: hidden;
  z-index: 2;
}
.card-name {
  font-size: 22rpx;
  font-weight: 600;
  color: #fff;
  line-height: 1.3;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
.card-room {
  font-size: 18rpx;
  color: rgba(255,255,255,0.85);
  margin-top: 4rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

/* 拖拽态 */
.dragging-card { opacity: 0.4; }

/* ===== 列表视图 ===== */
.list-wrapper { background: #fff; }
.list-wrapper.view-hidden { display: none; }
.week-tabs {
  display: flex;
  border-bottom: 1rpx solid #e8e8e8;
}
.week-tab {
  flex: 1;
  text-align: center;
  padding: 18rpx 0;
  position: relative;
}
.week-tab.active { background: #e8f5e9; }
.week-tab.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 48rpx;
  height: 6rpx;
  border-radius: 3rpx;
  background: #58CC02;
}
.week-tab.today-tab .tab-name { color: #58CC02; }
.tab-name { font-size: 26rpx; color: #333; }
.tab-date { font-size: 20rpx; color: #bbb; margin-top: 2rpx; }

.course-list { padding: 16rpx 24rpx; }
.course-item {
  display: flex;
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06);
  overflow: hidden;
}
.item-bar { width: 8rpx; }
.item-body { flex: 1; padding: 20rpx 24rpx; }
.item-name { font-size: 30rpx; font-weight: 600; color: #333; }
.item-detail { font-size: 24rpx; color: #999; margin-top: 6rpx; }

.empty-state { text-align: center; padding: 120rpx 0; }
.empty-icon { font-size: 80rpx; }
.empty-text { font-size: 28rpx; color: #bbb; margin-top: 16rpx; }

/* FAB */
.fab {
  position: fixed;
  right: 40rpx;
  bottom: 140rpx;
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: #58CC02;
  color: #fff;
  font-size: 52rpx;
  text-align: center;
  line-height: 100rpx;
  box-shadow: 0 8rpx 24rpx rgba(88,204,2,0.4);
  z-index: 100;
}
