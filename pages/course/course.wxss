page {
  background: #f5f5f5;
}

.container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

/* ===== 顶栏 ===== */
.top-bar {
  background: #fff;
  padding: 16rpx 24rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  flex-shrink: 0;
}
.week-selector {
  display: flex;
  align-items: center;
}
.week-picker-wrap {
  display: flex;
  align-items: center;
  background: #e8f5e9;
  padding: 10rpx 30rpx;
  border-radius: 30rpx;
}
.week-text {
  font-size: 28rpx;
  font-weight: 600;
  color: #58CC02;
}
.week-arrow {
  font-size: 20rpx;
  color: #58CC02;
  margin-left: 10rpx;
}

/* ===== 课表滚动区（微信文档：scroll-view 需固定高度） ===== */
.timetable-scroll {
  flex: 1;
  height: 0;
}

.timetable-body {
  display: flex;
  flex-wrap: wrap;
  position: relative;
  width: 750rpx;
}

/* 左上角月份 */
.corner-cell {
  width: 70rpx;
  height: 70rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  flex-shrink: 0;
}
.corner-month {
  font-size: 24rpx;
  font-weight: 600;
  color: #58CC02;
}

/* 星期标题行 */
.day-header {
  display: flex;
  width: calc(750rpx - 70rpx);
  height: 70rpx;
  flex-shrink: 0;
}
.day-item {
  width: calc(100% / 7);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 4rpx 0;
}
.day-item.today {
  background: #e8f5e9;
  border-radius: 12rpx;
}
.day-name {
  font-size: 24rpx;
  font-weight: 600;
  color: #333;
}
.day-item.today .day-name {
  color: #58CC02;
}
.day-date {
  font-size: 20rpx;
  color: #999;
  margin-top: 2rpx;
}
.day-item.today .day-date {
  color: #7ecb8a;
}

/* 节次标签列 */
.section-col {
  width: 70rpx;
  flex-shrink: 0;
}
.section-cell {
  height: 120rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
}
.section-num {
  font-size: 24rpx;
  font-weight: 600;
  color: #58CC02;
}
.section-times {
  display: flex;
  flex-direction: column;
  align-items: center;
}
.section-time {
  font-size: 14rpx;
  color: #bbb;
  line-height: 1.2;
}

/* 课程网格区域 */
.grid-area {
  position: relative;
  width: calc(750rpx - 70rpx);
  min-height: calc(12 * 120rpx + 5rpx);
}

/* 水平分隔线 */
.h-line {
  position: absolute;
  left: 0;
  right: 0;
  height: 1rpx;
  background: rgba(200, 200, 200, 0.3);
}

/* 竖直分隔线 */
.v-line {
  position: absolute;
  top: 0;
  width: 1rpx;
  height: 100%;
  background: rgba(200, 200, 200, 0.3);
}

/* 课程卡片（rpx 固定定位） */
.course-card {
  position: absolute;
  width: calc(100% / 7 - 10rpx);
  box-sizing: border-box;
  border-radius: 16rpx;
  padding: 8rpx 8rpx;
  overflow: hidden;
  z-index: 2;
}
.card-name {
  font-size: 20rpx;
  font-weight: 600;
  color: #fff;
  line-height: 1.2;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
  padding-left: 4rpx;
}
.card-room {
  font-size: 16rpx;
  color: rgba(255,255,255,0.85);
  margin-top: 2rpx;
  padding-left: 4rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

/* FAB */
.fab {
  position: fixed;
  right: 40rpx;
  bottom: 140rpx;
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: #58CC02;
  color: #fff;
  font-size: 52rpx;
  text-align: center;
  line-height: 100rpx;
  box-shadow: 0 8rpx 24rpx rgba(88,204,2,0.4);
  z-index: 100;
}
