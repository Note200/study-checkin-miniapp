/* pages/course/course.wxss - Modern Design */
.container {
  min-height: 100vh;
  background: #f0f2f8;
}

.week-selector {
  background: #fff;
  padding: 24rpx 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.week-label {
  font-size: 28rpx;
  color: #6b7280;
  font-weight: 500;
}

.week-value {
  font-size: 32rpx;
  font-weight: 800;
  color: #6C5CE7;
  margin: 0 12rpx;
  padding: 12rpx 24rpx;
  background: #f5f3ff;
  border-radius: 14rpx;
}

.weekday-tabs {
  background: #fff;
  display: flex;
  padding: 16rpx 20rpx;
  margin-bottom: 20rpx;
  gap: 8rpx;
}

.weekday-tab {
  flex: 1;
  text-align: center;
  padding: 18rpx 0;
  font-size: 26rpx;
  color: #9ca3af;
  border-radius: 14rpx;
  font-weight: 500;
}

.weekday-tab.active {
  background: linear-gradient(135deg, #6C5CE7 0%, #a855f7 100%);
  color: #fff;
  font-weight: 700;
  box-shadow: 0 4rpx 16rpx rgba(108, 92, 231, 0.3);
}

.course-list {
  padding: 0 20rpx;
}

.course-card {
  background: #fff;
  border-radius: 24rpx;
  display: flex;
  overflow: hidden;
  margin-bottom: 16rpx;
  box-shadow: 0 4rpx 20rpx rgba(108, 92, 231, 0.06), 0 1rpx 4rpx rgba(0,0,0,0.02);
}

.course-color-bar {
  width: 8rpx;
  flex-shrink: 0;
}

.course-content {
  padding: 28rpx 24rpx;
  flex: 1;
}

.course-content:active {
  background: #fafaff;
}

.course-name {
  font-size: 32rpx;
  font-weight: 700;
  color: #1a1a2e;
  margin-bottom: 14rpx;
}

.course-info {
  display: flex;
  align-items: center;
  margin-bottom: 10rpx;
}

.info-item {
  font-size: 26rpx;
  color: #6b7280;
}

.info-sep {
  margin: 0 14rpx;
  color: #e5e7eb;
}

.course-time {
  font-size: 24rpx;
  color: #9ca3af;
  font-weight: 500;
}

.course-action {
  display: flex;
  align-items: center;
  padding: 0 24rpx;
}

.delete-dot {
  display: inline-block;
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #ef4444;
  opacity: 0.5;
}

.course-action:active .delete-dot {
  opacity: 0.9;
  transform: scale(1.3);
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 160rpx 0;
}

.empty-icon {
  width: 200rpx;
  height: 200rpx;
  opacity: 0.3;
}

.empty-text {
  font-size: 28rpx;
  color: #9ca3af;
  margin: 32rpx 0;
}

.btn-add {
  background: linear-gradient(135deg, #6C5CE7 0%, #a855f7 100%);
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
  padding: 24rpx 64rpx;
  border-radius: 52rpx;
  box-shadow: 0 6rpx 20rpx rgba(108, 92, 231, 0.3);
}

.fab {
  position: fixed;
  right: 36rpx;
  bottom: 100rpx;
  width: 108rpx;
  height: 108rpx;
  background: linear-gradient(135deg, #6C5CE7 0%, #a855f7 100%);
  border-radius: 54rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 12rpx 36rpx rgba(108, 92, 231, 0.4);
  z-index: 100;
}

.fab:active {
  transform: scale(0.9);
}

.fab-icon {
  font-size: 52rpx;
  color: #fff;
  font-weight: 300;
  line-height: 1;
}
