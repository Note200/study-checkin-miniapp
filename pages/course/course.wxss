/* ===== 课程表页 ===== */
.container {
  background: var(--bg);
  min-height: 100vh;
  padding-bottom: 160rpx;
}

/* 顶部栏 */
.top-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 24rpx;
  background: #fff;
  border-bottom: 1rpx solid #f0f0f0;
}
.week-selector {
  display: flex;
  align-items: center;
  gap: 12rpx;
}
.week-selector-label { font-size: 28rpx; color: #555; }
.week-selector-value {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--green);
  min-width: 36rpx;
  text-align: center;
}
.view-toggle {
  background: var(--green-light);
  border-radius: 20rpx;
  padding: 10rpx 24rpx;
  font-size: 24rpx;
  color: var(--green);
  font-weight: 600;
}

/* FAB 悬浮按钮 */
.fab {
  position: fixed;
  right: 40rpx;
  bottom: 160rpx;
  width: 96rpx;
  height: 96rpx;
  background: var(--green);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(7,193,96,0.4);
  z-index: 100;
}

/* ===== 格子视图 ===== */
.grid-header {
  display: flex;
  background: #fff;
  border-bottom: 1rpx solid #f0f0f0;
  position: sticky;
  top: 0;
  z-index: 10;
}
.grid-corner {
  width: 70rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-right: 1rpx solid #f0f0f0;
  flex-shrink: 0;
}
.grid-corner-text { font-size: 20rpx; color: #999; }
.grid-day-header {
  flex: 1;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-right: 1rpx solid #f5f5f5;
  background: #fff;
}
.grid-day-header:last-child { border-right: none; }
.grid-day-header.today { background: var(--green-light); }
.grid-day-name { font-size: 24rpx; color: #666; font-weight: 600; }
.grid-day-header.today .grid-day-name { color: var(--green); }

.grid-body {
  background: #fff;
}
.grid-row {
  display: flex;
  min-height: 140rpx;
}
.grid-section-label {
  width: 70rpx;
  display: flex;
  align-items: flex-start;
  justify-content: center;
  padding-top: 16rpx;
  border-right: 1rpx solid #f0f0f0;
  border-bottom: 1rpx solid #f5f5f5;
  flex-shrink: 0;
  background: #fafafa;
}
.section-num { font-size: 24rpx; color: #666; font-weight: 600; }
.grid-cell {
  flex: 1;
  border-right: 1rpx solid #f5f5f5;
  border-bottom: 1rpx solid #f5f5f5;
  padding: 4rpx;
  min-height: 140rpx;
  background: #fff;
}
.grid-cell:last-child { border-right: none; }
.grid-cell.has-course {
  padding: 2rpx;
}

.cell-content {
  height: 100%;
  border-radius: 12rpx;
  padding: 12rpx 10rpx;
  display: flex;
  flex-direction: column;
  justify-content: flex-start;
  gap: 8rpx;
  overflow: hidden;
}
.cell-name {
  font-size: 22rpx;
  font-weight: 600;
  color: #fff;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  line-height: 1.3;
  text-shadow: 0 1rpx 2rpx rgba(0,0,0,0.15);
}
.cell-info {
  font-size: 18rpx;
  color: rgba(255,255,255,0.9);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  text-shadow: 0 1rpx 2rpx rgba(0,0,0,0.15);
}

/* ===== 列表视图 ===== */

/* 星期选择器 */
.week-tabs {
  background: #fff;
  padding: 24rpx 16rpx;
  display: flex;
  justify-content: space-around;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05);
}
.week-tab {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 16rpx;
  border-radius: 16rpx;
  transition: all 0.2s;
}
.week-tab.active { background: var(--green); }
.week-name { font-size: 22rpx; color: #aaa; }
.week-tab.active .week-name { color: #fff; }

/* 课程列表 */
.course-list { padding: 16rpx 24rpx; display: flex; flex-direction: column; gap: 16rpx; }
.course-card {
  background: #fff;
  border-radius: 20rpx;
  display: flex;
  overflow: hidden;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.05);
}
.course-left-bar { width: 8rpx; flex-shrink: 0; }
.course-body {
  flex: 1;
  padding: 24rpx 20rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}
.course-name { font-size: 30rpx; font-weight: 700; color: #1a1a1a; }
.course-detail { font-size: 24rpx; color: #aaa; }
.course-actions { display: flex; align-items: center; gap: 12rpx; padding-right: 16rpx; }
.btn-del { background: var(--red-light); color: var(--red); border: none; border-radius: 12rpx; font-size: 22rpx; padding: 10rpx 20rpx; }

/* 空状态 */
.empty-state {
  display: flex; flex-direction: column; align-items: center; padding: 80rpx 0; gap: 20rpx;
}
.empty-emoji { font-size: 80rpx; }
.empty-text { font-size: 28rpx; color: #aaa; }
.btn-create {
  background: var(--green); color: #fff; border-radius: 40rpx;
  font-size: 28rpx; padding: 18rpx 48rpx; border: none;
}
