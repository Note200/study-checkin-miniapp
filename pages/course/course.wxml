<view class="container">
  <!-- 周次选择 -->
  <view class="week-selector">
    <text class="week-selector-label">第</text>
    <picker mode="selector" range="{{weeks}}" bindchange="onWeekChange">
      <text class="week-selector-value">{{currentWeek}}</text>
    </picker>
    <text class="week-selector-label">周</text>
  </view>

  <!-- 星期选择 -->
  <view class="week-tabs">
    <view 
      class="week-tab {{weekDay === index + 1 ? 'active' : ''}}" 
      wx:for="{{weekDays}}" 
      wx:key="index"
      data-index="{{index}}"
      bindtap="switchWeekDay">
      <text class="week-name">{{item}}</text>
    </view>
  </view>

  <!-- 课程列表 -->
  <view class="course-list" wx:if="{{courses.length > 0}}">
    <view class="course-card" wx:for="{{courses}}" wx:key="id">
      <view class="course-left-bar" style="background: {{item.color}}"></view>
      <view class="course-body" data-id="{{item.id}}" bindtap="editCourse">
        <view class="course-name">{{item.name}}</view>
        <view class="course-detail">
          <text>{{item.teacher}}</text>
          <text> · </text>
          <text>{{item.classroom}}</text>
        </view>
        <view class="course-detail">第{{item.startSection}}-{{item.endSection}}节</view>
      </view>
      <view class="course-actions">
        <button class="btn-del" data-id="{{item.id}}" bindtap="deleteCourse">删除</button>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:else>
    <image class="empty-emoji" src="/assets/icons/course.png" mode="aspectFit" style="width:120rpx;height:120rpx;"/>
    <text class="empty-text">暂无课程安排</text>
    <button class="btn-create" bindtap="addCourse">添加课程</button>
  </view>

  <!-- 添加按钮（FAB） -->
  <view class="fab" bindtap="addCourse">
    <text class="fab-icon">+</text>
  </view>
</view>
