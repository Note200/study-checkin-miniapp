<view class="container">
  <!-- 顶部栏 -->
  <view class="top-bar">
    <view class="week-selector" bindtap="onWeekTap">
      <text class="week-text">第{{currentWeek}}周</text>
      <text class="week-arrow">▼</text>
    </view>
    <picker mode="selector" range="{{weeks}}" value="{{currentWeek - 1}}" bindchange="onWeekChange">
      <view class="week-picker-trigger"></view>
    </picker>
  </view>

  <!-- 星期行 -->
  <view class="day-row">
    <view class="day-left">
      <text class="month-text">{{monthStr}}</text>
    </view>
    <view class="day-item {{todayDay === index + 1 ? 'today' : ''}}" wx:for="{{weekDays}}" wx:key="index">
      <text class="day-name">周{{item}}</text>
      <text class="day-date">{{weekDates[index]}}</text>
    </view>
  </view>

  <!-- 课表主体 -->
  <view class="timetable">
    <!-- 节次标签列 -->
    <view class="section-col">
      <view class="section-cell" wx:for="{{gridRows}}" wx:key="section">
        <text class="section-num">{{item.section}}</text>
        <text class="section-time">{{item.startTime}}</text>
        <text class="section-time">{{item.endTime}}</text>
      </view>
    </view>

    <!-- 课程网格区域 -->
    <view class="grid-area">
      <!-- 水平分隔线 -->
      <view class="h-line" wx:for="{{gridRows}}" wx:key="section"
        style="top: {{(index + 1) * ROW_H}}rpx;"></view>

      <!-- 竖直分隔线 -->
      <view class="v-line" wx:for="{{vLines}}" wx:key="*this"
        style="left: {{item}}%;"></view>

      <!-- 课程卡片 -->
      <view
        wx:for="{{visibleCourses}}" wx:key="id" wx:for-item="c"
        class="course-card"
        style="left: {{c._leftPct}}%; top: {{c._top}}rpx; width: {{c._widthPct}}%; height: {{c._height}}rpx; background: {{c.color}};"
        data-id="{{c.id}}" bindtap="editCourse" bindlongtap="longPressCourse">
        <view class="card-name">{{c.name}}</view>
        <view class="card-room">{{c.classroom}}</view>
      </view>
    </view>
  </view>

  <!-- FAB -->
  <view class="fab" bindtap="addCourse">+</view>
</view>
