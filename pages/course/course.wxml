<view class="container">
  <!-- 顶部栏 -->
  <view class="top-bar">
    <view class="week-selector">
      <view class="week-label">第</view>
      <picker mode="selector" range="{{weeks}}" bindchange="onWeekChange">
        <view class="week-value">{{currentWeek}}</view>
      </picker>
      <view class="week-label">{{currentWeek >= 17 ? '周（考试周）' : '周'}}</view>
    </view>
    <view class="view-toggle" bindtap="switchView">
      <view>{{showGrid ? '📋 列表' : '📊 表格'}}</view>
    </view>
  </view>

  <!-- ====== 格子视图 ====== -->
  <view class="grid-wrapper {{showGrid ? (viewAnim ? 'view-fade-in' : '') : 'view-hidden'}}">
    <!-- 星期标题行 -->
    <view class="day-row">
      <view class="day-label-box"></view>
      <view class="day-item {{todayDay === index + 1 ? 'today' : ''}}" wx:for="{{weekDays}}" wx:key="index">
        <view class="day-name">{{item}}</view>
        <view class="day-date">{{weekDates[index]}}</view>
      </view>
    </view>

    <!-- 课程表主体 -->
    <scroll-view scroll-y class="grid-scroll"
      bindtouchstart="onGridTouchStart"
      bindtouchmove="onGridTouchMove"
      bindtouchend="onGridTouchEnd">
      <view class="grid-inner" style="height: {{maxSection * ROW_H + 10}}rpx;">

        <!-- 水平分隔线 -->
        <view wx:for="{{gridRows}}" wx:key="section" class="h-line" style="top: {{(index + 1) * ROW_H}}rpx;"></view>

        <!-- 竖直分隔线（用 data 数组，不用字面量） -->
        <view wx:for="{{vLines}}" wx:key="*this" class="v-line"
          style="left: {{SEC_W + item * COL_W}}rpx; height: {{maxSection * ROW_H}}rpx;"></view>

        <!-- 节次标签 -->
        <view wx:for="{{gridRows}}" wx:key="section" class="section-label"
          style="top: {{(item.section - 1) * ROW_H}}rpx; height: {{ROW_H}}rpx;">
          <view class="section-num">{{item.section}}</view>
        </view>

        <!-- 课程卡片 -->
        <view
          wx:for="{{visibleCourses}}" wx:key="id" wx:for-item="c"
          class="course-card"
          animation="{{c._anim}}"
          style="top: {{c._top}}rpx; left: {{c._left}}rpx; width: {{c._width}}rpx; height: {{c._height}}rpx; background: {{c.color}}; opacity: 0; transform: scale(0.3);"
          data-id="{{c.id}}" bindtap="editCourse" bindlongtap="longPressCourse">
          <view class="card-name">{{c.name}}</view>
          <view class="card-room">{{c.classroom}}</view>
        </view>

      </view>
    </scroll-view>
  </view>

  <!-- ====== 列表视图 ====== -->
  <view class="list-wrapper {{!showGrid ? (viewAnim ? 'view-fade-in' : '') : 'view-hidden'}}">
    <view class="week-tabs">
      <view class="week-tab {{weekDay === index + 1 ? 'active' : ''}} {{todayDateStr === weekDates[index] ? 'today-tab' : ''}}"
        wx:for="{{weekDays}}" wx:key="index"
        data-index="{{index}}" bindtap="switchWeekDay">
        <view class="tab-name">{{item}}</view>
        <view class="tab-date">{{weekDates[index]}}</view>
      </view>
    </view>
    <view class="course-list" wx:if="{{courses.length > 0}}">
      <view class="course-item" style="animation-delay: {{index * 80}}ms;" wx:for="{{courses}}" wx:key="id">
        <view class="item-bar" style="background: {{item.color}}"></view>
        <view class="item-body" data-id="{{item.id}}" bindtap="editCourse" bindlongtap="longPressCourse">
          <view class="item-name">{{item.name}}</view>
          <view class="item-detail">{{item.teacher}} · {{item.classroom}}</view>
          <view class="item-detail">第{{item.startSection}}-{{item.endSection}}节</view>
        </view>
      </view>
    </view>
    <view class="empty-state" wx:else>
      <view class="empty-icon">📚</view>
      <view class="empty-text">今天没有课程</view>
    </view>
  </view>

  <!-- FAB -->
  <view class="fab" bindtap="addCourse">+</view>
</view>
