<view class="container">
  <!-- 顶部栏 -->
  <view class="top-bar">
    <view class="week-selector">
      <picker mode="selector" range="{{weeks}}" value="{{currentWeek - 1}}" bindchange="onWeekChange">
        <view class="week-picker-wrap">
          <text class="week-text">第{{currentWeek}}周</text>
          <text class="week-arrow">▼</text>
        </view>
      </picker>
    </view>
  </view>

  <!-- 提示条 -->
  <view class="swipe-hint" wx:if="{{currentWeek <= 18}}">
    <text class="hint-text">← 左右滑动切换周次 →</text>
  </view>

  <!-- 课表主体 -->
  <scroll-view scroll-y class="timetable-scroll"
    bindtouchstart="onGridTouchStart"
    bindtouchmove="onGridTouchMove"
    bindtouchend="onGridTouchEnd">
    <view class="timetable-body">
      <!-- 左上角：月份 -->
      <view class="corner-cell">
        <text class="corner-month">{{monthStr}}</text>
      </view>

      <!-- 星期标题行（7列） -->
      <view class="day-header">
        <view class="day-item {{todayDay === idx + 1 ? 'today' : ''}}" wx:for="{{weekDays}}" wx:key="index" wx:for-index="idx">
          <text class="day-name">周{{item}}</text>
          <text class="day-date">{{weekDates[idx]}}</text>
        </view>
      </view>

      <!-- 左侧节次标签列 -->
      <view class="section-col">
        <view class="section-cell" wx:for="{{gridRows}}" wx:key="section">
          <text class="section-num">{{item.section}}</text>
          <view class="section-times">
            <text class="section-time">{{item.startTime}}</text>
            <text class="section-time">{{item.endTime}}</text>
          </view>
        </view>
      </view>

      <!-- 课程网格（position: relative，卡片用 top/left 绝对定位） -->
      <view class="grid-area {{slideClass}}">
        <!-- 水平分隔线 -->
        <view class="h-line" wx:for="{{gridRows}}" wx:key="section"
          style="top: {{index * ROW_H + ROW_H}}rpx;"></view>

        <!-- 课程卡片 — top/left 绝对定位 -->
        <view
          wx:for="{{visibleCourses}}" wx:key="id" wx:for-item="c"
          class="course-card"
          style="top:{{c._top}}rpx;left:{{c._left}}rpx;width:{{c._width}}rpx;height:{{c._height}}rpx;background:{{c.color}};"
          data-id="{{c.id}}" bindtap="editCourse" bindlongtap="longPressCourse">
          <view class="card-name">{{c.name}}</view>
          <view class="card-room">{{c.teacher}}{{c.teacher && c.classroom ? '·' : ''}}{{c.classroom}}</view>
        </view>
      </view>
    </view>
  </scroll-view>

  <!-- FAB -->
  <view class="fab" bindtap="addCourse">+</view>
</view>
