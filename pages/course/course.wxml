<view class="container">
  <!-- 顶部栏 -->
  <view class="top-bar">
    <view class="week-selector">
      <text class="week-selector-label">第</text>
      <picker mode="selector" range="{{weeks}}" bindchange="onWeekChange">
        <text class="week-selector-value">{{currentWeek}}</text>
      </picker>
      <text class="week-selector-label">{{currentWeek >= 17 ? '周（考试周）' : '周'}}</text>
    </view>
    <view class="view-toggle" bindtap="switchView">
      <text>{{showGrid ? '📋 列表' : '📊 表格'}}</text>
    </view>
  </view>

  <!-- ====== 格子视图 ====== -->
  <view wx:if="{{showGrid}}" class="grid-wrapper">
    <!-- 星期标题行 -->
    <view class="grid-header">
      <view class="grid-corner"><text class="grid-corner-text">节/日</text></view>
      <view class="grid-day-header {{todayDateStr === weekDates[index] ? 'today' : ''}}" wx:for="{{weekDays}}" wx:key="index">
        <view class="day-header-content">
          <text class="grid-day-name">{{item}}</text>
          <text class="grid-day-date">{{weekDates[index]}}</text>
        </view>
      </view>
    </view>

    <!-- 格子主体 -->
    <scroll-view scroll-y class="grid-body {{slideDir || ''}}"
      bindtouchstart="onGridTouchStart"
      bindtouchmove="onGridTouchMove"
      bindtouchend="onGridTouchEnd">
      <view class="grid-bg">
        <view class="grid-bg-row" wx:for="{{gridRows}}" wx:key="section">
          <view class="grid-bg-cell section-label">
            <text class="grid-bg-section">{{item.section}}</text>
          </view>
          <view class="grid-bg-cell" wx:for="{{item.cells}}" wx:key="day" wx:for-item="cell"></view>
        </view>
      </view>
      <!-- 课程卡片叠层 -->
      <view class="course-layer">
        <view 
          wx:for="{{visibleCourses}}" wx:key="id" wx:for-item="c"
          class="course-card-overlay {{dragging && dragCourse.id === c.id ? 'dragging-card' : ''}}"
          style="top: {{c._top}}rpx; left: {{c._left}}%; width: {{c._width}}%; height: {{c._height}}rpx; background: {{c.color}};"
          data-id="{{c.id}}" bindtap="editCourse">
          <text class="cell-name">{{c.name}}</text>
          <text class="cell-info">{{c.teacher}}</text>
          <text class="cell-classroom">{{c.classroom}}</text>
        </view>
      </view>
    </scroll-view>
    <!-- 拖拽幽灵卡片 -->
    <view wx:if="{{dragging}}" class="drag-ghost"
      style="left: {{dragLeft}}px; top: {{dragTop}}px; width: {{_cellPx || 96}}px; height: {{_rowPx || 128}}px; background: {{dragCourse.color}};">
      <text class="cell-name">{{dragCourse.name}}</text>
      <text class="cell-info">{{dragCourse.teacher}}</text>
      <text class="cell-classroom">{{dragCourse.classroom}}</text>
    </view>
  </view>

  <!-- ====== 列表视图 ====== -->
  <view wx:else class="list-wrapper">
    <view class="week-tabs">
      <view class="week-tab {{weekDay === index + 1 ? 'active' : ''}} {{todayDateStr === weekDates[index] ? 'today-tab' : ''}}" wx:for="{{weekDays}}" wx:key="index"
        data-index="{{index}}" bindtap="switchWeekDay">
        <text class="week-name">{{item}}</text>
        <text class="week-date">{{weekDates[index]}}</text>
      </view>
    </view>
    <view class="course-list" wx:if="{{courses.length > 0}}">
      <view class="course-card" wx:for="{{courses}}" wx:key="id">
        <view class="course-left-bar" style="background: {{item.color}}"></view>
        <view class="course-body" data-id="{{item.id}}" bindtap="editCourse" bindlongtap="longPressCourse">
          <view class="course-name">{{item.name}}</view>
          <view class="course-detail">
            <text>{{item.teacher}}</text><text> · </text><text>{{item.classroom}}</text>
          </view>
          <view class="course-detail">第{{item.startSection}}-{{item.endSection}}节</view>
        </view>
      </view>
    </view>
    <view class="empty-state" wx:else>
      <text class="empty-emoji">📚</text>
      <text class="empty-text">暂无课程安排</text>
      <button class="btn-create" bindtap="addCourse">添加课程</button>
    </view>
  </view>

  <view class="fab" bindtap="addCourse">+</view>
</view>
