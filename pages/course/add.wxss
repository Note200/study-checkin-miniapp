/* ===== 娣诲姞璇剧▼椤?===== */
page { background: #f4f6f8; }
.container { padding: 32rpx 24rpx; }
.page-title { margin-bottom: 36rpx; }
.page-title text:first-child { font-size: 40rpx; font-weight: 700; color: #1a1a1a; display: block; }
.page-subtitle { font-size: 26rpx; color: #aaa; }

/* 琛ㄥ崟 */
.form { display: flex; flex-direction: column; /* gap: 0; */ }
.form-item {
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx 28rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.05);
}
.form-row {
  display: flex;
  /* gap: 16rpx; */
}
.form-row .form-item.half {
  flex: 1;
}
.label {
  font-size: 26rpx;
  color: #555;
  margin-bottom: 16rpx;
  display: block;
  font-weight: 600;
}

/* 杈撳叆妗?*/
.input-wrap {
  background: #f7f8fa;
  border-radius: 14rpx;
  padding: 0 24rpx;
  border: 2rpx solid transparent;
  transition: border 0.2s;
}
.input-wrap:focus-within {
  border-color: #07C160;
  background: #fff;
}
.input {
  height: 88rpx;
  font-size: 28rpx;
  color: #1a1a1a;
  width: 100%;
}

/* 閫夋嫨鍣?*/
.picker-wrap { margin-top: 4rpx; }
.picker {
  background: #f7f8fa;
  border-radius: 14rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  color: #1a1a1a;
  border: 2rpx solid transparent;
  transition: border 0.2s;
}

/* 棰滆壊閫夋嫨 */
.color-list {
  display: flex;
  /* gap: 20rpx; */
  margin-top: 8rpx;
  flex-wrap: wrap;
}
.color-item {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  border: 4rpx solid transparent;
  transition: all 0.2s;
}
.color-item.active {
  border-color: #333;
  transform: scale(1.15);
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.2);
}

/* 鎻愪氦鎸夐挳 */
.btn-submit {
  width: 100%;
  background: #07C160;
  color: #fff;
  border-radius: 50rpx;
  font-size: 32rpx;
  font-weight: 700;
  padding: 28rpx 0;
  border: none;
  margin-top: 16rpx;
  box-shadow: 0 6rpx 20rpx rgba(7,193,96,0.3);
}
.btn-submit:active { transform: scale(0.97); }


