<view class="container">
  <view class="page-title">
    <view>{{id ? '缂栬緫璇剧▼' : '娣诲姞璇剧▼'}}</view>
    <view class="page-subtitle">{{id ? '淇敼璇剧▼淇℃伅' : '濉啓璇剧▼淇℃伅'}}</view>
  </view>

  <view class="form">
    <view class="form-item">
      <view class="label">璇剧▼鍚嶇О</view>
      <view class="input-wrap">
        <input class="input" placeholder="濡傦細Java绋嬪簭璁捐" bindinput="onNameInput" value="{{name}}" />
      </view>
    </view>

    <view class="form-item">
      <view class="label">鎺堣鏁欏笀</view>
      <view class="input-wrap">
        <input class="input" placeholder="濡傦細闄堣€佸笀" bindinput="onTeacherInput" value="{{teacher}}" />
      </view>
    </view>

    <view class="form-item">
      <view class="label">涓婅鏁欏</view>
      <view class="input-wrap">
        <input class="input" placeholder="濡傦細A301" bindinput="onClassroomInput" value="{{classroom}}" />
      </view>
    </view>

    <view class="form-item">
      <view class="label">鏄熸湡</view>
      <view class="picker-wrap">
        <picker mode="selector" range="{{weekDays}}" bindchange="onWeekDayChange">
          <view class="picker">{{weekDays[weekDay - 1]}}</view>
        </picker>
      </view>
    </view>

    <view class="form-row">
      <view class="form-item half">
        <view class="label">寮€濮嬭妭娆?/text>
        <view class="picker-wrap">
          <picker mode="selector" range="{{sections}}" bindchange="onStartSectionChange">
            <view class="picker">绗瑊{startSection}}鑺?/view>
          </picker>
        </view>
      </view>
      <view class="form-item half">
        <view class="label">缁撴潫鑺傛</view>
        <view class="picker-wrap">
          <picker mode="selector" range="{{sections}}" bindchange="onEndSectionChange">
            <view class="picker">绗瑊{endSection}}鑺?/view>
          </picker>
        </view>
      </view>
    </view>

    <view class="form-row">
      <view class="form-item half">
        <view class="label">寮€濮嬪懆</view>
        <view class="picker-wrap">
          <picker mode="selector" range="{{weeks}}" bindchange="onStartWeekChange">
            <view class="picker">绗瑊{startWeek}}鍛?/view>
          </picker>
        </view>
      </view>
      <view class="form-item half">
        <view class="label">缁撴潫鍛?/text>
        <view class="picker-wrap">
          <picker mode="selector" range="{{weeks}}" bindchange="onEndWeekChange">
            <view class="picker">绗瑊{endWeek}}鍛?/view>
          </picker>
        </view>
      </view>
    </view>

    <view class="form-item">
      <view class="label">涓婅鍛ㄦ</view>
      <view class="picker-wrap">
        <picker mode="selector" range="{{weekTypes}}" bindchange="onWeekTypeChange">
          <view class="picker">{{weekTypes[weekTypeIndex]}}</view>
        </picker>
      </view>
    </view>

    <view class="form-item">
      <view class="label">璇剧▼棰滆壊</view>
      <view class="color-list">
        <view
          wx:for="{{colors}}"
          wx:key="index"
          class="color-item {{color === item ? 'active' : ''}}"
          style="background: {{item}}"
          data-index="{{index}}"
          bindtap="onColorChange"
        ></view>
      </view>
    </view>

    <button class="btn-submit" bindtap="submit">淇濆瓨璇剧▼</button>
  </view>
</view>
