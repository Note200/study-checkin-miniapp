<view class="container">
  <!-- 顶部装饰 -->
  <view class="header">
    <image class="logo" src="/assets/icons/logo.png" mode="aspectFit"/>
    <text class="title">学习打卡系统</text>
    <text class="subtitle">养成好习惯，从每天打卡开始</text>
  </view>

  <!-- 登录方式切换 -->
  <view class="login-tabs">
    <view 
      class="tab {{loginType === 'wechat' ? 'active' : ''}}" 
      data-type="wechat" 
      bindtap="switchLoginType">
      <text>微信登录</text>
    </view>
    <view 
      class="tab {{loginType === 'account' ? 'active' : ''}}" 
      data-type="account" 
      bindtap="switchLoginType">
      <text>账号登录</text>
    </view>
  </view>

  <!-- 微信登录 -->
  <view class="login-form" wx:if="{{loginType === 'wechat'}}">
    <button 
      class="btn-wechat {{loading ? 'disabled' : ''}}" 
      bindtap="wxLogin"
      disabled="{{loading}}">
      <image class="btn-icon" src="/assets/icons/wechat.png" mode="aspectFit"/>
      <text>{{loading ? '登录中...' : '微信一键登录'}}</text>
    </button>
    <view class="tips">
      <text>登录即表示同意</text>
      <text class="link">《用户协议》</text>
      <text>和</text>
      <text class="link">《隐私政策》</text>
    </view>
  </view>

  <!-- 账号登录 -->
  <view class="login-form" wx:if="{{loginType === 'account'}}">
    <view class="input-group">
      <image class="input-icon" src="/assets/icons/user.png" mode="aspectFit"/>
      <input 
        class="input" 
        type="text" 
        placeholder="请输入用户名/学号"
        value="{{username}}"
        bindinput="onUsernameInput"/>
    </view>
    
    <view class="input-group">
      <image class="input-icon" src="/assets/icons/lock.png" mode="aspectFit"/>
      <input 
        class="input" 
        type="password" 
        placeholder="请输入密码"
        value="{{password}}"
        bindinput="onPasswordInput"/>
    </view>
    
    <view class="options">
      <checkbox-group bindchange="onRememberChange">
        <label class="remember">
          <checkbox value="1"/>
          <text>记住我</text>
        </label>
      </checkbox-group>
      <text class="forgot" bindtap="onForgotPwd">忘记密码？</text>
    </view>
    
    <button 
      class="btn-login {{loading ? 'disabled' : ''}}" 
      bindtap="accountLogin"
      disabled="{{loading}}">
      <text>{{loading ? '登录中...' : '登 录'}}</text>
    </button>
    
    <view class="register-link">
      <text>还没有账号？</text>
      <text class="link" bindtap="toRegister">立即注册</text>
    </view>
  </view>
</view>
