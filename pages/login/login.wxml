п»ҝ<view class="container">
  <!-- Logo йҚ–?-->
  <view class="logo-wrap">
    <image class="logo" src="/assets/icons/logo.png" mode="aspectFit"/>
    <view class="app-name">зҖӣпёҝзҜ„йҺөж’іеҙұз»ҜиҚӨзІә</view>
    <view class="app-slogan">йҚҸз»ҳеһҡжҝӮжҲ’зҜ„йҺҜоҲӨзҙқжө еәўзҳЎжҫ¶в•ӮеўҰйҚ—вҖізҙ‘жҝ®?/text>
  </view>

  <!-- йҚ—пј„еў– -->
  <view class="login-card">
    <view class="card-title">з’җп№ҖеҪҝйҗ§иҜІз¶Қ</view>

    <view class="input-group">
      <view class="input-icon-text">йҰғжҮҒ</view>
      <input
        class="input"
        type="text"
        placeholder="з’Үз–Ҝз·ӯйҚҸгғ§ж•ӨйҺҙеі°жӮ•/зҖӣп№ҖеҪҝ"
        value="{{username}}"
        bindinput="onUsernameInput"/>
    </view>

    <view class="input-group">
      <view class="input-icon-text">йҰғж•Җ</view>
      <input
        class="input"
        type="password"
        placeholder="з’Үз–Ҝз·ӯйҚҸгғҘзҳ‘йҗ®?
        value="{{password}}"
        bindinput="onPasswordInput"/>
    </view>

    <view style="display:flex;justify-content:space-between;align-items:center;margin-bottom:32rpx;">
      <checkbox-group bindchange="onRememberChange">
        <label style="display:flex;align-items:center;font-size:24rpx;color:#999;">
          <checkbox value="1" style="transform:scale(0.8);"/>
          <view>з’ҒйўҒз¶ҮйҺҙ?/text>
        </label>
      </checkbox-group>
      <view class="forgot" bindtap="onForgotPwd">и№ҮжЁҝоҶҮзҖөе—ҷзҲңй”ӣ?/text>
    </view>

    <button
      class="btn-login {{loading ? 'disabled' : ''}}"
      bindtap="accountLogin"
      disabled="{{loading}}">
      <view>{{loading ? 'йҗ§иҜІз¶Қж¶“?..' : 'йҗ§?иӨ°?}}</view>
    </button>

    <view class="register-link">
      <view>жқ©жЁ»з—…йҸҲеӨҺеӨ„йҚҷеҮӨзҙө</view>
      <view class="link" bindtap="toRegister">з»”е¬ӘеөҶеЁүг„Ҙе”Ҫ</view>
    </view>
  </view>

  <!-- йҚ—еҝҡоҶ… -->
  <view class="agreement">
    <view>йҗ§иҜІз¶ҚйҚ—е® гҖғз»Җе“„жӮ“йҺ°?/text>
    <view class="agreement-link">йҠҶе©„ж•ӨйҺҙеі°еҙ—з’ҒоҶәвӮ¬?/text>
    <view>йҚң?/text>
    <view class="agreement-link">йҠҶе©Үж®Јз»үдҪ№ж–Ӯз»ӣж ҘвӮ¬?/text>
  </view>
</view>
