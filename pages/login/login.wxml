<view class="container">
  <!-- Logo 区 -->
  <view class="logo-wrap">
    <image class="logo" src="/assets/icons/logo.png" mode="aspectFit"/>
    <view class="app-name">学习打卡系统</view>
    <view class="app-slogan">养成好习惯，从每天打卡开始</view>
  </view>

  <!-- 卡片 -->
  <view class="login-card">
    <view class="card-title">账号登录</view>

    <view class="input-group">
      <view class="input-icon-text">👤</view>
      <input
        class="input"
        type="text"
        placeholder="请输入用户名/学号"
        value="{{username}}"
        bindinput="onUsernameInput"/>
    </view>

    <view class="input-group">
      <view class="input-icon-text">🔒</view>
      <input
        class="input"
        type="password"
        placeholder="请输入密码"
        value="{{password}}"
        bindinput="onPasswordInput"/>
    </view>

    <view style="display:flex;justify-content:space-between;align-items:center;margin-bottom:32rpx;">
      <checkbox-group bindchange="onRememberChange">
        <label style="display:flex;align-items:center;font-size:24rpx;color:#999;">
          <checkbox value="1" style="transform:scale(0.8);"/>
          <view>记住我</view>
        </label>
      </checkbox-group>
      <view class="forgot" bindtap="onForgotPwd">忘记密码？</view>
    </view>

    <button
      class="btn-login {{loading ? 'disabled' : ''}}"
      bindtap="accountLogin"
      disabled="{{loading}}">
      <view>{{loading ? '登录中...' : '登 录'}}</view>
    </button>

    <view class="register-link">
      <view>还没有账号？</view>
      <view class="link" bindtap="toRegister">立即注册</view>
    </view>
  </view>

  <!-- 协议 -->
  <view class="agreement">
    <view>登录即表示同意</view>
    <view class="agreement-link">《用户协议》</view>
    <view>和</view>
    <view class="agreement-link">《隐私政策》</view>
  </view>
</view>
