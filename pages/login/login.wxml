<view class="container">
  <!-- Logo 区 -->
  <view class="logo-wrap">
    <image class="logo" src="/assets/icons/logo.png" mode="aspectFit"/>
    <text class="app-name">学习打卡系统</text>
    <text class="app-slogan">养成好习惯，从每天打卡开始</text>
  </view>

  <!-- 卡片 -->
  <view class="login-card">
    <text class="card-title">账号登录</text>

    <view class="input-group">
      <text class="input-icon-text">👤</text>
      <input
        class="input"
        type="text"
        placeholder="请输入用户名/学号"
        value="{{username}}"
        bindinput="onUsernameInput"/>
    </view>

    <view class="input-group">
      <text class="input-icon-text">🔒</text>
      <input
        class="input"
        type="password"
        placeholder="请输入密码"
        value="{{password}}"
        bindinput="onPasswordInput"/>
    </view>

    <view style="display:flex;justify-content:space-between;align-items:center;margin-bottom:32rpx;">
      <checkbox-group bindchange="onRememberChange">
        <label style="display:flex;align-items:center;font-size:24rpx;color:#999;">
          <checkbox value="1" style="transform:scale(0.8);"/>
          <text>记住我</text>
        </label>
      </checkbox-group>
      <text class="forgot" bindtap="onForgotPwd">忘记密码？</text>
    </view>

    <button
      class="btn-login {{loading ? 'disabled' : ''}}"
      bindtap="accountLogin"
      disabled="{{loading}}">
      <text>{{loading ? '登录中...' : '登 录'}}</text>
    </button>

    <view class="register-link">
      <text>还没有账号？</text>
      <text class="link" bindtap="toRegister">立即注册</text>
    </view>
  </view>

  <!-- 协议 -->
  <view class="agreement">
    <text>登录即表示同意</text>
    <text class="agreement-link">《用户协议》</text>
    <text>和</text>
    <text class="agreement-link">《隐私政策》</text>
  </view>
</view>
