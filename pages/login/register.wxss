/* pages/login/register.wxss - Modern Glassmorphism */
.container {
  min-height: 100vh;
  background: linear-gradient(160deg, #0f0c29 0%, #302b63 50%, #6C5CE7 100%);
  padding: 60rpx 44rpx;
  display: flex;
  flex-direction: column;
}

.header {
  text-align: center;
  margin-bottom: 48rpx;
  padding-top: 40rpx;
}

.logo {
  width: 120rpx;
  height: 120rpx;
  background: rgba(255,255,255,0.15);
  border-radius: 30rpx;
  margin-bottom: 28rpx;
  box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.15);
}

.title {
  display: block;
  font-size: 46rpx;
  font-weight: 800;
  color: #fff;
  margin-bottom: 12rpx;
  letter-spacing: 4rpx;
}

.subtitle {
  font-size: 26rpx;
  color: rgba(255,255,255,0.6);
  letter-spacing: 2rpx;
}

.form {
  background: rgba(255,255,255,0.95);
  border-radius: 36rpx;
  padding: 48rpx 40rpx;
  box-shadow: 0 24rpx 64rpx rgba(0,0,0,0.15);
  backdrop-filter: blur(20px);
}

.input-group {
  display: flex;
  align-items: center;
  background: #f5f6fa;
  border-radius: 52rpx;
  padding: 26rpx 30rpx;
  margin-bottom: 24rpx;
  border: 2rpx solid transparent;
}

.input-group:focus-within {
  background: #fff;
  border-color: #6C5CE7;
  box-shadow: 0 0 0 6rpx rgba(108, 92, 231, 0.08);
}

.input-icon {
  width: 38rpx;
  height: 38rpx;
  margin-right: 20rpx;
  opacity: 0.55;
}

.input {
  flex: 1;
  font-size: 28rpx;
  color: #1a1a2e;
}

.btn-register {
  background: linear-gradient(135deg, #6C5CE7 0%, #a855f7 100%);
  color: #fff;
  font-size: 32rpx;
  font-weight: 700;
  padding: 26rpx;
  border-radius: 52rpx;
  border: none;
  margin-top: 16rpx;
  box-shadow: 0 8rpx 28rpx rgba(108, 92, 231, 0.35);
  letter-spacing: 6rpx;
}

.btn-register:active {
  transform: scale(0.97);
}

.btn-register.disabled {
  opacity: 0.5;
}

.login-link {
  text-align: center;
  margin-top: 36rpx;
  font-size: 26rpx;
  color: #6b7280;
}

.link {
  color: #6C5CE7;
  margin-left: 8rpx;
  font-weight: 700;
}
