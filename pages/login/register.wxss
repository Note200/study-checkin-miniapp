/* ===== 注册页 ===== */
page { background: #f4f6f8; }
.container {
  min-height: 100vh;
  background: linear-gradient(160deg, #2ECC71 0%, #07C160 45%, #05A550 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60rpx 0;
}

.logo-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 48rpx;
  gap: 12rpx;
}
.logo { width: 88rpx; height: 88rpx; border-radius: 24rpx; }
.app-name { font-size: 40rpx; font-weight: 700; color: #fff; }

.register-card {
  background: #fff;
  border-radius: 32rpx;
  padding: 44rpx 40rpx;
  width: 680rpx;
  box-shadow: 0 16rpx 48rpx rgba(0,0,0,0.12);
}
.card-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1a1a1a;
  margin-bottom: 36rpx;
  text-align: center;
}

.input-group {
  display: flex;
  align-items: center;
  background: #f7f8fa;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  padding: 0 24rpx;
  border: 2rpx solid transparent;
  transition: border 0.2s;
}
.input-group:focus-within { border-color: #07C160; background: #fff; }
.input-icon { width: 36rpx; height: 36rpx; flex-shrink: 0; margin-right: 16rpx; }
.input { flex: 1; height: 96rpx; font-size: 28rpx; color: #1a1a1a; }

.btn-register {
  width: 100%;
  background: #07C160;
  color: #fff;
  border-radius: 50rpx;
  font-size: 32rpx;
  font-weight: 700;
  padding: 28rpx 0;
  border: none;
  margin-top: 12rpx;
  box-shadow: 0 6rpx 20rpx rgba(7,193,96,0.3);
}
.btn-register:active { transform: scale(0.97); }

.login-link {
  text-align: center;
  margin-top: 28rpx;
  font-size: 26rpx;
  color: #999;
}
.login-link text:last-child { color: #07C160; font-weight: 600; }
