/* ===== 注册页 — 多邻国风格 ===== */
page { background: var(--bg); }
.container {
  min-height: 100vh;
  background: linear-gradient(160deg, #58CC02 0%, #46a302 45%, #3d8c02 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60rpx 0;
  position: relative;
  overflow: hidden;
}
.container::before {
  content: '';
  position: absolute;
  top: -80rpx;
  right: -60rpx;
  width: 300rpx;
  height: 300rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.08);
}
.container::after {
  content: '';
  position: absolute;
  bottom: 120rpx;
  left: -100rpx;
  width: 400rpx;
  height: 400rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.06);
}

.logo-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 48rpx;
  gap: 12rpx;
}
.logo { width: 140rpx; height: 140rpx; border-radius: 36rpx; }
.app-name { font-size: 40rpx; font-weight: 800; color: #fff; }

.register-card {
  background: #fff;
  border-radius: 32rpx;
  padding: 44rpx 40rpx;
  width: 680rpx;
  box-shadow: 0 16rpx 48rpx rgba(0,0,0,0.12);
  border: 4rpx solid var(--border);
}
.card-title {
  font-size: 36rpx;
  font-weight: 800;
  color: var(--text-1);
  margin-bottom: 36rpx;
  text-align: center;
}

.input-group {
  display: flex;
  align-items: center;
  background: var(--bg);
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  padding: 0 24rpx;
  border: 4rpx solid var(--border);
  transition: border 0.2s;
}
.input-group:focus-within { border-color: var(--green); background: #fff; }
.input-icon { width: 36rpx; height: 36rpx; flex-shrink: 0; margin-right: 16rpx; }
.input { flex: 1; height: 96rpx; font-size: 28rpx; color: var(--text-1); }

.btn-register {
  width: 100%;
  background: var(--green);
  color: #fff;
  border-radius: 16rpx;
  font-size: 32rpx;
  font-weight: 800;
  padding: 28rpx 0;
  border: none;
  margin-top: 12rpx;
  box-shadow: 0 6rpx 0 var(--green-dark);
  text-transform: uppercase;
  }
.btn-register:active { transform: translateY(4rpx); box-shadow: 0 2rpx 0 var(--green-dark); }

.login-link {
  text-align: center;
  margin-top: 28rpx;
  font-size: 26rpx;
  color: var(--text-3);
}
.login-link text:last-child { color: var(--green); font-weight: 700; }
