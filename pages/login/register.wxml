<view class="container">
  <!-- Logo 鍖?-->
  <view class="logo-wrap">
    <image class="logo" src="/assets/icons/logo.png" mode="aspectFit"/>
    <view class="app-name">鍒涘缓璐﹀彿</view>
  </view>

  <!-- 鍗＄墖 -->
  <view class="register-card">
    <view class="card-title">濉啓娉ㄥ唽淇℃伅</view>

    <view class="input-group">
      <image class="input-icon" src="/assets/icons/user.png" mode="aspectFit"/>
      <input
        class="input"
        type="text"
        placeholder="璇疯緭鍏ョ敤鎴峰悕/瀛﹀彿"
        bindinput="onUsernameInput"/>
    </view>

    <view class="input-group">
      <image class="input-icon" src="/assets/icons/user.png" mode="aspectFit"/>
      <input
        class="input"
        type="text"
        placeholder="璇疯緭鍏ユ樀绉帮紙閫夊～锛?
        bindinput="onNicknameInput"/>
    </view>

    <view class="input-group">
      <image class="input-icon" src="/assets/icons/lock.png" mode="aspectFit"/>
      <input
        class="input"
        type="password"
        placeholder="璇疯緭鍏ュ瘑鐮侊紙鑷冲皯6浣嶏級"
        bindinput="onPasswordInput"/>
    </view>

    <view class="input-group">
      <image class="input-icon" src="/assets/icons/lock.png" mode="aspectFit"/>
      <input
        class="input"
        type="password"
        placeholder="璇峰啀娆¤緭鍏ュ瘑鐮?
        bindinput="onConfirmInput"/>
    </view>

    <button
      class="btn-register {{loading ? 'disabled' : ''}}"
      bindtap="register"
      disabled="{{loading}}">
      <view>{{loading ? '娉ㄥ唽涓?..' : '娉?鍐?}}</view>
    </button>

    <view class="login-link">
      <view>宸叉湁璐﹀彿锛?/text>
      <view class="link" bindtap="goBack">绔嬪嵆鐧诲綍</view>
    </view>
  </view>
</view>
