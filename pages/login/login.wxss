/* ===== 登录页 — 多邻国风格 ===== */
page { background: var(--bg); }
.container {
  min-height: 100vh;
  background: linear-gradient(160deg, #58CC02 0%, #46a302 45%, #3d8c02 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60rpx 0;
}

/* CSS Logo */
.logo-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 56rpx;
  gap: 16rpx;
}
.css-logo {
  width: 140rpx;
  height: 140rpx;
  border-radius: 36rpx;
  background: rgba(255,255,255,0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  border: 4rpx solid rgba(255,255,255,0.4);
}
.logo-book {
  position: relative;
  width: 72rpx;
  height: 80rpx;
}
.logo-book .book-page {
  position: absolute;
  left: 0;
  bottom: 0;
  width: 30rpx;
  height: 60rpx;
  background: #fff;
  border-radius: 4rpx 0 0 4rpx;
}
.logo-book .book-page:nth-child(2) {
  left: 32rpx;
  border-radius: 0 4rpx 4rpx 0;
}
.logo-book .book-check {
  position: absolute;
  right: -8rpx;
  top: -8rpx;
  width: 36rpx;
  height: 36rpx;
  background: var(--gold);
  border-radius: 50%;
  color: var(--green);
  font-size: 22rpx;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
}
.app-name { font-size: 44rpx; font-weight: 800; color: #fff; letter-spacing: 2rpx; }
.app-slogan { font-size: 26rpx; color: rgba(255,255,255,0.9); font-weight: 600; }

/* 卡片 */
.login-card {
  background: #fff;
  border-radius: 32rpx;
  padding: 48rpx 40rpx;
  width: 680rpx;
  box-shadow: 0 16rpx 48rpx rgba(0,0,0,0.12);
  border: 4rpx solid var(--border);
}
.card-title {
  font-size: 36rpx;
  font-weight: 800;
  color: var(--text-1);
  text-align: center;
  margin-bottom: 40rpx;
}

/* 输入框 */
.input-group {
  display: flex;
  align-items: center;
  background: var(--bg);
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  padding: 0 24rpx;
  border: 4rpx solid var(--border);
  transition: border 0.2s;
}
.input-group:focus-within { border-color: var(--green); background: #fff; }
.input-icon { width: 36rpx; height: 36rpx; flex-shrink: 0; margin-right: 16rpx; }
.input { flex: 1; height: 96rpx; font-size: 28rpx; color: var(--text-1); }

.forgot {
  text-align: right;
  font-size: 24rpx;
  color: var(--green);
  font-weight: 700;
  display: block;
}

/* 登录按钮 — 多邻国立体 */
.btn-login {
  width: 100%;
  background: var(--green);
  color: #fff;
  border-radius: 16rpx;
  font-size: 32rpx;
  font-weight: 800;
  padding: 28rpx 0;
  border: none;
  box-shadow: 0 6rpx 0 var(--green-dark);
  margin-top: 32rpx;
  text-transform: uppercase;
  letter-spacing: 4rpx;
}
.btn-login:active { transform: translateY(4rpx); box-shadow: 0 2rpx 0 var(--green-dark); }
.btn-login.disabled { opacity: 0.6; }

/* 注册链接 */
.register-link {
  text-align: center;
  margin-top: 28rpx;
  font-size: 26rpx;
  color: var(--text-3);
  display: flex;
  justify-content: center;
  align-items: center;
}
.register-link .link { color: var(--green); font-weight: 700; margin-left: 8rpx; }

/* 协议 */
.agreement {
  margin-top: 40rpx;
  text-align: center;
  font-size: 22rpx;
  color: rgba(255,255,255,0.7);
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
}
.agreement-link { color: #fff; font-weight: 600; }
