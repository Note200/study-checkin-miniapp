/* pages/login/login.wxss - Modern Glassmorphism */
.container {
  min-height: 100vh;
  background: linear-gradient(160deg, #0f0c29 0%, #302b63 50%, #6C5CE7 100%);
  padding: 80rpx 44rpx;
  display: flex;
  flex-direction: column;
}

.header {
  text-align: center;
  margin-bottom: 60rpx;
  padding-top: 60rpx;
}

.logo {
  width: 140rpx;
  height: 140rpx;
  background: rgba(255,255,255,0.15);
  border-radius: 36rpx;
  margin-bottom: 36rpx;
  box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.15);
}

.title {
  display: block;
  font-size: 52rpx;
  font-weight: 800;
  color: #fff;
  margin-bottom: 16rpx;
  letter-spacing: 4rpx;
}

.subtitle {
  font-size: 26rpx;
  color: rgba(255,255,255,0.6);
  letter-spacing: 2rpx;
}

.login-tabs {
  display: flex;
  background: rgba(255,255,255,0.1);
  border-radius: 56rpx;
  padding: 8rpx;
  margin-bottom: 40rpx;
  backdrop-filter: blur(10px);
}

.tab {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  border-radius: 48rpx;
  font-size: 28rpx;
  color: rgba(255,255,255,0.5);
  font-weight: 500;
}

.tab.active {
  background: rgba(255,255,255,0.95);
  color: #6C5CE7;
  font-weight: 700;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.1);
}

.login-form {
  background: rgba(255,255,255,0.95);
  border-radius: 36rpx;
  padding: 56rpx 44rpx;
  box-shadow: 0 24rpx 64rpx rgba(0,0,0,0.15);
  backdrop-filter: blur(20px);
}

.btn-wechat {
  background: #07C160;
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  padding: 26rpx;
  border-radius: 52rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(7, 193, 96, 0.3);
}

.btn-wechat:active {
  transform: scale(0.97);
}

.btn-wechat.disabled {
  opacity: 0.5;
}

.btn-icon {
  width: 48rpx;
  height: 48rpx;
  margin-right: 16rpx;
}

.tips {
  text-align: center;
  margin-top: 36rpx;
  font-size: 22rpx;
  color: #aaa;
}

.link {
  color: #6C5CE7;
  font-weight: 600;
}

.input-group {
  display: flex;
  align-items: center;
  background: #f5f6fa;
  border-radius: 52rpx;
  padding: 26rpx 30rpx;
  margin-bottom: 28rpx;
  border: 2rpx solid transparent;
}

.input-group:focus-within {
  background: #fff;
  border-color: #6C5CE7;
  box-shadow: 0 0 0 6rpx rgba(108, 92, 231, 0.08);
}

.input-icon {
  width: 40rpx;
  height: 40rpx;
  margin-right: 20rpx;
  opacity: 0.6;
}

.input {
  flex: 1;
  font-size: 28rpx;
  color: #1a1a2e;
}

.options {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 36rpx;
}

.remember {
  display: flex;
  align-items: center;
  font-size: 26rpx;
  color: #6b7280;
}

.forgot {
  font-size: 26rpx;
  color: #6C5CE7;
  font-weight: 500;
}

.btn-login {
  background: linear-gradient(135deg, #6C5CE7 0%, #a855f7 100%);
  color: #fff;
  font-size: 32rpx;
  font-weight: 700;
  padding: 26rpx;
  border-radius: 52rpx;
  border: none;
  box-shadow: 0 8rpx 28rpx rgba(108, 92, 231, 0.35);
  letter-spacing: 6rpx;
}

.btn-login:active {
  transform: scale(0.97);
}

.btn-login.disabled {
  opacity: 0.5;
}

.register-link {
  text-align: center;
  margin-top: 36rpx;
  font-size: 26rpx;
  color: #6b7280;
}
