/* ===== 登录页 ===== */
page { background: #f4f6f8; }
.container {
  min-height: 100vh;
  background: linear-gradient(160deg, #2ECC71 0%, #07C160 45%, #05A550 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60rpx 0;
}

/* Logo区 */
.logo-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 56rpx;
  gap: 16rpx;
}
.logo { width: 140rpx; height: 140rpx; border-radius: 36rpx; }
.app-name { font-size: 44rpx; font-weight: 700; color: #fff; }
.app-slogan { font-size: 26rpx; color: rgba(255,255,255,0.85); }

/* 卡片 */
.login-card {
  background: #fff;
  border-radius: 32rpx;
  padding: 48rpx 40rpx;
  width: 680rpx;
  box-shadow: 0 16rpx 48rpx rgba(0,0,0,0.12);
}

/* 切换类型 */
.login-types {
  display: flex;
  background: #f7f8fa;
  border-radius: 50rpx;
  padding: 6rpx;
  margin-bottom: 36rpx;
}
.type-btn {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  border-radius: 44rpx;
  font-size: 28rpx;
  color: #999;
  transition: all 0.2s;
}
.type-btn.active {
  background: #07C160;
  color: #fff;
  font-weight: 700;
}

/* 输入框 */
.input-group {
  display: flex;
  align-items: center;
  background: #f7f8fa;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  padding: 0 24rpx;
  border: 2rpx solid transparent;
  transition: border 0.2s;
}
.input-group:focus-within { border-color: #07C160; background: #fff; }
.input-icon { width: 36rpx; height: 36rpx; flex-shrink: 0; margin-right: 16rpx; }
.input { flex: 1; height: 96rpx; font-size: 28rpx; color: #1a1a1a; }

.forgot {
  text-align: right;
  font-size: 24rpx;
  color: #07C160;
  margin-bottom: 32rpx;
  display: block;
}

/* 登录按钮 */
.btn-login {
  width: 100%;
  background: #07C160;
  color: #fff;
  border-radius: 50rpx;
  font-size: 32rpx;
  font-weight: 700;
  padding: 28rpx 0;
  border: none;
  box-shadow: 0 6rpx 20rpx rgba(7,193,96,0.3);
}
.btn-login:active { transform: scale(0.97); }

/* 微信登录 */
.wechat-btn {
  width: 100%;
  background: #fff;
  color: #07C160;
  border: 2rpx solid #07C160;
  border-radius: 50rpx;
  font-size: 30rpx;
  font-weight: 600;
  padding: 26rpx 0;
}

/* 分割线 */
.divider {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin: 28rpx 0;
}
.divider-line { flex: 1; height: 1rpx; background: #eee; }
.divider-text { font-size: 24rpx; color: #aaa; }

/* 注册链接 */
.register-link {
  text-align: center;
  margin-top: 28rpx;
  font-size: 26rpx;
  color: #999;
}
.register-link text:last-child { color: #07C160; font-weight: 600; }
