/* ===== 登录页 — 多邻国风格 ===== */
page { background: var(--bg); }
.container {
  min-height: 100vh;
  background: linear-gradient(160deg, #58CC02 0%, #46a302 45%, #3d8c02 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60rpx 0;
  position: relative;
  overflow: hidden;
}
/* 浮动装饰元素 — 差异化 */
.container::before {
  content: '';
  position: absolute;
  top: -80rpx;
  right: -60rpx;
  width: 300rpx;
  height: 300rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.08);
}
.container::after {
  content: '';
  position: absolute;
  bottom: 120rpx;
  left: -100rpx;
  width: 400rpx;
  height: 400rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.06);
}

/* Logo — 差异化发光效果 */
.logo-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 56rpx;
  gap: 16rpx;
  position: relative;
  z-index: 1;
}
.logo {
  width: 200rpx;
  height: 200rpx;
  border-radius: 48rpx;
  box-shadow: 0 12rpx 40rpx rgba(0,0,0,0.2);
  animation: logoPulse 2s ease-in-out infinite;
}
@keyframes logoPulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.03); }
}
.app-name { font-size: 44rpx; font-weight: 800; color: #fff; letter-spacing: 2rpx; }
.app-slogan { font-size: 26rpx; color: rgba(255,255,255,0.9); font-weight: 600; }

/* 卡片 — 差异化玻璃效果 */
.login-card {
  background: #fff;
  border-radius: 32rpx;
  padding: 48rpx 40rpx;
  width: 680rpx;
  box-shadow: 0 16rpx 48rpx rgba(0,0,0,0.12);
  border: 4rpx solid rgba(255,255,255,0.3);
  position: relative;
  z-index: 1;
}
.card-title {
  font-size: 36rpx;
  font-weight: 800;
  color: var(--text-1);
  text-align: center;
  margin-bottom: 40rpx;
}

/* 输入框 */
.input-group {
  display: flex;
  align-items: center;
  background: var(--bg);
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  padding: 0 24rpx;
  border: 4rpx solid var(--border);
  transition: border 0.2s;
}
.input-group:focus-within { border-color: var(--green); background: #fff; }
.input-icon { width: 36rpx; height: 36rpx; flex-shrink: 0; margin-right: 16rpx; }
.input { flex: 1; height: 96rpx; font-size: 28rpx; color: var(--text-1); }

.forgot {
  text-align: right;
  font-size: 24rpx;
  color: var(--green);
  font-weight: 700;
  display: block;
}

/* 登录按钮 — 多邻国立体 */
.btn-login {
  width: 100%;
  background: var(--green);
  color: #fff;
  border-radius: 16rpx;
  font-size: 32rpx;
  font-weight: 800;
  padding: 28rpx 0;
  border: none;
  box-shadow: 0 6rpx 0 var(--green-dark);
  margin-top: 32rpx;
  text-transform: uppercase;
  }
.btn-login:active { transform: translateY(4rpx); box-shadow: 0 2rpx 0 var(--green-dark); }
.btn-login.disabled { opacity: 0.6; }

/* 注册链接 */
.register-link {
  text-align: center;
  margin-top: 28rpx;
  font-size: 26rpx;
  color: var(--text-3);
  display: flex;
  justify-content: center;
  align-items: center;
}
.register-link .link { color: var(--green); font-weight: 700; margin-left: 8rpx; }

/* 协议 */
.agreement {
  margin-top: 40rpx;
  text-align: center;
  font-size: 22rpx;
  color: rgba(255,255,255,0.7);
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
}
.agreement-link { color: #fff; font-weight: 600; }
