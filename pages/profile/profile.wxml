<view class="container">

  <!-- 绿色渐变头部 -->
  <view class="profile-header">
    <image class="avatar" src="{{userInfo.avatar || '/assets/icons/default_avatar.png'}}" mode="aspectFill" bindtap="changeAvatar"/>
    <view class="avatar-edit-hint"><text>📷</text></view>
    <view class="name-row">
      <text class="nickname">{{userInfo.nickname || '同学'}}</text>
      <view class="edit-icon" bindtap="editProfile"><text>✏️</text></view>
    </view>
    <text class="sub-info">{{userInfo.major || ''}}{{userInfo.className ? ' · ' + userInfo.className : ''}}</text>
  </view>

  <!-- 学习数据面板 -->
  <view class="stats-panel">
    <view class="stats-item">
      <text class="stats-num">{{totalDays}}</text>
      <text class="stats-label">累计打卡</text>
    </view>
    <view class="stats-divider"></view>
    <view class="stats-item">
      <text class="stats-num">{{streakDays}}</text>
      <text class="stats-label">连续天数</text>
    </view>
    <view class="stats-divider"></view>
    <view class="stats-item">
      <text class="stats-num">{{monthDays}}</text>
      <text class="stats-label">本月打卡</text>
    </view>
  </view>

  <!-- 成就徽章 -->
  <view class="section-label">我的成就</view>
  <scroll-view scroll-x class="achievement-scroll">
    <view class="achievement-item {{item.unlocked ? '' : 'locked'}}" wx:for="{{achievements}}" wx:key="name">
      <view class="achievement-icon" style="background: {{item.unlocked ? item.bg : '#f0f0f0'}}">
        <text>{{item.icon}}</text>
      </view>
      <text class="achievement-name">{{item.name}}</text>
      <text class="achievement-desc">{{item.desc}}</text>
    </view>
  </scroll-view>

  <!-- 学习设置 -->
  <view class="section-label">学习设置</view>
  <view class="menu-card">
    <view class="menu-item" wx:for="{{menuItems}}" wx:key="title" data-path="{{item.path}}" data-is-tab="{{item.isTab}}" bindtap="onMenuTap">
      <view class="menu-icon-wrap" style="background: {{item.bg || '#E8F8EF'}}">
        <text class="menu-emoji">{{item.emoji}}</text>
      </view>
      <view class="menu-body">
        <text class="menu-title">{{item.title}}</text>
        <text class="menu-desc">{{item.desc}}</text>
      </view>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <!-- 管理员入口 -->
  <view class="menu-card" wx:if="{{isAdmin}}">
    <view class="menu-item" bindtap="goAdmin">
      <view class="menu-icon-wrap" style="background: #E8F8EF">
        <text class="menu-emoji">🛡️</text>
      </view>
      <view class="menu-body">
        <text class="menu-title">班级管理</text>
        <text class="menu-desc">管理成员与公告</text>
      </view>
      <view class="admin-tag"><text>管理员</text></view>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <!-- 账号安全 -->
  <view class="section-label">账号安全</view>
  <view class="menu-card">
    <view class="menu-item" wx:for="{{actionItems}}" wx:key="title" data-action="{{item.action}}" bindtap="onActionTap">
      <view class="menu-icon-wrap" style="background: {{item.bg || '#F7F8FA'}}">
        <text class="menu-emoji">{{item.emoji}}</text>
      </view>
      <view class="menu-body">
        <text class="menu-title">{{item.title}}</text>
      </view>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <!-- 退出登录 -->
  <view class="logout-wrap">
    <view class="logout-btn" bindtap="logout">
      <text>退出登录</text>
    </view>
  </view>

  <view class="version"><text>学而时习 v1.0.0</text></view>

  <!-- 编辑昵称弹窗 -->
  <view class="modal-mask" wx:if="{{showEditModal}}" bindtap="closeEditModal">
    <view class="modal-content" catchtap="preventClose">
      <view class="modal-title">编辑个人信息</view>
      <view class="form-input-group">
        <input class="input" placeholder="请输入昵称" bindinput="onNicknameInput" value="{{editNickname}}" />
      </view>
      <view class="form-input-group">
        <input class="input" placeholder="请输入专业" bindinput="onMajorInput" value="{{editMajor}}" />
      </view>
      <view class="form-input-group">
        <input class="input" placeholder="请输入班级" bindinput="onClassInput" value="{{editClass}}" />
      </view>
      <view class="modal-actions">
        <button class="modal-btn cancel" bindtap="closeEditModal">取消</button>
        <button class="modal-btn confirm" bindtap="saveProfile">保存</button>
      </view>
    </view>
  </view>

  <!-- 修改密码弹窗 -->
  <view class="modal-mask" wx:if="{{showPasswordModal}}" bindtap="closePasswordModal">
    <view class="modal-content" catchtap="preventClose">
      <view class="modal-title">修改密码</view>
      <view class="form-input-group">
        <input class="input" password placeholder="请输入旧密码" bindinput="onOldPwdInput" value="{{oldPassword}}" />
      </view>
      <view class="form-input-group">
        <input class="input" password placeholder="请输入新密码（至少6位）" bindinput="onNewPwdInput" value="{{newPassword}}" />
      </view>
      <view class="form-input-group">
        <input class="input" password placeholder="请确认新密码" bindinput="onConfirmPwdInput" value="{{confirmPassword}}" />
      </view>
      <view class="modal-actions">
        <button class="modal-btn cancel" bindtap="closePasswordModal">取消</button>
        <button class="modal-btn confirm" bindtap="savePassword">确认修改</button>
      </view>
    </view>
  </view>

</view>
