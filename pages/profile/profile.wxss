/* ===== 个人中心 ===== */
.container {
  background: var(--bg);
  min-height: 100vh;
  padding-bottom: 60rpx;
}

/* 绿色渐变头部 — 差异化 */
.profile-header {
  background: linear-gradient(160deg, #58CC02 0%, #46a302 60%, #3d8c02 100%);
  padding: 60rpx 32rpx 80rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  position: relative;
  overflow: hidden;
}
.profile-header::before {
  content: '';
  position: absolute;
  top: -60rpx;
  right: -40rpx;
  width: 240rpx;
  height: 240rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.08);
}
.profile-header::after {
  content: '';
  position: absolute;
  bottom: -40rpx;
  left: -60rpx;
  width: 200rpx;
  border-radius: 50%;
  height: 200rpx;
  background: rgba(255,255,255,0.06);
}
.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 6rpx solid rgba(255,255,255,0.7);
  margin-bottom: 8rpx;
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.15);
  position: relative;
  z-index: 1;
}
.avatar-edit-hint {
  position: absolute;
  bottom: 48rpx;
  left: 50%;
  margin-left: 36rpx;
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: rgba(0,0,0,0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  z-index: 3;
}
.name-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}
.nickname {
  font-size: 40rpx;
  font-weight: 700;
  color: #fff;
}
.edit-icon {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.25);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
}
.sub-info {
  font-size: 24rpx;
  color: rgba(255,255,255,0.85);
}

/* 学习数据面板 — 差异化彩色 */
.stats-panel {
  background: #fff;
  margin: -36rpx 24rpx 16rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: space-around;
  padding: 28rpx 0;
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.1);
  position: relative;
  z-index: 2;
  border: 2rpx solid rgba(88,204,2,0.1);
}
.stats-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
}
.stats-num {
  font-size: 40rpx;
  font-weight: 800;
  color: var(--green);
}
.stats-item:nth-child(1) .stats-num { color: var(--green); }
.stats-item:nth-child(3) .stats-num { color: var(--blue); }
.stats-item:nth-child(5) .stats-num { color: var(--orange); }
.stats-item:nth-child(7) .stats-num { color: var(--purple); }
.stats-label {
  font-size: 22rpx;
  color: #999;
}
.stats-divider {
  width: 1rpx;
  height: 48rpx;
  background: #f0f0f0;
}

/* 成就徽章 */
.achievement-scroll {
  white-space: nowrap;
  padding: 0 24rpx;
}
.achievement-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  width: 180rpx;
  padding: 20rpx 12rpx;
  gap: 8rpx;
  vertical-align: top;
}
.achievement-item.locked { opacity: 0.4; }
.achievement-icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
}
.achievement-name {
  font-size: 24rpx;
  font-weight: 600;
  color: #1a1a1a;
}
.achievement-desc {
  font-size: 20rpx;
  color: #aaa;
}

/* 分组标签 */
.section-label {
  font-size: 24rpx;
  color: #aaa;
  padding: 28rpx 28rpx 10rpx;
  letter-spacing: 1rpx;
}

/* 菜单卡片 */
.menu-card {
  background: #fff;
  border-radius: 20rpx;
  margin: 0 24rpx 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 28rpx 24rpx;
  gap: 20rpx;
  border-bottom: 1rpx solid #f5f5f5;
  transition: background 0.15s;
}
.menu-item:active {
  background: #f8f8f8;
}
.menu-item:last-child { border-bottom: none; }

.menu-icon-wrap {
  width: 72rpx;
  height: 72rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.menu-emoji { font-size: 34rpx; }

.menu-body { flex: 1; }
.menu-title { font-size: 30rpx; color: #1a1a1a; display: block; }
.menu-desc { font-size: 22rpx; color: #aaa; margin-top: 4rpx; display: block; }

.menu-arrow { font-size: 36rpx; color: #ccc; }

.admin-tag {
  background: var(--green-light);
  color: var(--green);
  font-size: 20rpx;
  font-weight: 700;
  padding: 4rpx 14rpx;
  border-radius: 20rpx;
  margin-right: 4rpx;
}

/* 退出按钮 */
.logout-wrap {
  padding: 20rpx 24rpx 0;
}
.logout-btn {
  background: #fff;
  border-radius: 50rpx;
  text-align: center;
  padding: 28rpx 0;
  font-size: 30rpx;
  color: var(--red);
  font-weight: 600;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}
.logout-btn:active { opacity: 0.75; }

.version {
  text-align: center;
  padding: 32rpx 0 0;
  font-size: 22rpx;
  color: #ccc;
}

/* 编辑弹窗 input 样式复用全局 .form-input-group（已在 app.wxss 统一 height:88rpx） */
.modal-content .form-input-group {
  margin-bottom: 20rpx;
}
