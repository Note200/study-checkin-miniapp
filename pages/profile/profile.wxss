/* ===== 个人中心 ===== */
.container {
  background: #f4f6f8;
  min-height: 100vh;
  padding-bottom: 60rpx;
}

/* 绿色渐变头部 */
.profile-header {
  background: linear-gradient(135deg, #2ECC71 0%, #07C160 100%);
  padding: 60rpx 32rpx 80rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}
.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 6rpx solid rgba(255,255,255,0.7);
  margin-bottom: 8rpx;
}
.name-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}
.nickname {
  font-size: 40rpx;
  font-weight: 700;
  color: #fff;
}
.edit-icon {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.25);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
}
.sub-info {
  font-size: 24rpx;
  color: rgba(255,255,255,0.85);
}

/* 分组标签 */
.section-label {
  font-size: 24rpx;
  color: #aaa;
  padding: 28rpx 28rpx 10rpx;
  letter-spacing: 1rpx;
}

/* 菜单卡片 */
.menu-card {
  background: #fff;
  border-radius: 20rpx;
  margin: 0 24rpx 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 28rpx 24rpx;
  gap: 20rpx;
  border-bottom: 1rpx solid #f5f5f5;
}
.menu-item:last-child { border-bottom: none; }

.menu-icon-wrap {
  width: 72rpx;
  height: 72rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.menu-emoji { font-size: 34rpx; }

.menu-body { flex: 1; }
.menu-title { font-size: 30rpx; color: #1a1a1a; display: block; }
.menu-desc { font-size: 22rpx; color: #aaa; margin-top: 4rpx; display: block; }

.menu-arrow { font-size: 36rpx; color: #ccc; }

.admin-tag {
  background: #E8F8EF;
  color: #07C160;
  font-size: 20rpx;
  font-weight: 700;
  padding: 4rpx 14rpx;
  border-radius: 20rpx;
  margin-right: 4rpx;
}

/* 退出按钮 */
.logout-wrap {
  padding: 20rpx 24rpx 0;
}
.logout-btn {
  background: #fff;
  border-radius: 50rpx;
  text-align: center;
  padding: 28rpx 0;
  font-size: 30rpx;
  color: #F56C6C;
  font-weight: 600;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}
.logout-btn:active { opacity: 0.75; }

.version {
  text-align: center;
  padding: 32rpx 0 0;
  font-size: 22rpx;
  color: #ccc;
}
