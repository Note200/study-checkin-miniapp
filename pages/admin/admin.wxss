/* pages/admin/admin.wxss - Modern Design */
.container {
  min-height: 100vh;
  background: #f0f2f8;
}

.tabs {
  background: #fff;
  display: flex;
  padding: 16rpx 24rpx;
  gap: 12rpx;
}

.tab {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  font-size: 28rpx;
  color: #9ca3af;
  border-radius: 16rpx;
  font-weight: 500;
}

.tab.active {
  background: linear-gradient(135deg, #6C5CE7 0%, #a855f7 100%);
  color: #fff;
  font-weight: 700;
  box-shadow: 0 4rpx 16rpx rgba(108, 92, 231, 0.3);
}

.tab-content {
  padding: 20rpx;
}

.card {
  background: #fff;
  border-radius: 28rpx;
  padding: 36rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 24rpx rgba(108, 92, 231, 0.06), 0 1rpx 4rpx rgba(0,0,0,0.02);
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 28rpx;
}

.card-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1a1a2e;
}

.card-count {
  font-size: 24rpx;
  color: #9ca3af;
  font-weight: 500;
}

.btn-small {
  background: linear-gradient(135deg, #6C5CE7 0%, #a855f7 100%);
  color: #fff;
  font-size: 24rpx;
  font-weight: 600;
  padding: 12rpx 28rpx;
  border-radius: 28rpx;
  box-shadow: 0 4rpx 14rpx rgba(108, 92, 231, 0.3);
}

.btn-small:active {
  transform: scale(0.95);
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f5f6fa;
}

.info-row:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 28rpx;
  color: #9ca3af;
}

.info-value {
  font-size: 28rpx;
  color: #1a1a2e;
  font-weight: 500;
}

.code-wrap {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.info-value.code {
  color: #6C5CE7;
  font-weight: 800;
  font-size: 32rpx;
  letter-spacing: 4rpx;
}

.copy-btn {
  font-size: 24rpx;
  color: #6C5CE7;
  padding: 8rpx 20rpx;
  background: #f5f3ff;
  border-radius: 12rpx;
  font-weight: 600;
}

.copy-btn:active {
  background: #ebe8ff;
}

.member-list {
  display: flex;
  flex-direction: column;
}

.member-item {
  display: flex;
  align-items: center;
  padding: 22rpx 0;
  border-bottom: 1rpx solid #fafafa;
}

.member-item:last-child {
  border-bottom: none;
}

.member-avatar {
  width: 76rpx;
  height: 76rpx;
  border-radius: 38rpx;
  background: #f5f3ff;
  margin-right: 20rpx;
}

.member-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.member-name {
  font-size: 28rpx;
  color: #1a1a2e;
  margin-bottom: 6rpx;
  font-weight: 600;
}

.member-role {
  font-size: 24rpx;
  color: #9ca3af;
}

.member-badge {
  padding: 8rpx 20rpx;
  border-radius: 24rpx;
  font-size: 22rpx;
  background: #f0f2f8;
  color: #9ca3af;
  font-weight: 500;
}

.member-badge.admin {
  background: linear-gradient(135deg, #6C5CE7 0%, #a855f7 100%);
  color: #fff;
  font-weight: 600;
  box-shadow: 0 2rpx 8rpx rgba(108, 92, 231, 0.2);
}

.btn-publish {
  background: linear-gradient(135deg, #6C5CE7 0%, #a855f7 100%);
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
  padding: 28rpx;
  border-radius: 52rpx;
  margin-bottom: 28rpx;
  box-shadow: 0 6rpx 20rpx rgba(108, 92, 231, 0.3);
}

.btn-publish:active {
  transform: scale(0.97);
}

.notice-list {
  display: flex;
  flex-direction: column;
}

.notice-item {
  background: #fff;
  border-radius: 24rpx;
  padding: 28rpx;
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
  box-shadow: 0 4rpx 20rpx rgba(108, 92, 231, 0.06), 0 1rpx 4rpx rgba(0,0,0,0.02);
}

.notice-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #6C5CE7;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.notice-content {
  flex: 1;
}

.notice-title {
  font-size: 28rpx;
  color: #1a1a2e;
  display: block;
  margin-bottom: 8rpx;
  font-weight: 600;
}

.notice-date {
  font-size: 24rpx;
  color: #9ca3af;
}

.notice-action text {
  color: #ef4444;
  font-size: 26rpx;
  font-weight: 500;
}

.notice-action:active text {
  opacity: 0.6;
}

.empty-tip {
  text-align: center;
  padding: 100rpx 0;
}

.empty-tip text {
  font-size: 28rpx;
  color: #9ca3af;
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.stats-card {
  background: #fff;
  border-radius: 28rpx;
  padding: 44rpx 24rpx;
  text-align: center;
  box-shadow: 0 4rpx 24rpx rgba(108, 92, 231, 0.06), 0 1rpx 4rpx rgba(0,0,0,0.02);
}

.stats-icon-wrap {
  margin-bottom: 20rpx;
}

.stats-icon {
  font-size: 48rpx;
}

.stats-num {
  display: block;
  font-size: 56rpx;
  font-weight: 800;
  background: linear-gradient(135deg, #6C5CE7 0%, #a855f7 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  margin-bottom: 8rpx;
}

.stats-label {
  font-size: 26rpx;
  color: #9ca3af;
  font-weight: 500;
}

/* 公告弹窗 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(10, 10, 30, 0.45);
  backdrop-filter: blur(6px);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}

.modal-content {
  background: #fff;
  border-radius: 32rpx;
  padding: 48rpx 40rpx;
  width: 620rpx;
  box-sizing: border-box;
  box-shadow: 0 24rpx 60rpx rgba(0,0,0,0.12);
}

.modal-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1a1a2e;
  margin-bottom: 32rpx;
  text-align: center;
}

.notice-textarea-wrap {
  margin-bottom: 24rpx;
}

.notice-textarea {
  width: 100%;
  height: 180rpx;
  padding: 24rpx;
  border: none;
  background: #f5f6fa;
  border-radius: 20rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  color: #1a1a2e;
}

.modal-actions {
  display: flex;
  gap: 20rpx;
}

.modal-btn {
  flex: 1;
  height: 92rpx;
  line-height: 92rpx;
  border-radius: 46rpx;
  font-size: 28rpx;
  font-weight: 600;
  padding: 0;
  margin: 0;
}

.modal-btn.cancel {
  background: #f0f2f8;
  color: #6b7280;
}

.modal-btn.confirm {
  background: linear-gradient(135deg, #6C5CE7 0%, #a855f7 100%);
  color: #fff;
  box-shadow: 0 6rpx 18rpx rgba(108, 92, 231, 0.3);
}
