/* ===== 管理页 ===== */
.container {
  background: #f4f6f8;
  min-height: 100vh;
  padding-bottom: 40rpx;
}

/* 顶部标签 */
.tabs {
  background: #fff;
  display: flex;
  padding: 20rpx 24rpx;
  gap: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05);
}
.tab {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  border-radius: 50rpx;
  font-size: 26rpx;
  color: #999;
  background: #f7f8fa;
}
.tab.active { background: #07C160; color: #fff; font-weight: 700; }

.tab-content { padding: 16rpx 0; }

/* 卡片 */
.card {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx;
  margin: 16rpx 24rpx 0;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.05);
}
.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}
.card-title { font-size: 30rpx; font-weight: 700; color: #1a1a1a; }
.card-count { font-size: 24rpx; color: #aaa; }

/* 班级信息 */
.class-info { display: flex; flex-direction: column; gap: 16rpx; }
.info-row { display: flex; justify-content: space-between; align-items: center; }
.info-label { font-size: 26rpx; color: #aaa; }
.info-value { font-size: 28rpx; color: #1a1a1a; }
.code { font-family: monospace; font-size: 32rpx; color: #07C160; font-weight: 700; letter-spacing: 4rpx; }
.code-wrap { display: flex; align-items: center; gap: 16rpx; }
.copy-btn {
  background: #E8F8EF; color: #07C160; font-size: 22rpx;
  border-radius: 10rpx; padding: 6rpx 16rpx;
}

/* 统计卡片 */
.stats-grid { display: flex; gap: 16rpx; }
.stat-item {
  flex: 1; background: #f7f8fa; border-radius: 16rpx;
  padding: 20rpx; text-align: center;
}
.stat-num {
  font-size: 44rpx; font-weight: 700; color: #07C160;
  display: block; margin-bottom: 6rpx;
}
.stat-label { font-size: 22rpx; color: #aaa; }

/* 成员列表 */
.member-list { display: flex; flex-direction: column; gap: 0; }
.member-item {
  display: flex; align-items: center; padding: 20rpx 0;
  border-bottom: 1rpx solid #f5f5f5; gap: 16rpx;
}
.member-item:last-child { border-bottom: none; }
.member-avatar { width: 72rpx; height: 72rpx; border-radius: 50%; flex-shrink: 0; }
.member-info { flex: 1; }
.member-name { font-size: 28rpx; color: #1a1a1a; display: block; }
.member-role { font-size: 22rpx; color: #aaa; }
.member-badge {
  background: #f0f0f0; color: #999; font-size: 20rpx;
  border-radius: 20rpx; padding: 4rpx 16rpx;
}
.member-badge.admin { background: #E8F8EF; color: #07C160; }

/* 公告 */
.notice-list { display: flex; flex-direction: column; gap: 16rpx; }
.notice-item {
  background: #f7f8fa; border-radius: 16rpx; padding: 20rpx;
}
.notice-content { font-size: 26rpx; color: #333; margin-bottom: 8rpx; display: block; }
.notice-time { font-size: 22rpx; color: #aaa; }
.btn-small {
  background: #07C160; color: #fff; border: none; border-radius: 12rpx;
  font-size: 24rpx; padding: 12rpx 24rpx; line-height: 1.4;
}

/* 空状态 */
.empty-tip { text-align: center; padding: 40rpx 0; font-size: 26rpx; color: #aaa; }
