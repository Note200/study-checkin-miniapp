/* ===== 管理页 ===== */
.container {
  background: #f4f6f8;
  min-height: 100vh;
  padding-bottom: 40rpx;
}

/* 顶部标签 */
.tabs {
  background: #fff;
  display: flex;
  padding: 20rpx 24rpx;
  gap: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05);
}
.tab {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  border-radius: 50rpx;
  font-size: 26rpx;
  color: #999;
  background: #f7f8fa;
}
.tab.active { background: #07C160; color: #fff; font-weight: 700; }

.tab-content { padding: 16rpx 0; }

/* 卡片 */
.card {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx;
  margin: 16rpx 24rpx 0;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.05);
}
.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}
.card-title { font-size: 30rpx; font-weight: 700; color: #1a1a1a; }
.card-count { font-size: 24rpx; color: #aaa; }

/* 班级信息 */
.class-info { display: flex; flex-direction: column; gap: 16rpx; }
.info-row { display: flex; justify-content: space-between; align-items: center; }
.info-label { font-size: 26rpx; color: #aaa; }
.info-value { font-size: 28rpx; color: #1a1a1a; }
.code { font-family: monospace; font-size: 32rpx; color: #07C160; font-weight: 700; letter-spacing: 4rpx; }
.code-wrap { display: flex; align-items: center; gap: 16rpx; }
.copy-btn {
  background: #E8F8EF; color: #07C160; font-size: 22rpx;
  border-radius: 10rpx; padding: 6rpx 16rpx;
}

/* 统计卡片 */
.stats-grid { display: flex; flex-wrap: wrap; gap: 16rpx; padding: 0 24rpx; }
.stats-card {
  width: calc(50% - 8rpx);
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.05);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}
.stats-icon-wrap {
  width: 72rpx;
  height: 72rpx;
  border-radius: 20rpx;
  background: #E8F8EF;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 4rpx;
}
.stats-icon { font-size: 36rpx; }
.stats-num {
  font-size: 44rpx;
  font-weight: 700;
  color: #07C160;
}
.stats-label {
  font-size: 24rpx;
  color: #aaa;
}

/* 成员列表 */
.member-list { display: flex; flex-direction: column; gap: 0; }
.member-item {
  display: flex; align-items: center; padding: 20rpx 0;
  border-bottom: 1rpx solid #f5f5f5; gap: 16rpx;
}
.member-item:last-child { border-bottom: none; }
.member-avatar { width: 72rpx; height: 72rpx; border-radius: 50%; flex-shrink: 0; }
.member-info { flex: 1; }
.member-name { font-size: 28rpx; color: #1a1a1a; display: block; }
.member-role { font-size: 22rpx; color: #aaa; }
.member-badge {
  background: #f0f0f0; color: #999; font-size: 20rpx;
  border-radius: 20rpx; padding: 4rpx 16rpx;
}
.member-badge.admin { background: #E8F8EF; color: #07C160; }

/* 公告 */
.notice-list { padding: 0 24rpx; display: flex; flex-direction: column; gap: 16rpx; }
.notice-item {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.05);
}
.notice-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #E6A23C;
  flex-shrink: 0;
}
.notice-content { flex: 1; display: flex; flex-direction: column; gap: 6rpx; }
.notice-title { font-size: 28rpx; font-weight: 600; color: #333; }
.notice-date { font-size: 22rpx; color: #aaa; }
.notice-action {
  font-size: 24rpx;
  color: #F56C6C;
  font-weight: 600;
  flex-shrink: 0;
  padding: 8rpx 16rpx;
}

/* 发布公告按钮 */
.btn-publish {
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 16rpx 24rpx;
  background: #07C160;
  color: #fff;
  border-radius: 50rpx;
  font-size: 28rpx;
  font-weight: 600;
  padding: 20rpx 0;
  border: none;
  box-shadow: 0 4rpx 12rpx rgba(7,193,96,0.3);
}

/* 公告弹窗输入 */
.notice-textarea-wrap { margin-bottom: 20rpx; }
.notice-textarea {
  width: 100%;
  min-height: 120rpx;
  background: #f7f8fa;
  border-radius: 14rpx;
  padding: 20rpx;
  font-size: 26rpx;
  box-sizing: border-box;
}

.btn-small {
  background: #07C160; color: #fff; border: none; border-radius: 12rpx;
  font-size: 24rpx; padding: 12rpx 24rpx; line-height: 1.4;
}

/* 空状态 */
.empty-tip { text-align: center; padding: 40rpx 0; font-size: 26rpx; color: #aaa; }
