<view class="container">
  <!-- 标签栏 -->
  <view class="tabs">
    <view 
      class="tab {{activeTab === 0 ? 'active' : ''}}" 
      data-index="0" 
      bindtap="switchTab">
      <view>班级管理</view>
    </view>
    <view 
      class="tab {{activeTab === 1 ? 'active' : ''}}" 
      data-index="1" 
      bindtap="switchTab">
      <view>公告管理</view>
    </view>
    <view 
      class="tab {{activeTab === 2 ? 'active' : ''}}" 
      data-index="2" 
      bindtap="switchTab">
      <view>数据统计</view>
    </view>
  </view>

  <!-- 班级管理 -->
  <view class="tab-content" wx:if="{{activeTab === 0}}">
    <view class="card" wx:if="{{classInfo}}">
      <view class="card-header">
        <view class="card-title">班级信息</view>
        <button class="btn-small" bindtap="generateCode">生成邀请码</button>
      </view>
      <view class="class-info">
        <view class="info-row">
          <view class="info-label">班级名称</view>
          <view class="info-value">{{classInfo.name || ''}}</view>
        </view>
        <view class="info-row">
          <view class="info-label">邀请码</view>
          <view class="code-wrap">
            <view class="info-value code">{{classInfo.inviteCode || '未生成'}}</view>
            <view class="copy-btn" bindtap="copyCode" wx:if="{{classInfo.inviteCode}}">复制</view>
          </view>
        </view>
        <view class="info-row">
          <view class="info-label">成员数量</view>
          <view class="info-value">{{stats.memberCount || 0}} 人</view>
        </view>
      </view>
    </view>

    <view class="card">
      <view class="card-header">
        <view class="card-title">成员列表</view>
        <view class="card-count">{{stats.memberCount || 0}} 人</view>
      </view>
      <view class="member-list" wx:if="{{memberList.length > 0}}">
        <view class="member-item" wx:for="{{memberList}}" wx:key="id">
          <image class="member-avatar" src="{{item.avatar || '/assets/icons/default_avatar.png'}}" mode="aspectFill"/>
          <view class="member-info">
            <view class="member-name">{{item.nickname}}</view>
            <view class="member-role">{{item.role === 1 ? '管理员' : '成员'}}</view>
          </view>
          <view class="member-badge {{item.role === 1 ? 'admin' : ''}}">
            <view>{{item.role === 1 ? '管理' : '成员'}}</view>
          </view>
        </view>
      </view>
      <view class="empty-tip" wx:else>
        <view>暂无成员</view>
      </view>
    </view>

    <view class="empty-tip" wx:if="{{!classInfo}}">
      <view>暂未加入班级</view>
    </view>
  </view>

  <!-- 公告管理 -->
  <view class="tab-content" wx:if="{{activeTab === 1}}">
    <button class="btn-publish" bindtap="showNoticeModal">
      <view>+ 发布公告</view>
    </button>

    <view class="notice-list">
      <view class="notice-item" wx:for="{{noticeList}}" wx:key="id">
        <view class="notice-dot"></view>
        <view class="notice-content">
          <view class="notice-title">{{item.title}}</view>
          <view class="notice-date">{{item.createTime}}</view>
        </view>
        <view class="notice-action" data-id="{{item.id}}" bindtap="deleteNotice">
          <view>删除</view>
        </view>
      </view>
    </view>

    <view class="empty-tip" wx:if="{{noticeList.length === 0}}">
      <view>暂无公告</view>
    </view>
  </view>

  <!-- 数据统计 -->
  <view class="tab-content" wx:if="{{activeTab === 2}}">
    <view class="stats-grid">
      <view class="stats-card">
        <view class="stats-icon-wrap">
          <view class="stats-icon">👥</view>
        </view>
        <view class="stats-num">{{stats.memberCount || 0}}</view>
        <view class="stats-label">成员数</view>
      </view>
      <view class="stats-card">
        <view class="stats-icon-wrap">
          <view class="stats-icon">📋</view>
        </view>
        <view class="stats-num">{{stats.taskCount || 0}}</view>
        <view class="stats-label">打卡任务</view>
      </view>
      <view class="stats-card">
        <view class="stats-icon-wrap">
          <view class="stats-icon">✅</view>
        </view>
        <view class="stats-num">{{stats.checkinCount || 0}}</view>
        <view class="stats-label">打卡记录</view>
      </view>
      <view class="stats-card">
        <view class="stats-icon-wrap">
          <view class="stats-icon">📝</view>
        </view>
        <view class="stats-num">{{stats.planCount || 0}}</view>
        <view class="stats-label">学习计划</view>
      </view>
    </view>
  </view>

  <!-- 公告发布弹窗 -->
  <view class="modal-mask" wx:if="{{showPublishModal}}" bindtap="hideNoticeModal">
    <view class="modal-content" catchtap="preventClose">
      <view class="modal-title">发布公告</view>
      <view class="form-input-group">
        <input class="input" placeholder="公告标题" bindinput="onNoticeTitleInput" value="{{noticeTitle}}"/>
      </view>
      <view class="notice-textarea-wrap">
        <textarea class="notice-textarea" placeholder="公告内容（选填）" bindinput="onNoticeContentInput" value="{{noticeContent}}"/>
      </view>
      <view class="modal-actions">
        <button class="modal-btn cancel" bindtap="hideNoticeModal">取消</button>
        <button class="modal-btn confirm" bindtap="submitNotice">发布</button>
      </view>
    </view>
  </view>
</view>
