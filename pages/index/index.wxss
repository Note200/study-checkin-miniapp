/* ===== 首页 ===== */
.container {
  background: #f4f6f8;
  min-height: 100vh;
}

/* 绿色渐变头部 */
.header {
  background: linear-gradient(135deg, #2ECC71 0%, #07C160 100%);
  padding: 40rpx 32rpx 48rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.header-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
}
.avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255,255,255,0.6);
}
.header-text { display: flex; flex-direction: column; gap: 6rpx; }
.nickname {
  font-size: 34rpx;
  font-weight: 700;
  color: #fff;
}
.slogan {
  font-size: 24rpx;
  color: rgba(255,255,255,0.85);
}
.bell-btn {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.25);
  display: flex;
  align-items: center;
  justify-content: center;
}
.bell-icon { font-size: 36rpx; }

.header-right {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

/* 连续打卡火焰徽章 */
.streak-badge {
  background: rgba(255,255,255,0.3);
  border-radius: 40rpx;
  padding: 8rpx 20rpx;
  display: flex;
  align-items: center;
  gap: 6rpx;
}
.streak-fire { font-size: 28rpx; }
.streak-num {
  font-size: 28rpx;
  font-weight: 700;
  color: #fff;
}

/* 公告横幅 */
.notice-bar {
  background: #FFFDE7;
  margin: 0 24rpx;
  margin-top: -24rpx;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
  box-shadow: 0 2rpx 12rpx rgba(230,162,60,0.12);
}
.notice-icon { font-size: 32rpx; }
.notice-text { font-size: 26rpx; color: #E6A23C; flex: 1; }

/* 段落标题 */
.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 32rpx 0;
}
.section-title { font-size: 32rpx; font-weight: 700; color: #1a1a1a; }
.section-right { font-size: 26rpx; color: #999; }
.section-right.green { color: #07C160; }

/* 今日进度卡片 */
.progress-card {
  margin-top: 20rpx;
  padding: 32rpx;
}
.ring-row {
  display: flex;
  align-items: center;
  gap: 40rpx;
  margin-bottom: 28rpx;
}
.ring-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}
.ring-bg {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: background 0.6s ease;
}
.ring-inner {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: #fff;
  display: flex;
  align-items: baseline;
  justify-content: center;
  gap: 2rpx;
}
.ring-num {
  font-size: 44rpx;
  font-weight: 800;
  color: #07C160;
}
.ring-unit {
  font-size: 22rpx;
  color: #07C160;
  font-weight: 600;
}
.ring-label {
  font-size: 22rpx;
  color: #aaa;
}
.ring-stats {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}
.stat-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
}
.stat-val {
  font-size: 32rpx;
  font-weight: 700;
  color: #1a1a1a;
}
.stat-val.green { color: #07C160; }
.stat-val.orange { color: #FF9500; }
.stat-label {
  font-size: 24rpx;
  color: #aaa;
}

/* 任务列表 */
.task-list { display: flex; flex-direction: column; gap: 0; position: relative; }

/* 左滑容器 */
.swipe-wrap {
  position: relative;
  overflow: hidden;
  border-bottom: 1rpx solid #f2f3f5;
}
.swipe-wrap:last-child { border-bottom: none; }
.swipe-content {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  gap: 20rpx;
  position: relative;
  background: #fff;
  z-index: 2;
  transition: transform 0.25s ease;
}
.swipe-actions {
  position: absolute;
  right: 0;
  top: 0;
  bottom: 0;
  width: 160rpx;
  display: flex;
  z-index: 1;
}
.swipe-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 600;
  color: #fff;
}
.btn-do { background: #07C160; }
.btn-undo { background: #FF9500; }

.swipe-row {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f2f3f5;
  gap: 20rpx;
}

/* 勾选圆 */
.task-check {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  border: 3rpx solid #ddd;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  color: #fff;
  font-size: 22rpx;
}
.task-check.checked {
  background: #07C160;
  border-color: #07C160;
}

.task-meta { flex: 1; }
.task-name { font-size: 28rpx; color: #1a1a1a; display: block; }
.task-name.done-text { color: #aaa; text-decoration: line-through; }
.task-sub { font-size: 22rpx; color: #aaa; margin-top: 4rpx; display: block; }

/* 状态标签 */
.task-badge {
  font-size: 22rpx;
  font-weight: 600;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  flex-shrink: 0;
}
.badge-done {
  background: #E8F8EF;
  color: #07C160;
}
.badge-pending {
  background: #FFF3E0;
  color: #E6A23C;
}

/* 柱状图 */
.chart-card { padding: 28rpx 20rpx; margin-top: 20rpx; }
.bar-chart {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  height: 180rpx;
  padding-bottom: 8rpx;
}
.bar-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
  gap: 8rpx;
}
.bar-wrap {
  width: 32rpx;
  height: 160rpx;
  display: flex;
  align-items: flex-end;
}
.bar-fill {
  width: 100%;
  background: #B8F5D0;
  border-radius: 8rpx 8rpx 0 0;
  transition: height 0.4s ease;
}
.bar-fill.today { background: #07C160; }
.bar-label { font-size: 20rpx; color: #aaa; }

.chart-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 20rpx;
  padding: 0 12rpx;
  border-top: 1rpx solid #f2f3f5;
  padding-top: 16rpx;
}
.chart-total-label { font-size: 24rpx; color: #999; }
.chart-total-val { font-size: 34rpx; font-weight: 700; color: #07C160; }

/* 快捷功能 */
.quick-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 0;
  padding: 16rpx 16rpx 0;
}
.quick-item {
  width: 25%;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 0;
  gap: 12rpx;
}
.quick-icon {
  width: 96rpx;
  height: 96rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
}
.bg-green  { background: #E8F8EF; }
.bg-blue   { background: #E3F2FD; }
.bg-orange { background: #FFF3E0; }
.bg-purple { background: #F3E8FF; }
.quick-label { font-size: 24rpx; color: #555; }

/* 今日课程横向滚动 */
.course-scroll {
  white-space: nowrap;
  padding: 0 32rpx 0;
}
.course-chip {
  display: inline-flex;
  flex-direction: column;
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  margin-right: 16rpx;
  width: 280rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
  vertical-align: top;
  overflow: hidden;
  position: relative;
}
.course-chip-bar {
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 8rpx;
  border-radius: 16rpx 0 0 16rpx;
}
.course-chip-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #1a1a1a;
  margin-bottom: 8rpx;
  padding-left: 12rpx;
}
.course-chip-info {
  font-size: 22rpx;
  color: #aaa;
  padding-left: 12rpx;
}
