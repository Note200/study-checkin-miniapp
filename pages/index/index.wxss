/* ===== 首页 — 多邻国风格 ===== */
.container {
  background: var(--bg);
  min-height: 100vh;
}

/* 绿色渐变头部 */
.header {
  background: linear-gradient(135deg, #58CC02 0%, #46a302 100%);
  padding: 40rpx 32rpx 48rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.header-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
}
.avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255,255,255,0.6);
}
.header-text { display: flex; flex-direction: column; gap: 6rpx; }
.nickname {
  font-size: 34rpx;
  font-weight: 800;
  color: #fff;
}
.slogan {
  font-size: 24rpx;
  color: rgba(255,255,255,0.9);
  font-weight: 600;
}
.bell-btn {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.25);
  display: flex;
  align-items: center;
  justify-content: center;
}
.bell-icon { font-size: 36rpx; }

.header-right {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

/* 连续打卡火焰徽章 */
.streak-badge {
  background: rgba(255,255,255,0.3);
  border-radius: 40rpx;
  padding: 8rpx 20rpx;
  display: flex;
  align-items: center;
  gap: 6rpx;
}
.streak-fire { font-size: 28rpx; }
.streak-num {
  font-size: 28rpx;
  font-weight: 800;
  color: #fff;
}

/* 公告横幅 */
.notice-bar {
  background: var(--gold-light);
  margin: 0 24rpx;
  margin-top: -24rpx;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
  border: 2rpx solid var(--gold);
}
.notice-icon { font-size: 32rpx; }
.notice-text { font-size: 26rpx; color: var(--gold-dark); flex: 1; font-weight: 600; }

/* 段落标题 */
.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 32rpx 0;
}
.section-title { font-size: 32rpx; font-weight: 800; color: var(--text-1); }
.section-right { font-size: 26rpx; color: var(--text-3); }
.section-right.green { color: var(--green); font-weight: 700; }

/* 快捷功能 — 6宫格 */
.quick-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 0;
  padding: 16rpx 24rpx 0;
  background: #fff;
  margin: 0 24rpx;
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow);
  border: 2rpx solid var(--border);
}
.quick-item {
  width: 33.33%;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 28rpx 0;
  gap: 12rpx;
}
.quick-icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 38rpx;
}
.bg-green  { background: var(--green-light); }
.bg-blue   { background: var(--blue-light); }
.bg-orange { background: var(--orange-light); }
.bg-purple { background: var(--purple-light); }
.bg-red    { background: var(--red-light); }
.bg-gold   { background: var(--gold-light); }
.quick-label { font-size: 24rpx; color: var(--text-2); font-weight: 600; }

/* 今日课程横向滚动 */
.course-scroll {
  white-space: nowrap;
  padding: 0 32rpx 0;
}
.course-chip {
  display: inline-flex;
  flex-direction: column;
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  margin-right: 16rpx;
  width: 280rpx;
  box-shadow: var(--shadow-sm);
  vertical-align: top;
  overflow: hidden;
  position: relative;
  border: 2rpx solid var(--border);
}
.course-chip-bar {
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 8rpx;
  border-radius: 16rpx 0 0 16rpx;
}
.course-chip-name {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text-1);
  margin-bottom: 8rpx;
  padding-left: 12rpx;
}
.course-chip-info {
  font-size: 22rpx;
  color: var(--text-3);
  padding-left: 12rpx;
}

/* 今日进度卡片 */
.progress-card {
  margin-top: 20rpx;
  padding: 32rpx;
}
.ring-row {
  display: flex;
  align-items: center;
  gap: 40rpx;
  margin-bottom: 28rpx;
}
.ring-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}
.ring-bg {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: background 0.6s ease;
}
.ring-inner {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}
.ring-num {
  font-size: 44rpx;
  font-weight: 800;
  color: var(--green);
  line-height: 1;
}
.ring-unit {
  font-size: 22rpx;
  color: var(--green);
  font-weight: 700;
  line-height: 1;
  margin-left: 2rpx;
  align-self: flex-end;
  margin-bottom: 4rpx;
}
.ring-label {
  font-size: 22rpx;
  color: var(--text-3);
  font-weight: 600;
}
.ring-stats {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}
.stat-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
}
.stat-val {
  font-size: 32rpx;
  font-weight: 800;
  color: var(--text-1);
}
.stat-val.green { color: var(--green); }
.stat-val.orange { color: var(--orange); }
.stat-label {
  font-size: 24rpx;
  color: var(--text-3);
}

/* 任务列表 */
.task-list { display: flex; flex-direction: column; gap: 0; position: relative; }

/* 左滑容器 */
.swipe-wrap {
  position: relative;
  overflow: hidden;
  border-bottom: 2rpx solid var(--border);
}
.swipe-wrap:last-child { border-bottom: none; }
.swipe-content {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  gap: 20rpx;
  position: relative;
  background: #fff;
  z-index: 2;
  transition: transform 0.25s ease;
}
.swipe-actions {
  position: absolute;
  right: 0;
  top: 0;
  bottom: 0;
  width: 160rpx;
  display: flex;
  z-index: 1;
}
.swipe-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 700;
  color: #fff;
}
.btn-do { background: var(--green); }
.btn-undo { background: var(--orange); }

/* 勾选圆 */
.task-check {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  border: 4rpx solid var(--border);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  color: #fff;
  font-size: 22rpx;
  transition: all 0.2s;
}
.task-check.checked {
  background: var(--green);
  border-color: var(--green);
}

.task-meta { flex: 1; min-width: 0; overflow: hidden; }
.task-name { font-size: 28rpx; color: var(--text-1); display: block; line-height: 1.4; font-weight: 600; }
.task-name.done-text { color: var(--text-3); text-decoration: line-through; }
.task-sub { font-size: 22rpx; color: var(--text-3); margin-top: 4rpx; display: block; line-height: 1.4; }

/* 状态标签 */
.task-badge {
  font-size: 22rpx;
  font-weight: 700;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  flex-shrink: 0;
}
.badge-done {
  background: var(--green-light);
  color: var(--green-dark);
}
.badge-pending {
  background: var(--orange-light);
  color: var(--orange-dark);
}

/* 柱状图 */
.chart-card { padding: 28rpx 20rpx; margin-top: 20rpx; }
.bar-chart {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  height: 180rpx;
  padding-bottom: 8rpx;
}
.bar-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
  gap: 8rpx;
}
.bar-wrap {
  width: 32rpx;
  height: 160rpx;
  display: flex;
  align-items: flex-end;
}
.bar-fill {
  width: 100%;
  background: var(--green-light);
  border-radius: 8rpx 8rpx 0 0;
  transition: height 0.4s ease;
}
.bar-fill.today { background: var(--green); }
.bar-label { font-size: 20rpx; color: var(--text-3); font-weight: 600; }

.chart-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 20rpx;
  padding: 0 12rpx;
  border-top: 2rpx solid var(--border);
  padding-top: 16rpx;
}
.chart-total-label { font-size: 24rpx; color: var(--text-3); }
.chart-total-val { font-size: 34rpx; font-weight: 800; color: var(--green); }
