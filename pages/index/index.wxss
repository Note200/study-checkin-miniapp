/* ===== 首页 — 多邻国风格 ===== */
.container {
  background: var(--bg);
  min-height: 100vh;
}

/* 绿色渐变头部 — 紧凑 */
.header {
  background: linear-gradient(135deg, #58CC02 0%, #46a302 100%);
  padding: 28rpx 24rpx 20rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.header-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
}
.avatar {
  width: 76rpx;
  height: 76rpx;
  border-radius: 50%;
  border: 3rpx solid rgba(255,255,255,0.6);
}
.header-text { display: flex; flex-direction: column; gap: 6rpx; }
.nickname {
  font-size: 34rpx;
  font-weight: 800;
  color: #fff;
}
.slogan {
  font-size: 24rpx;
  color: rgba(255,255,255,0.9);
  font-weight: 600;
}
.bell-btn {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.25);
  display: flex;
  align-items: center;
  justify-content: center;
}
.bell-icon { font-size: 36rpx; }

.header-right {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

/* 连续打卡火焰徽章 */
.streak-badge {
  background: rgba(255,255,255,0.3);
  border-radius: 40rpx;
  padding: 8rpx 20rpx;
  display: flex;
  align-items: center;
  gap: 6rpx;
}
.streak-fire { font-size: 28rpx; }
.streak-num {
  font-size: 28rpx;
  font-weight: 800;
  color: #fff;
}

/* 公告横幅 — 紧凑 */
.notice-bar {
  background: var(--gold-light);
  margin: 0 20rpx;
  margin-top: -16rpx;
  border-radius: 12rpx;
  padding: 14rpx 20rpx;
  display: flex;
  align-items: center;
  gap: 10rpx;
  border: 2rpx solid var(--gold);
}
.notice-icon { font-size: 28rpx; }
.notice-text { font-size: 24rpx; color: var(--gold-dark); flex: 1; font-weight: 600; }

/* 段落标题 — 紧凑间距 */
.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 24rpx 0;
}
.section-title { font-size: 32rpx; font-weight: 800; color: var(--text-1); }
.section-right { font-size: 26rpx; color: var(--text-3); }
.section-right.green { color: var(--green); font-weight: 700; }

/* 快捷功能 — 紧凑4列 */
.quick-grid {
  display: flex;
  flex-wrap: wrap;
  padding: 12rpx;
  margin: 0 20rpx;
  background: #fff;
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow);
}
.quick-item {
  width: 33.33%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 20rpx 0 14rpx;
  gap: 8rpx;
  transition: transform 0.1s ease;
  border-radius: 16rpx;
  margin: 2rpx 0;
}
.quick-item:nth-child(1) { background: #e8f5e9; }
.quick-item:nth-child(2) { background: #e3f2fd; }
.quick-item:nth-child(3) { background: #f3e5f5; }
.quick-item:nth-child(4) { background: #fff3e0; }
.quick-item:nth-child(5) { background: #fce4ec; }
.quick-item:nth-child(6) { background: #e0f7fa; }
.quick-item:active {
  transform: scale(0.9);
}
.quick-icon-img {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  display: block;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.1);
  transition: transform 0.1s ease;
}
.quick-item:active .quick-icon-img {
  transform: scale(0.92);
}
.quick-label { font-size: 22rpx; color: var(--text-2); font-weight: 600; }

/* 今日课程横向滚动 — 紧凑 */
.course-scroll {
  white-space: nowrap;
  padding: 0 24rpx 0;
}
.course-chip {
  display: inline-flex;
  flex-direction: column;
  background: #fff;
  border-radius: 14rpx;
  padding: 16rpx 20rpx;
  margin-right: 12rpx;
  width: 260rpx;
  box-shadow: var(--shadow-sm);
  vertical-align: top;
  overflow: hidden;
  position: relative;
  border: 2rpx solid var(--border);
  transition: transform 0.1s ease;
}
.course-chip:active {
  transform: scale(0.95);
}
.course-chip-bar {
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 8rpx;
  border-radius: 16rpx 0 0 16rpx;
}
.course-chip-name {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text-1);
  margin-bottom: 8rpx;
  padding-left: 16rpx;
}
.course-chip-info {
  font-size: 22rpx;
  color: var(--text-3);
  padding-left: 16rpx;
}

/* 今日进度卡片 — 紧凑 */
.progress-card {
  margin-top: 12rpx;
  padding: 24rpx;
}
.ring-row {
  display: flex;
  align-items: center;
  gap: 28rpx;
  margin-bottom: 20rpx;
}
.ring-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}
.ring-bg {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: background 0.6s ease;
}
.ring-inner {
  width: 104rpx;
  height: 104rpx;
  border-radius: 50%;
  background: #fff;
  display: flex;
  flex-direction: row;
  align-items: baseline;
  justify-content: center;
  box-sizing: border-box;
  padding-top: 32rpx;
}
.ring-num {
  font-size: 40rpx;
  font-weight: 800;
  color: var(--green);
  line-height: 1;
}
.ring-unit {
  font-size: 26rpx;
  color: var(--green);
  font-weight: 700;
  line-height: 1;
  margin-left: 2rpx;
}
.ring-label {
  font-size: 22rpx;
  color: var(--text-3);
  font-weight: 600;
}
.ring-stats {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}
.stat-item {
  display: flex;
  align-items: center;
  justify-content: flex-start;
  gap: 8rpx;
}
.stat-val {
  font-size: 28rpx;
  font-weight: 800;
  color: var(--text-1);
}
.stat-val.green { color: var(--green); }
.stat-val.orange { color: var(--orange); }
.stat-label {
  font-size: 24rpx;
  color: var(--text-3);
}

/* 任务列表 */
.task-list { display: flex; flex-direction: column; gap: 0; position: relative; }

/* 左滑容器 — 快速响应 */
.swipe-wrap {
  position: relative;
  overflow: hidden;
  border-bottom: 2rpx solid var(--border);
}
.swipe-wrap:last-child { border-bottom: none; }
.swipe-content {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  gap: 16rpx;
  position: relative;
  background: #fff;
  z-index: 2;
  transition: transform 0.12s ease-out;
}
.swipe-actions {
  position: absolute;
  right: 0;
  top: 0;
  bottom: 0;
  width: 160rpx;
  display: flex;
  z-index: 1;
}
.swipe-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 700;
  color: #fff;
}
.btn-do { background: var(--green); }
.btn-undo { background: var(--orange); }

/* 勾选圆 */
.task-check {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  border: 4rpx solid var(--border);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  color: #fff;
  font-size: 22rpx;
  transition: all 0.2s;
}
.task-check.checked {
  background: var(--green);
  border-color: var(--green);
}

.task-meta { flex: 1; min-width: 0; overflow: hidden; }
.task-name { font-size: 28rpx; color: var(--text-1); display: block; line-height: 1.4; font-weight: 600; }
.task-name.done-text { color: var(--text-3); text-decoration: line-through; }
.task-sub { font-size: 22rpx; color: var(--text-3); margin-top: 4rpx; display: block; line-height: 1.4; }

/* 状态标签 */
.task-badge {
  font-size: 22rpx;
  font-weight: 700;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 40rpx;
}
.badge-done {
  background: var(--green-light);
  color: var(--green-dark);
}
.badge-pending {
  background: var(--orange-light);
  color: var(--orange-dark);
}

/* 柱状图 — 紧凑 */
.chart-card {
  padding: 20rpx 16rpx;
  margin-top: 12rpx;
  position: relative;
}
.bar-chart {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  height: 150rpx;
  padding-bottom: 8rpx;
  position: relative;
}
.bar-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-end;
  flex: 1;
  gap: 8rpx;
  position: relative;
  z-index: 1;
}
.bar-wrap {
  width: 40rpx;
  height: 130rpx;
  display: flex;
  align-items: flex-end;
  position: relative;
}
.bar-fill {
  width: 100%;
  background: var(--green-light);
  border-radius: 8rpx 8rpx 0 0;
  transition: height 0.4s ease;
  min-height: 8rpx;
}
.bar-fill.today { background: var(--green); }
.bar-label { font-size: 20rpx; color: var(--text-3); font-weight: 600; }

/* 柱状图浮层提示 */
.bar-tooltip {
  position: absolute;
  left: 50%;
  bottom: calc(100% + 8rpx);
  transform: translateX(-50%);
  background: #1a1a1a;
  color: #fff;
  font-size: 22rpx;
  font-weight: 700;
  padding: 8rpx 16rpx;
  border-radius: 10rpx;
  white-space: nowrap;
  z-index: 10;
  pointer-events: none;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.25);
}
.bar-tooltip::after {
  content: '';
  position: absolute;
  top: 100%;
  left: 50%;
  transform: translateX(-50%);
  border: 8rpx solid transparent;
  border-top-color: #1a1a1a;
}

.chart-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 20rpx;
  padding: 0 12rpx;
  border-top: 2rpx solid var(--border);
  padding-top: 16rpx;
}
.chart-total-label { font-size: 24rpx; color: var(--text-3); }
.chart-total-val { font-size: 34rpx; font-weight: 800; color: var(--green); }

/* 每日名言 — 紧凑单行 */
.quote-bar {
  background: rgba(255,255,255,0.15);
  padding: 10rpx 24rpx;
}
.quote-inline {
  font-size: 22rpx;
  color: rgba(255,255,255,0.9);
  font-weight: 500;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 成就里程碑 — 紧凑 */
.milestone-bar {
  margin: 10rpx 20rpx 0;
  padding: 14rpx 24rpx;
  background: linear-gradient(135deg, #fff8e1 0%, #ffecb3 100%);
  border-radius: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid #ffe082;
}
.milestone-emoji { font-size: 30rpx; margin-right: 10rpx; }
.milestone-text {
  font-size: 24rpx;
  color: #e65100;
  font-weight: 700;
}

/* 火焰脉冲动画 */
.pulse-fire {
  animation: firePulse 2s ease-in-out infinite;
}
@keyframes firePulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.1); box-shadow: 0 0 16rpx rgba(255,152,0,0.4); }
}

/* 卡片入场动画 — 快速 */
.card-enter {
  animation: cardSlideIn 0.2s ease-out both;
}
@keyframes cardSlideIn {
  from { opacity: 0; transform: translateY(16rpx); }
  to { opacity: 1; transform: translateY(0); }
}
.card-enter:nth-child(2) { animation-delay: 0.04s; }
.card-enter:nth-child(3) { animation-delay: 0.08s; }
.card-enter:nth-child(4) { animation-delay: 0.12s; }
.card-enter:nth-child(5) { animation-delay: 0.16s; }
.card-enter:nth-child(6) { animation-delay: 0.2s; }
