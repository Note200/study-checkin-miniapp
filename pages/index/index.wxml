<view class="container">

  <!-- 顶部绿色渐变头部 -->
  <view class="header">
    <view class="header-left">
      <image class="avatar" src="{{userInfo.avatar || '/assets/icons/default_avatar.png'}}" mode="aspectFill" bindtap="goProfile"/>
      <view class="header-text">
        <text class="nickname">{{userInfo.nickname || '同学'}}，{{greeting}}！</text>
        <text class="slogan">{{motivation}}</text>
      </view>
    </view>
    <view class="header-right">
      <!-- 连续打卡火焰徽章 -->
      <view class="streak-badge" wx:if="{{streakDays > 0}}">
        <text class="streak-fire">🔥</text>
        <text class="streak-num">{{streakDays}}</text>
      </view>
      <view class="bell-btn" bindtap="goAdmin" wx:if="{{isAdmin}}">
        <text class="bell-icon">🔔</text>
      </view>
    </view>
  </view>

  <!-- 公告横幅 -->
  <view class="notice-bar" wx:if="{{notice}}">
    <text class="notice-icon">📢</text>
    <text class="notice-text">{{notice}}</text>
  </view>

  <!-- 快捷功能 — 6个彩色入口 -->
  <view class="section-header">
    <text class="section-title">快捷功能</text>
  </view>
  <view class="quick-grid">
    <view class="quick-item" bindtap="goCheckin">
      <image class="quick-icon-img" src="/assets/icons/quick-checkin.png" mode="aspectFit"/>
      <text class="quick-label">每日打卡</text>
    </view>
    <view class="quick-item" bindtap="goRank">
      <image class="quick-icon-img" src="/assets/icons/quick-rank.png" mode="aspectFit"/>
      <text class="quick-label">排行榜</text>
    </view>
    <view class="quick-item" bindtap="goCourse">
      <image class="quick-icon-img" src="/assets/icons/quick-course.png" mode="aspectFit"/>
      <text class="quick-label">课程表</text>
    </view>
    <view class="quick-item" bindtap="goPlan">
      <image class="quick-icon-img" src="/assets/icons/quick-plan.png" mode="aspectFit"/>
      <text class="quick-label">学习计划</text>
    </view>
    <view class="quick-item" bindtap="goCircle">
      <image class="quick-icon-img" src="/assets/icons/quick-circle.png" mode="aspectFit"/>
      <text class="quick-label">班级圈</text>
    </view>
    <view class="quick-item" bindtap="goStats">
      <image class="quick-icon-img" src="/assets/icons/quick-stats.png" mode="aspectFit"/>
      <text class="quick-label">学习统计</text>
    </view>
    <view class="quick-item" bindtap="goProfile">
      <image class="quick-icon-img" src="/assets/icons/quick-profile.png" mode="aspectFit"/>
      <text class="quick-label">我的</text>
    </view>
  </view>

  <!-- 今日课程 -->
  <view class="section-header" wx:if="{{todayCourses.length > 0}}">
    <text class="section-title">今日课程</text>
    <text class="section-right green" bindtap="goCourse">查看课表 ›</text>
  </view>
  <scroll-view class="course-scroll" scroll-x wx:if="{{todayCourses.length > 0}}">
    <view class="course-chip" wx:for="{{todayCourses}}" wx:key="id" bindtap="goCourse">
      <view class="course-chip-bar" style="background: {{item.color || 'var(--blue)'}}"></view>
      <text class="course-chip-name">{{item.name}}</text>
      <text class="course-chip-info">第{{item.startSection}}-{{item.endSection}}节 · {{item.classroom}}</text>
    </view>
  </scroll-view>

  <!-- 今日进度 -->
  <view class="section-header" bindtap="goCheckin">
    <text class="section-title">今日进度</text>
    <text class="section-right green" bindtap="goCheckin">查看详情 ›</text>
  </view>
  <view class="card progress-card" bindtap="goCheckin">
    <!-- 环形进度 + 学习时长 -->
    <view class="ring-row">
      <view class="ring-wrap">
        <view class="ring-bg" style="background: conic-gradient(var(--green) {{todayRate}}%, var(--border) {{todayRate}}%);">
          <view class="ring-inner">
            <text class="ring-num">{{todayRate}}</text>
            <text class="ring-unit">%</text>
          </view>
        </view>
        <text class="ring-label">完成率</text>
      </view>
      <view class="ring-stats">
        <view class="stat-item">
          <text class="stat-val green">{{studyHours.done}}</text>
          <text class="stat-label">已学时长(h)</text>
        </view>
        <view class="stat-item">
          <text class="stat-val">{{studyHours.target}}</text>
          <text class="stat-label">目标时长(h)</text>
        </view>
        <view class="stat-item" wx:if="{{streakDays > 0}}">
          <text class="stat-val orange">🔥 {{streakDays}}</text>
          <text class="stat-label">连续打卡(天)</text>
        </view>
      </view>
    </view>

    <!-- 今日任务列表（支持左滑） -->
    <view class="task-list">
      <view class="swipe-wrap" wx:for="{{todayTasks}}" wx:key="id">
        <view 
          class="swipe-content {{item.todayChecked ? 'done' : ''}} {{item.swiped ? 'swiped' : ''}}"
          style="transform: translateX({{item.swiped ? -160 : 0}}rpx)"
          data-id="{{item.id}}" 
          data-index="{{index}}"
          bindtap="goCheckin"
          bindtouchstart="onSwipeStart"
          bindtouchmove="onSwipeMove"
          bindtouchend="onSwipeEnd">
          <view class="task-check {{item.todayChecked ? 'checked' : ''}}">
            <text wx:if="{{item.todayChecked}}">✓</text>
          </view>
          <view class="task-meta">
            <text class="task-name {{item.todayChecked ? 'done-text' : ''}}">{{item.title}}</text>
            <text class="task-sub">{{item.courseName || '习惯打卡'}} · {{item.targetMinutes || 30}}分钟</text>
          </view>
          <text class="task-badge {{item.todayChecked ? 'badge-done' : 'badge-pending'}}">
            {{item.todayChecked ? '已完成' : '待完成'}}
          </text>
        </view>
        <view class="swipe-actions">
          <view class="swipe-btn {{item.todayChecked ? 'btn-undo' : 'btn-do'}}" data-id="{{item.id}}" data-checked="{{item.todayChecked}}" bindtap="quickCheckin">
            <text>{{item.todayChecked ? '撤销' : '打卡'}}</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 无任务空状态 -->
    <view class="empty-tip" wx:if="{{todayTasks.length === 0}}">
      <text>暂无打卡任务，去创建一个吧</text>
    </view>
  </view>

  <!-- 本周学习时长 -->
  <view class="section-header" bindtap="goStats">
    <text class="section-title">本周学习时长</text>
    <text class="section-right green">详细报告 ›</text>
  </view>
  <view class="card chart-card" bindtap="goStats">
    <!-- 简易柱状图 -->
    <view class="bar-chart">
      <view class="bar-item" wx:for="{{weekData}}" wx:key="day" bindtap="onBarTap" data-index="{{index}}">
        <view class="bar-wrap">
          <view class="bar-fill {{item.isToday ? 'today' : ''}}" style="height: {{item.height}}rpx"></view>
          <view class="bar-tooltip" wx:if="{{tooltipIndex === index}}">{{item.hours}}h</view>
        </view>
        <text class="bar-label">{{item.day}}</text>
      </view>
    </view>
    <view class="chart-footer">
      <text class="chart-total-label">本周累计</text>
      <text class="chart-total-val">{{weekTotal}} 小时</text>
    </view>
  </view>

</view>
