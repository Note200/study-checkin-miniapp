<view class="container">
  <!-- 顶部欢迎区域 -->
  <view class="header">
    <view class="user-info">
      <image class="avatar" src="{{userInfo.avatar || '/assets/icons/profile.png'}}" mode="aspectFill"/>
      <view class="user-text">
        <text class="nickname">{{userInfo.nickname || '同学'}}</text>
        <text class="greeting">今天也要加油哦~</text>
      </view>
    </view>
  </view>

  <!-- 打卡统计卡片 -->
  <view class="card checkin-card" bindtap="goCheckin">
    <view class="card-header">
      <text class="card-title">今日打卡</text>
      <text class="card-more">去打卡 ></text>
    </view>
    <view class="stats-row">
      <view class="stat-item">
        <text class="stat-num">{{checkinStats.done}}</text>
        <text class="stat-label">已打卡</text>
      </view>
      <view class="stat-item">
        <text class="stat-num">{{checkinStats.total}}</text>
        <text class="stat-label">目标</text>
      </view>
      <view class="stat-item">
        <text class="stat-num">{{checkinStats.rate}}%</text>
        <text class="stat-label">完成率</text>
      </view>
    </view>
  </view>

  <!-- 今日课程 -->
  <view class="card" bindtap="goCourse">
    <view class="card-header">
      <text class="card-title">今日课程</text>
      <text class="card-more">查看全部 ></text>
    </view>
    <view class="course-list" wx:if="{{todayCourse.length > 0}}">
      <view class="course-item" wx:for="{{todayCourse}}" wx:key="id">
        <view class="course-color" style="background: {{item.color}}"></view>
        <view class="course-info">
          <text class="course-name">{{item.name}}</text>
          <text class="course-detail">{{item.classroom}} · 第{{item.startSection}}-{{item.endSection}}节</text>
        </view>
      </view>
    </view>
    <view class="empty-tip" wx:else>
      <text>今日无课程安排</text>
    </view>
  </view>

  <!-- 今日计划 -->
  <view class="card" bindtap="goPlan">
    <view class="card-header">
      <text class="card-title">今日计划</text>
      <text class="card-more">查看全部 ></text>
    </view>
    <view class="plan-list" wx:if="{{todayPlans.length > 0}}">
      <view class="plan-item {{item.status === 1 ? 'done' : ''}}" wx:for="{{todayPlans}}" wx:key="id">
        <icon type="{{item.status === 1 ? 'success' : 'circle'}}" size="20" color="{{item.status === 1 ? '#67C23A' : '#999'}}"/>
        <text class="plan-title">{{item.title}}</text>
      </view>
    </view>
    <view class="empty-tip" wx:else>
      <text>暂无计划，去制定一个吧</text>
    </view>
  </view>
</view>
