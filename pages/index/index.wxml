<view class="container">

  <!-- 顶部绿色渐变头部 -->
  <view class="header">
    <view class="header-left">
      <image class="avatar" src="{{userInfo.avatar || '/assets/icons/default_avatar.png'}}" mode="aspectFill" bindtap="goProfile"/>
      <view class="header-text">
        <view class="nickname">{{userInfo.nickname || '同学'}}，{{greeting}}！</view>
        <view class="slogan">{{motivation}}</view>
      </view>
    </view>
    <view class="header-right">
      <!-- 连续打卡火焰徽章 -->
      <view class="streak-badge pulse-fire" wx:if="{{streakDays > 0}}">
        <view class="streak-fire">🔥</view>
        <view class="streak-num">{{streakDays}}</view>
      </view>
      <view class="bell-btn" bindtap="goAdmin" wx:if="{{isAdmin}}">
        <view class="bell-icon">🔔</view>
      </view>
    </view>
  </view>
  <!-- 每日名言 — 紧凑单行 -->
  <view class="quote-bar" wx:if="{{dailyQuote.text}}">
    <text class="quote-inline">「{{dailyQuote.text}}」—— {{dailyQuote.author}}</text>
  </view>

  <!-- 公告横幅 -->
  <view class="notice-bar" wx:if="{{notice}}">
    <view class="notice-icon">📢</view>
    <view class="notice-text">{{notice}}</view>
  </view>

  <!-- 快捷功能 — 紧凑网格 -->
  <view class="quick-grid">
    <view class="quick-item" bindtap="goCheckin">
      <image class="quick-icon-img" src="/assets/icons/quick-checkin.png" mode="aspectFit"/>
      <view class="quick-label">打卡</view>
    </view>
    <view class="quick-item" bindtap="goCourse">
      <image class="quick-icon-img" src="/assets/icons/quick-course.png" mode="aspectFit"/>
      <view class="quick-label">课表</view>
    </view>
    <view class="quick-item" bindtap="goPlan">
      <image class="quick-icon-img" src="/assets/icons/quick-plan.png" mode="aspectFit"/>
      <view class="quick-label">计划</view>
    </view>
    <view class="quick-item" bindtap="goRank">
      <image class="quick-icon-img" src="/assets/icons/quick-rank.png" mode="aspectFit"/>
      <view class="quick-label">排行</view>
    </view>
    <view class="quick-item" bindtap="goCircle">
      <image class="quick-icon-img" src="/assets/icons/quick-circle.png" mode="aspectFit"/>
      <view class="quick-label">班级圈</view>
    </view>
    <view class="quick-item" bindtap="goStats">
      <image class="quick-icon-img" src="/assets/icons/quick-stats.png" mode="aspectFit"/>
      <view class="quick-label">统计</view>
    </view>
  </view>

  <!-- 成就里程碑 -->
  <view class="milestone-bar card-enter" wx:if="{{milestone}}">
    <view class="milestone-emoji">{{milestone.emoji}}</view>
    <view class="milestone-text">已连续打卡 {{streakDays}} 天 · {{milestone.label}}</view>
  </view>

  <!-- 今日课程 -->
  <view class="section-header" wx:if="{{todayCourses.length > 0}}">
    <view class="section-title">今日课程</view>
    <view class="section-right green" bindtap="goCourse">查看课表 ›</view>
  </view>
  <scroll-view class="course-scroll" scroll-x wx:if="{{todayCourses.length > 0}}">
    <view class="course-chip" wx:for="{{todayCourses}}" wx:key="id" bindtap="goCourse">
      <view class="course-chip-bar" style="background: {{item.color || 'var(--blue)'}}"></view>
      <view class="course-chip-name">{{item.name}}</view>
      <view class="course-chip-info">第{{item.startSection}}-{{item.endSection}}节 · {{item.classroom}}</view>
    </view>
  </scroll-view>

  <!-- 今日进度 -->
  <view class="section-header" bindtap="goCheckin">
    <view class="section-title">今日进度</view>
    <view class="section-right green" bindtap="goCheckin">查看详情 ›</view>
  </view>
  <view class="card progress-card card-enter" bindtap="goCheckin">
    <!-- 环形进度 + 学习时长 -->
    <view class="ring-row">
      <view class="ring-wrap">
        <view class="ring-bg" style="background: conic-gradient(var(--green) {{todayRate}}%, var(--border) {{todayRate}}%);">
          <view class="ring-inner">
            <view class="ring-num">{{todayRate}}</view>
            <view class="ring-unit">%</view>
          </view>
        </view>
        <view class="ring-label">完成率</view>
      </view>
      <view class="ring-stats">
        <view class="stat-item">
          <view class="stat-val green">{{studyHours.done}}</view>
          <view class="stat-label">已学时长(h)</view>
        </view>
        <view class="stat-item">
          <view class="stat-val">{{studyHours.target}}</view>
          <view class="stat-label">目标时长(h)</view>
        </view>
        <view class="stat-item" wx:if="{{streakDays > 0}}">
          <view class="stat-val orange">🔥 {{streakDays}}</view>
          <view class="stat-label">连续打卡(天)</view>
        </view>
      </view>
    </view>

    <!-- 今日任务列表（支持左滑） -->
    <view class="task-list">
      <view class="swipe-wrap" wx:for="{{todayTasks}}" wx:key="id">
        <view 
          class="swipe-content {{item.todayChecked ? 'done' : ''}} {{item.swiped ? 'swiped' : ''}}"
          style="transform: translateX({{item.swiped ? -160 : 0}}rpx)"
          data-id="{{item.id}}" 
          data-index="{{index}}"
          bindtap="goCheckin"
          bindlongpress="longPressTask"
          bindtouchstart="onSwipeStart"
          bindtouchmove="onSwipeMove"
          bindtouchend="onSwipeEnd">
          <view class="task-check {{item.todayChecked ? 'checked' : ''}}">
            <view wx:if="{{item.todayChecked}}">✓</view>
          </view>
          <view class="task-meta">
            <view class="task-name {{item.todayChecked ? 'done-text' : ''}}">{{item.title}}</view>
            <view class="task-sub">{{item.courseName || '习惯打卡'}} · {{item.targetMinutes || 30}}分钟</view>
          </view>
          <view class="task-badge {{item.todayChecked ? 'badge-done' : 'badge-pending'}}">
            {{item.todayChecked ? '已完成' : '待完成'}}
          </view>
        </view>
        <view class="swipe-actions">
          <view class="swipe-btn {{item.todayChecked ? 'btn-undo' : 'btn-do'}}" data-id="{{item.id}}" data-checked="{{item.todayChecked}}" bindtap="quickCheckin">
            <view>{{item.todayChecked ? '撤销' : '打卡'}}</view>
          </view>
        </view>
      </view>
    </view>

    <!-- 无任务空状态 -->
    <view class="empty-tip" wx:if="{{todayTasks.length === 0}}">
      <view>暂无打卡任务，去创建一个吧</view>
    </view>
  </view>

  <!-- 本周学习时长 -->
  <view class="section-header" bindtap="goStats">
    <view class="section-title">本周学习时长</view>
    <view class="section-right green">详细报告 ›</view>
  </view>
  <view class="card chart-card card-enter" bindtap="goStats">
    <!-- 简易柱状图 -->
    <view class="bar-chart">
      <view class="bar-item" wx:for="{{weekData}}" wx:key="day" catchtap="onBarTap" data-index="{{index}}">
        <view class="bar-wrap">
          <view class="bar-fill {{item.isToday ? 'today' : ''}}" style="height: {{item.height}}rpx"></view>
          <view class="bar-tooltip" wx:if="{{tooltipIndex === index}}">{{item.hours}}h</view>
        </view>
        <view class="bar-label">{{item.day}}</view>
      </view>
    </view>
    <view class="chart-footer">
      <view class="chart-total-label">本周累计</view>
      <view class="chart-total-val">{{weekTotal}} 小时</view>
    </view>
  </view>

</view>
