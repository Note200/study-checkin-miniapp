/* app.wxss - 全局样式 - Modern Design System */
page {
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'SF Pro Display', 'Helvetica Neue', sans-serif;
  background: #f0f2f8;
  color: #1a1a2e;
  box-sizing: border-box;
  -webkit-font-smoothing: antialiased;
}

/* ==================== 主题色 ==================== */
/* 主色渐变: #6C5CE7 → #a855f7 (现代紫) */
/* 辅助: #f8f9fe 浅紫背景 */

/* ==================== 全局过渡 ==================== */
view, text, image, button, input, textarea, picker {
  transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
}

/* ==================== 卡片通用 ==================== */
.card {
  background: #fff;
  border-radius: 28rpx;
  box-shadow: 0 2rpx 20rpx rgba(108, 92, 231, 0.06), 0 1rpx 4rpx rgba(0,0,0,0.03);
  backdrop-filter: blur(10px);
}

/* ==================== 通用主按钮 ==================== */
.btn-primary {
  background: linear-gradient(135deg, #6C5CE7 0%, #a855f7 100%);
  color: #fff;
  border-radius: 60rpx;
  font-size: 30rpx;
  font-weight: 600;
  border: none;
  padding: 24rpx 0;
  box-shadow: 0 8rpx 28rpx rgba(108, 92, 231, 0.35);
  letter-spacing: 2rpx;
}

.btn-primary:active {
  transform: scale(0.97);
  box-shadow: 0 4rpx 16rpx rgba(108, 92, 231, 0.25);
}

/* ==================== 通用表单输入框 ==================== */
.form-input-group {
  display: flex;
  align-items: center;
  background: #f8f9fe;
  border-radius: 52rpx;
  padding: 26rpx 32rpx;
  margin-bottom: 24rpx;
  border: 2rpx solid transparent;
}

.form-input-group:focus-within {
  background: #fff;
  border-color: #6C5CE7;
  box-shadow: 0 0 0 6rpx rgba(108, 92, 231, 0.08);
}

.form-input-group .input {
  flex: 1;
  font-size: 28rpx;
  color: #1a1a2e;
}

.form-input-group .input-placeholder {
  color: #b8b8d0;
}

/* ==================== 通用 FAB 按钮 ==================== */
.fab {
  position: fixed;
  right: 36rpx;
  bottom: 100rpx;
  width: 108rpx;
  height: 108rpx;
  background: linear-gradient(135deg, #6C5CE7 0%, #a855f7 100%);
  border-radius: 54rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 12rpx 36rpx rgba(108, 92, 231, 0.4);
  z-index: 100;
}

.fab:active {
  transform: scale(0.9);
}

.fab-icon {
  font-size: 56rpx;
  color: #fff;
  font-weight: 300;
  line-height: 1;
}

/* ==================== 通用弹窗 ==================== */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(10, 10, 30, 0.45);
  backdrop-filter: blur(6px);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
  animation: fadeIn 0.2s ease;
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

@keyframes slideUp {
  from { transform: translateY(40rpx); opacity: 0; }
  to { transform: translateY(0); opacity: 1; }
}

.modal-content {
  background: #fff;
  border-radius: 32rpx;
  padding: 48rpx 40rpx;
  width: 620rpx;
  box-sizing: border-box;
  animation: slideUp 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
  box-shadow: 0 24rpx 60rpx rgba(0,0,0,0.12);
}

.modal-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1a1a2e;
  margin-bottom: 32rpx;
  text-align: center;
  letter-spacing: 1rpx;
}

.modal-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 32rpx;
}

.modal-btn {
  flex: 1;
  height: 92rpx;
  line-height: 92rpx;
  border-radius: 46rpx;
  font-size: 28rpx;
  font-weight: 600;
  padding: 0;
  margin: 0;
}

.modal-btn.cancel {
  background: #f0f2f8;
  color: #6b7280;
}

.modal-btn.cancel:active {
  background: #e5e7ef;
}

.modal-btn.confirm {
  background: linear-gradient(135deg, #6C5CE7 0%, #a855f7 100%);
  color: #fff;
  box-shadow: 0 6rpx 18rpx rgba(108, 92, 231, 0.3);
}

.modal-btn.confirm:active {
  transform: scale(0.97);
}

/* ==================== 通用标签页 ==================== */
.tabs {
  background: #fff;
  display: flex;
  padding: 16rpx 20rpx;
  gap: 12rpx;
}

.tab {
  flex: 1;
  text-align: center;
  padding: 18rpx 0;
  font-size: 28rpx;
  color: #9ca3af;
  border-radius: 16rpx;
  font-weight: 500;
  position: relative;
}

.tab.active {
  background: linear-gradient(135deg, #6C5CE7 0%, #a855f7 100%);
  color: #fff;
  font-weight: 700;
  box-shadow: 0 4rpx 16rpx rgba(108, 92, 231, 0.3);
}

/* ==================== 通用空状态 ==================== */
.empty {
  text-align: center;
  color: #d1d5db;
  font-size: 26rpx;
  padding: 100rpx 0;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}

.empty-text {
  font-size: 28rpx;
  color: #9ca3af;
}

.empty-tip {
  text-align: center;
  padding: 60rpx 0;
}

.empty-tip text {
  font-size: 26rpx;
  color: #9ca3af;
}

/* ==================== 通用滚动区域 ==================== */
scroll-view {
  -webkit-overflow-scrolling: touch;
}

/* 隐藏滚动条 */
::-webkit-scrollbar {
  display: none;
}
