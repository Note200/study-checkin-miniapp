/* ===== 全局变量 ===== */
page {
  --primary: #07C160;
  --primary-dark: #06AE56;
  --primary-light: #E8F8EF;
  --primary-grad: linear-gradient(135deg, #2ECC71, #07C160);
  --danger: #F56C6C;
  --warn: #E6A23C;
  --text-1: #1a1a1a;
  --text-2: #555;
  --text-3: #999;
  --bg: #f4f6f8;
  --card-bg: #ffffff;
  --border: #eef0f3;
  --radius-sm: 12rpx;
  --radius-md: 20rpx;
  --radius-lg: 28rpx;
  --shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
  --shadow-green: 0 6rpx 24rpx rgba(7,193,96,0.20);
  background-color: var(--bg);
  font-family: -apple-system, 'PingFang SC', 'Microsoft YaHei', sans-serif;
  font-size: 28rpx;
  color: var(--text-1);
}

/* ===== 通用容器 ===== */
.container {
  min-height: 100vh;
  background: var(--bg);
  padding-bottom: 40rpx;
}

/* ===== 卡片 ===== */
.card {
  background: var(--card-bg);
  border-radius: var(--radius-lg);
  padding: 32rpx;
  margin: 24rpx 24rpx 0;
  box-shadow: var(--shadow);
}
.card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}
.card-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-1);
}
.card-more {
  font-size: 26rpx;
  color: var(--primary);
}
.card-count {
  font-size: 24rpx;
  color: var(--text-3);
}

/* ===== 按钮 ===== */
.btn-primary {
  background: var(--primary);
  color: #fff;
  border-radius: 50rpx;
  font-size: 28rpx;
  font-weight: 600;
  border: none;
  padding: 18rpx 48rpx;
  box-shadow: var(--shadow-green);
  transition: all 0.15s;
}
.btn-primary:active { transform: scale(0.96); opacity: 0.88; }

.btn-outline {
  background: transparent;
  color: var(--primary);
  border: 2rpx solid var(--primary);
  border-radius: 50rpx;
  font-size: 28rpx;
  padding: 16rpx 40rpx;
}

.btn-small {
  background: var(--primary);
  color: #fff;
  border-radius: 12rpx;
  font-size: 24rpx;
  padding: 10rpx 24rpx;
  border: none;
  line-height: 1.6;
}

/* ===== FAB ===== */
.fab {
  position: fixed;
  right: 40rpx;
  bottom: 120rpx;
  width: 100rpx;
  height: 100rpx;
  background: var(--primary);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: var(--shadow-green);
  z-index: 99;
  color: #fff;
  font-size: 52rpx;
  line-height: 1;
  font-weight: 300;
}
.fab:active { transform: scale(0.92); }

/* ===== 表单输入框 ===== */
.form-input-group {
  background: #f7f8fa;
  border-radius: 14rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
  border: 2rpx solid transparent;
  transition: border 0.2s;
}
.form-input-group.focused {
  border-color: var(--primary);
  background: #fff;
}
.form-input-group input {
  padding: 24rpx 28rpx;
  font-size: 28rpx;
  color: var(--text-1);
  width: 100%;
  box-sizing: border-box;
}

/* ===== 弹窗 ===== */
.modal-mask {
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.45);
  z-index: 100;
  display: flex;
  align-items: flex-end;
  justify-content: center;
}
.modal-content {
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  padding: 40rpx 32rpx calc(40rpx + env(safe-area-inset-bottom));
  width: 100%;
  animation: slideUp 0.25s ease;
}
@keyframes slideUp {
  from { transform: translateY(100%); }
  to   { transform: translateY(0); }
}
.modal-title {
  font-size: 34rpx;
  font-weight: 700;
  text-align: center;
  margin-bottom: 32rpx;
  color: var(--text-1);
}
.modal-textarea {
  width: 100%;
  min-height: 120rpx;
  background: #f7f8fa;
  border-radius: 14rpx;
  padding: 20rpx;
  font-size: 26rpx;
  box-sizing: border-box;
  margin-bottom: 20rpx;
}
.modal-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 24rpx;
}
.modal-btn {
  flex: 1;
  border-radius: 50rpx;
  font-size: 30rpx;
  font-weight: 600;
  border: none;
  padding: 22rpx 0;
  line-height: 1;
}
.modal-btn.cancel {
  background: #f2f3f5;
  color: var(--text-2);
}
.modal-btn.confirm {
  background: var(--primary);
  color: #fff;
  box-shadow: var(--shadow-green);
}
.modal-btn.confirm:active { transform: scale(0.97); }

/* ===== 空状态 ===== */
.empty-state, .empty-tip {
  text-align: center;
  padding: 60rpx 0;
  color: var(--text-3);
  font-size: 26rpx;
}

/* ===== 进度条 ===== */
.progress-bar {
  height: 10rpx;
  background: #eee;
  border-radius: 10rpx;
  overflow: hidden;
}
.progress-fill {
  height: 100%;
  background: var(--primary);
  border-radius: 10rpx;
  transition: width 0.4s ease;
}

/* ===== 标签 ===== */
.tag {
  display: inline-block;
  padding: 4rpx 14rpx;
  border-radius: 8rpx;
  font-size: 20rpx;
  font-weight: 600;
}
.tag-green { background: var(--primary-light); color: var(--primary); }
.tag-orange { background: #FFF3E0; color: #E6A23C; }
.tag-red { background: #FEF0F0; color: #F56C6C; }
.tag-purple { background: #F3E8FF; color: #9C27B0; }
.tag-blue { background: #E3F2FD; color: #1976D2; }
