/* ===== 全局变量 — 多邻国风格配色 ===== */
page {
  --green: #58CC02;
  --green-dark: #46a302;
  --green-light: #D7FFB8;
  --green-grad: linear-gradient(135deg, #58CC02, #46a302);
  --blue: #1CB0F6;
  --blue-dark: #1899D6;
  --blue-light: #DDF4FF;
  --orange: #FF9600;
  --orange-dark: #E08600;
  --orange-light: #FFE4B8;
  --purple: #CE82FF;
  --purple-dark: #B566E8;
  --purple-light: #F3E0FF;
  --red: #FF4B4B;
  --red-dark: #EA2B2B;
  --red-light: #FFD5D5;
  --gold: #FFC800;
  --gold-dark: #E0B000;
  --gold-light: #FFF3CC;
  --primary: var(--green);
  --primary-dark: var(--green-dark);
  --primary-light: var(--green-light);
  --primary-grad: var(--green-grad);
  --danger: var(--red);
  --warn: var(--orange);
  --text-1: #3C3C3C;
  --text-2: #777;
  --text-3: #AFAFAF;
  --bg: #F7F7F7;
  --card-bg: #ffffff;
  --border: #E5E5E5;
  --radius-sm: 12rpx;
  --radius-md: 20rpx;
  --radius-lg: 24rpx;
  --shadow-sm: 0 2rpx 8rpx rgba(0,0,0,0.06);
  --shadow: 0 4rpx 16rpx rgba(0,0,0,0.08);
  --shadow-green: 0 6rpx 0 var(--green-dark);
  --shadow-blue: 0 6rpx 0 var(--blue-dark);
  --shadow-orange: 0 6rpx 0 var(--orange-dark);
  --shadow-purple: 0 6rpx 0 var(--purple-dark);
  --shadow-red: 0 6rpx 0 var(--red-dark);
  background-color: var(--bg);
  font-family: -apple-system, 'PingFang SC', 'Nunito', 'Microsoft YaHei', sans-serif;
  font-size: 28rpx;
  color: var(--text-1);
}

/* ===== 通用容器 ===== */
.container {
  min-height: 100vh;
  background: var(--bg);
  padding-bottom: 40rpx;
}

/* ===== 卡片 ===== */
.card {
  background: var(--card-bg);
  border-radius: var(--radius-lg);
  padding: 32rpx;
  margin: 24rpx 24rpx 0;
  box-shadow: var(--shadow);
  border: 2rpx solid var(--border);
}
.card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}
.card-title {
  font-size: 32rpx;
  font-weight: 800;
  color: var(--text-1);
}
.card-more {
  font-size: 26rpx;
  color: var(--primary);
  font-weight: 700;
}
.card-count {
  font-size: 24rpx;
  color: var(--text-3);
}

/* ===== 按钮 — 多邻国立体风格 ===== */
.btn-primary {
  background: var(--green);
  color: #fff;
  border-radius: 16rpx;
  font-size: 30rpx;
  font-weight: 800;
  border: none;
  padding: 22rpx 48rpx;
  box-shadow: var(--shadow-green);
  text-transform: uppercase;
  letter-spacing: 2rpx;
  transition: all 0.1s;
}
.btn-primary:active { 
  transform: translateY(4rpx); 
  box-shadow: 0 2rpx 0 var(--green-dark); 
}

.btn-outline {
  background: transparent;
  color: var(--primary);
  border: 4rpx solid var(--border);
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: 700;
  padding: 18rpx 40rpx;
  transition: all 0.1s;
}

.btn-small {
  background: var(--green);
  color: #fff;
  border-radius: 12rpx;
  font-size: 24rpx;
  font-weight: 700;
  padding: 10rpx 24rpx;
  border: none;
  line-height: 1.6;
}

/* ===== FAB ===== */
.fab {
  position: fixed;
  right: 40rpx;
  bottom: 120rpx;
  width: 104rpx;
  height: 104rpx;
  background: var(--green);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 6rpx 0 var(--green-dark);
  z-index: 99;
  color: #fff;
  font-size: 52rpx;
  line-height: 1;
  font-weight: 300;
}
.fab:active { transform: translateY(4rpx); box-shadow: 0 2rpx 0 var(--green-dark); }

/* ===== 表单输入框 ===== */
.form-input-group {
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
  border: 4rpx solid var(--border);
  transition: border 0.2s;
}
.form-input-group.focused {
  border-color: var(--blue);
  background: #fff;
}
.form-input-group input {
  height: 88rpx;
  padding: 0 28rpx;
  font-size: 28rpx;
  color: var(--text-1);
  width: 100%;
  box-sizing: border-box;
  line-height: 88rpx;
}

/* ===== 弹窗 ===== */
.modal-mask {
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.45);
  z-index: 100;
  display: flex;
  align-items: flex-end;
  justify-content: center;
}
.modal-content {
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  padding: 40rpx 32rpx calc(40rpx + env(safe-area-inset-bottom));
  width: 100%;
  animation: slideUp 0.25s ease;
}
@keyframes slideUp {
  from { transform: translateY(100%); }
  to   { transform: translateY(0); }
}
.modal-title {
  font-size: 34rpx;
  font-weight: 800;
  text-align: center;
  margin-bottom: 32rpx;
  color: var(--text-1);
}
.modal-textarea {
  width: 100%;
  min-height: 120rpx;
  background: var(--bg);
  border-radius: 16rpx;
  padding: 20rpx;
  font-size: 26rpx;
  box-sizing: border-box;
  margin-bottom: 20rpx;
}
.modal-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 24rpx;
}
.modal-btn {
  flex: 1;
  border-radius: 16rpx;
  font-size: 30rpx;
  font-weight: 800;
  border: none;
  padding: 22rpx 0;
  line-height: 1;
}
.modal-btn.cancel {
  background: var(--bg);
  color: var(--text-2);
  border-bottom: 4rpx solid var(--border);
}
.modal-btn.confirm {
  background: var(--green);
  color: #fff;
  box-shadow: 0 4rpx 0 var(--green-dark);
}
.modal-btn.confirm:active { transform: translateY(3rpx); box-shadow: 0 1rpx 0 var(--green-dark); }

/* ===== 空状态 ===== */
.empty-state, .empty-tip {
  text-align: center;
  padding: 60rpx 0;
  color: var(--text-3);
  font-size: 26rpx;
}

/* ===== 进度条 ===== */
.progress-bar {
  height: 12rpx;
  background: var(--border);
  border-radius: 12rpx;
  overflow: hidden;
}
.progress-fill {
  height: 100%;
  background: var(--green);
  border-radius: 12rpx;
  transition: width 0.4s ease;
}

/* ===== 标签 ===== */
.tag {
  display: inline-block;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: 700;
}
.tag-green  { background: var(--green-light); color: var(--green-dark); }
.tag-orange { background: var(--orange-light); color: var(--orange-dark); }
.tag-red    { background: var(--red-light); color: var(--red-dark); }
.tag-purple { background: var(--purple-light); color: var(--purple-dark); }
.tag-blue   { background: var(--blue-light); color: var(--blue-dark); }
.tag-gold   { background: var(--gold-light); color: var(--gold-dark); }
